# CONSTANTS
# ═══════════════════════════════════════════════════════════════════

LOG_FORMAT_STANDARD: str = (
    "%(asctime)s | %(levelname)-8s | %(name)s | %(filename)s:%(lineno)d | %(message)s"
)

LOG_FORMAT_JSON_FIELDS: tuple = (
    "@timestamp", "level", "report", "run_id",
    "logger", "module", "filename", "lineno", "message",
)

DEFAULT_MAX_BYTES: int = 50 * 1024 * 1024   # 50 MB
DEFAULT_BACKUP_COUNT: int = 10
NULL_PCT_WARN_THRESHOLD: float = 5.0


# ═══════════════════════════════════════════════════════════════════
# SENSITIVE-DATA MASKING
# ═══════════════════════════════════════════════════════════════════

_MASK_PATTERNS: List[re.Pattern] = [
    re.compile(r"\b\d{3}-\d{2}-\d{4}\b"),                                      # SSN
    re.compile(r"\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b"),        # Email
    re.compile(r"\b(?:4\d{12}(?:\d{3})?|5[1-5]\d{14}|3[47]\d{13})\b"),         # CC
    re.compile(r"(?i)password\s*[:=]\s*\S+"),                                    # password=xxx
    re.compile(r"(?i)pwd\s*[:=]\s*\S+"),                                         # pwd=xxx
]
_MASK_TOKEN: str = "***MASKED***"


def _mask(text: str) -> str:
    """Replace known sensitive patterns with mask token."""
    for pat in _MASK_PATTERNS:
        text = pat.sub(_MASK_TOKEN, text)
    return text


