# TIER 1 - MANDATORY STANDARD
# ===================================================================

def init_logger(report_name, log_dir=None, console=True, env="PROD", json_output=False):
    log_dir = Path(log_dir) if log_dir else Path.cwd()
    log_dir.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    log_file = log_dir / ("%s_%s.log" % (report_name, ts))

    logger = logging.getLogger("regulatory.migration.%s" % report_name)
    logger.setLevel(logging.DEBUG)
    logger.propagate = False
    for h in logger.handlers[:]:
        logger.removeHandler(h)
        h.close()

    fmt = _MaskFormatter(_LOG_FORMAT)
    fh = logging.handlers.RotatingFileHandler(
        log_file, maxBytes=_MAX_BYTES, backupCount=_BACKUP_COUNT, encoding="utf-8")
    fh.setFormatter(fmt)
    logger.addHandler(fh)

    if console:
        ch = logging.StreamHandler(sys.stdout)
        ch.setFormatter(fmt)
        logger.addHandler(ch)

    if json_output:
        class _JF(logging.Formatter):
            def format(self, record):
                return json.dumps({
                    "@timestamp": datetime.fromtimestamp(record.created, tz=timezone.utc).isoformat(),
                    "level": record.levelname, "report": report_name,
                    "run_id": _state(logger)["run_id"],
                    "message": _mask(record.getMessage()),
                }, ensure_ascii=False)
        jf = log_dir / ("%s.jsonl" % report_name)
        jh = logging.handlers.RotatingFileHandler(
            jf, maxBytes=_MAX_BYTES, backupCount=_BACKUP_COUNT, encoding="utf-8")
        jh.setFormatter(_JF())
        logger.addHandler(jh)

    st = _state(logger)
    user = os.environ.get("USER", os.environ.get("USERNAME", "unknown"))
    host = os.environ.get("HOSTNAME", os.environ.get("COMPUTERNAME", "unknown"))
    logger.info("=" * 70)
    logger.info("Program: %s | run_id: %s", report_name, st["run_id"])
    logger.info("Started: %s | User: %s | Host: %s | Env: %s",
                st["start_dt"].strftime("%Y-%m-%d %H:%M:%S"), user, host, env)
    logger.info("=" * 70)
    return logger


def log_query(logger, table_name, sql, connection, source="database", params=None):
    import pandas as pd
    logger.info("QUERY | table=%s | source=%s", table_name, source)
    sql_flat = " ".join(sql.split())
    logger.info("  SQL: %s", sql_flat[:500] + "..." if len(sql_flat) > 500 else sql_flat)
    t0 = time.perf_counter()
    df = pd.read_sql(sql, connection, params=params)
    elapsed = time.perf_counter() - t0
    logger.info("  Result | rows=%d | cols=%d | elapsed=%.2fs", len(df), len(df.columns), elapsed)
    return df


def log_execute(logger, label, sql, connection, source="database"):
    logger.info("EXECUTE | label=%s | source=%s", label, source)
    sql_flat = " ".join(sql.split())
    logger.info("  SQL: %s", sql_flat[:500] + "..." if len(sql_flat) > 500 else sql_flat)
    t0 = time.perf_counter()
    cursor = connection.cursor()
    cursor.execute(sql)
    elapsed = time.perf_counter() - t0
    logger.info("  Done | elapsed=%.2fs", elapsed)


def log_insert(logger, table_name, insert_sql, records, connection, source="SQL Server", database=None):
    target = "%s.dbo.%s" % (database, table_name) if database else "dbo.%s" % table_name
    logger.info("INSERT | rows=%d | target=%s | source=%s", len(records), target, source)
    t0 = time.perf_counter()
    cursor = connection.cursor()
    cursor.fast_executemany = True
    cursor.executemany(insert_sql, records)
    connection.commit()
    elapsed = time.perf_counter() - t0
    logger.info("  Done | elapsed=%.2fs", elapsed)


def log_dataset(logger, name, df, input_name=None, input_nobs=None, where=None):
    nobs = len(df) if df is not None else 0
    nvars = len(df.columns) if df is not None and hasattr(df, "columns") else 0
    logger.info("DATASET | name=%s | rows=%d | cols=%d", name, nobs, nvars)
    if input_name:
        logger.info("  Input: %s (%d rows)", input_name, input_nobs or nobs)
    if where:
        logger.info("  WHERE: %s", where)


def log_export(logger, target, nobs=None, nvars=None):
    parts = ["EXPORT | target=%s" % target]
    if nobs is not None: parts.append("rows=%d" % nobs)
    if nvars is not None: parts.append("cols=%d" % nvars)
    logger.info(" | ".join(parts))


@contextlib.contextmanager
def log_step(logger, step_name, **kwargs):
    st = _state(logger)
    st["steps"] += 1
    step_num = st["steps"]
    extra = "".join(" | %s=%s" % (k, v) for k, v in kwargs.items())
    logger.info("STEP START | step=%d | name=%s%s", step_num, step_name, extra)
    t0 = time.perf_counter()
    try:
        yield
        elapsed = time.perf_counter() - t0
        logger.info("STEP END | step=%d | name=%s | elapsed=%.2fs | status=SUCCESS",
                     step_num, step_name, elapsed)
    except Exception as exc:
        elapsed = time.perf_counter() - t0
        st["errors"] += 1
        logger.error("STEP END | step=%d | name=%s | elapsed=%.2fs | status=FAILED | error=%s",
                      step_num, step_name, elapsed, exc)
        raise


def log_warn(logger, msg):
    _state(logger)["warnings"] += 1
    logger.warning(msg)


def log_error(logger, msg):
    _state(logger)["errors"] += 1
    logger.error(msg)


def log_exception(logger, exc, note=None, re_raise=False):
    _state(logger)["errors"] += 1
    if note:
        logger.error("EXCEPTION | context=%s | type=%s | msg=%s", note, type(exc).__name__, exc)
    else:
        logger.error("EXCEPTION | type=%s | msg=%s", type(exc).__name__, exc)
    if hasattr(exc, "__traceback__") and exc.__traceback__:
        for line in traceback.format_exception(type(exc), exc, exc.__traceback__):
            for sub in line.rstrip().split("\n"):
                logger.error("  %s", sub)
    if re_raise:
        raise exc


def log_summary(logger, **extra_metrics):
    st = _state(logger)
    elapsed = time.time() - st["start_ts"]
    status = "SUCCESS" if st["errors"] == 0 else "FAILED (%d errors)" % st["errors"]
    name = logger.name.split(".")[-1]
    logger.info("=" * 70)
    logger.info("Program: %s - %s | run_id: %s", name, status, st["run_id"])
    logger.info("Steps: %d | Errors: %d | Warnings: %d | Elapsed: %.2f seconds",
                st["steps"], st["errors"], st["warnings"], elapsed)
    for key, val in extra_metrics.items():
        logger.info("  %s: %s", key, val)
    logger.info("=" * 70)


