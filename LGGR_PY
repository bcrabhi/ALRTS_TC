def _guard_duplicate_handlers(logger: logging.Logger) -> None:
    """Remove existing handlers to prevent duplicates on re-init."""
    for h in logger.handlers[:]:
        logger.removeHandler(h)
        h.close()


def get_logger(
    report_name: str,
    log_dir: str | Path,
    level: int = logging.DEBUG,
) -> logging.Logger:
    """Create a UAT/staging logger with console + timestamped file output.

    Args:
        report_name: Used as logger name and filename prefix.
        log_dir: Directory for log files (created if missing).
        level: Logging level (default DEBUG).

    Returns:
        Configured Logger instance.
    """
    log_dir = Path(log_dir)
    log_dir.mkdir(parents=True, exist_ok=True)

    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    log_file = log_dir / f"{report_name}_{ts}.log"

    run_id = str(uuid.uuid4())
    logger = logging.getLogger(f"regulatory.migration.{report_name}")
    logger.setLevel(level)
    _guard_duplicate_handlers(logger)

    formatter = _StandardMaskingFormatter()
    run_filter = RunIdFilter(run_id)

    fh = logging.FileHandler(log_file, encoding="utf-8")
    fh.setFormatter(formatter)
    fh.addFilter(run_filter)
    fh.addFilter(MaskingFilter())
    logger.addHandler(fh)

    ch = logging.StreamHandler(sys.stdout)
    ch.setFormatter(formatter)
    ch.addFilter(run_filter)
    ch.addFilter(MaskingFilter())
    logger.addHandler(ch)

    logger.propagate = False
    return logger


def get_production_logger(
    report_name: str,
    log_dir: str | Path,
    run_id: Optional[str] = None,
) -> logging.Logger:
    """Create a production logger with rotating file handler.

    Args:
        report_name: Used as logger name and filename prefix.
        log_dir: Directory for log files.
        run_id: Pipeline run ID (auto-generated if None).

    Returns:
        Configured Logger with RotatingFileHandler.
    """
    log_dir = Path(log_dir)
    log_dir.mkdir(parents=True, exist_ok=True)

    if run_id is None:
        run_id = str(uuid.uuid4())

    log_file = log_dir / f"{report_name}.log"
    logger = logging.getLogger(f"regulatory.migration.{report_name}")
    logger.setLevel(logging.DEBUG)
    _guard_duplicate_handlers(logger)

    formatter = _StandardMaskingFormatter()

    rh = logging.handlers.RotatingFileHandler(
        log_file, maxBytes=DEFAULT_MAX_BYTES, backupCount=DEFAULT_BACKUP_COUNT,
        encoding="utf-8",
    )
    rh.setFormatter(formatter)
    rh.addFilter(RunIdFilter(run_id))
    rh.addFilter(MaskingFilter())
    logger.addHandler(rh)

    logger.propagate = False
    return logger


def get_json_logger(
    report_name: str,
    log_dir: str | Path,
    run_id: Optional[str] = None,
) -> logging.Logger:
    """Create a production JSON logger (preferred for SIEM/ELK ingestion).

    Writes one JSON object per line to {report_name}.jsonl.

    Args:
        report_name: Used as logger name and filename prefix.
        log_dir: Directory for log files.
        run_id: Pipeline run ID (auto-generated if None).

    Returns:
        Configured Logger with JSON output.
    """
    log_dir = Path(log_dir)
    log_dir.mkdir(parents=True, exist_ok=True)

    if run_id is None:
        run_id = str(uuid.uuid4())

    log_file = log_dir / f"{report_name}.jsonl"
    logger = logging.getLogger(f"regulatory.migration.{report_name}.json")
    logger.setLevel(logging.DEBUG)
    _guard_duplicate_handlers(logger)

    rh = logging.handlers.RotatingFileHandler(
        log_file, maxBytes=DEFAULT_MAX_BYTES, backupCount=DEFAULT_BACKUP_COUNT,
        encoding="utf-8",
    )
    rh.setFormatter(JsonFormatter(report_name, run_id))
    rh.addFilter(RunIdFilter(run_id))
    rh.addFilter(MaskingFilter())
    logger.addHandler(rh)

    logger.propagate = False
    return logger


def load_logging_config(config_path: str | Path) -> None:
    """Load logging configuration from a YAML file.

    Args:
        config_path: Path to YAML config file.

    Raises:
        ImportError: If PyYAML is not installed.
        FileNotFoundError: If config file doesn't exist.
    """
    try:
        import yaml  # type: ignore[import-untyped]
    except ImportError:
        raise ImportError(
            "PyYAML is required for YAML config loading. "
            "Install with: pip install pyyaml"
        )

    config_path = Path(config_path)
    if not config_path.exists():
        raise FileNotFoundError(
            "Logging config file not found: %s" % config_path
        )

    with open(config_path, "r", encoding="utf-8") as f:
        config = yaml.safe_load(f)

    logging.config.dictConfig(config)


