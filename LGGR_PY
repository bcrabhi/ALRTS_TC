@contextlib.contextmanager
def log_stage(
    logger: logging.Logger,
    stage_name: str,
    **kwargs: Any,
) -> Generator[None, None, None]:
    """Context manager that logs stage start/end with elapsed time.

    Args:
        logger: Logger instance.
        stage_name: Name of the processing stage.
        **kwargs: Additional key=value pairs logged on the START line.

    Example:
        with log_stage(logger, "Pull tracking data", source="Teradata"):
            df = pd.read_sql(sql, conn)
    """
    extra = "".join(" | %s=%s" % (k, v) for k, v in kwargs.items())
    logger.info("STAGE START | stage=%s%s", stage_name, extra)
    t0 = time.perf_counter()
    try:
        yield
        elapsed = time.perf_counter() - t0
        logger.info(
            "STAGE END | stage=%s | elapsed=%.2fs | status=SUCCESS",
            stage_name, elapsed,
        )
    except Exception as exc:
        elapsed = time.perf_counter() - t0
        logger.error(
            "STAGE END | stage=%s | elapsed=%.2fs | status=FAILED | error=%s",
            stage_name, elapsed, exc,
        )
        raise


def log_run_header(logger: logging.Logger, config: dict) -> None:
    """Emit a structured run header with configuration parameters.

    Args:
        logger: Logger instance.
        config: Dictionary of configuration key-value pairs to log.
    """
    logger.info("=" * 70)
    logger.info("REGULATORY PIPELINE RUN HEADER")
    logger.info("  %-24s : %s", "Timestamp", datetime.now().isoformat())
    logger.info("  %-24s : %s", "Python version", sys.version.split()[0])
    logger.info("  %-24s : %s", "Working dir", os.getcwd())
    logger.info(
        "  %-24s : %s", "User",
        os.environ.get("USER", os.environ.get("USERNAME", "unknown")),
    )
    logger.info("CONFIGURATION PARAMETERS")
    for key, val in config.items():
        logger.info("  %-24s : %s", key, val)
    logger.info("=" * 70)


def log_run_summary(logger: logging.Logger, metrics: dict) -> None:
    """Emit a structured run summary with metrics.

    Args:
        logger: Logger instance.
        metrics: Dictionary of metric key-value pairs.
    """
    logger.info("=" * 70)
    logger.info("RUN SUMMARY")
    for key, val in metrics.items():
        logger.info("  %-28s : %s", key, val)
    logger.info("=" * 70)


def validate_column_check(
    logger: logging.Logger,
    df: Any,
    columns: list,
    report_period: str,
    null_threshold: float = NULL_PCT_WARN_THRESHOLD,
) -> None:
    """Check columns for null percentages and log results.

    Args:
        logger: Logger instance.
        df: pandas DataFrame to validate.
        columns: List of column names to check.
        report_period: Reporting period label for the log.
        null_threshold: Percentage threshold — below = WARNING, at/above = ERROR.
    """
    n = len(df)
    if n == 0:
        logger.warning("Data validation skipped — DataFrame is empty | period=%s", report_period)
        return

    for col in columns:
        if col not in df.columns:
            logger.warning("Column not found in DataFrame | col=%s", col)
            continue

        null_count = int(df[col].isna().sum())
        null_pct = null_count / n * 100

        if null_pct == 0:
            logger.debug("Null check PASSED | col=%s", col)
        elif null_pct < null_threshold:
            logger.warning(
                "Null check | col=%s | null_pct=%.2f | rows=%d",
                col, null_pct, null_count,
            )
        else:
            logger.error(
                "Null check | col=%s | null_pct=%.2f | rows=%d",
                col, null_pct, null_count,
            )

    logger.info("Data validation complete | period=%s | rows=%d", report_period, n)


# ═══════════════════════════════════════════════════════════════════
# SASLogger — HIGH-LEVEL API (existing scripts, zero duplication)
# ═══════════════════════════════════════════════════════════════════

class SASLogger:
    """High-level logger for converted SAS scripts.

    Provides zero-duplication methods that both execute database operations
    AND log them.  Works with any DB-API connection (Teradata, Hive,
    SQL Server, Salesforce).

    Args:
        program_name: Script/job name (appears in log header).
        log_dir: Directory for the log file.
        log_file: Optional explicit log filename.
        console: Mirror output to stdout (default True).
        env: Environment label ("PROD", "DEV", "UAT").
        json_mode: If True, also writes JSON logs alongside standard logs.
        run_id: Pipeline run ID (auto-generated if None).

    Example:
        log = SASLogger("C86_PA_Client360", log_dir="path/to/logs")
        df = log.run_query("tracking_all", sql, conn, source="Teradata")
        log.log_dataset("c360_detail", df)
        log.finalize()
    """

    def __init__(
        self,
        program_name: str,
        log_dir: str | Path | None = None,
        log_file: Optional[str] = None,
        console: bool = True,
        env: str = "PROD",
        json_mode: bool = False,
        run_id: Optional[str] = None,
    ) -> None:
        self.program_name = program_name
        self.env = env
        self.run_id = run_id or str(uuid.uuid4())
        self.start_time = datetime.now()
        self.start_ts = time.time()
        self.step_counter: int = 0
        self.error_count: int = 0
        self.warning_count: int = 0

        # Resolve log path
        log_dir_path = Path(log_dir) if log_dir else Path.cwd()
        log_dir_path.mkdir(parents=True, exist_ok=True)
        if log_file is None:
            ymd = self.start_time.strftime("%Y%m%d_%H%M%S")
            log_file = "%s_%s.log" % (program_name, ymd)
        self.log_file_path = log_dir_path / log_file

        # Create logger with naming convention
        self._logger = logging.getLogger(
            "regulatory.migration.%s" % program_name
        )
        self._logger.setLevel(logging.DEBUG)
        self._logger.propagate = False
        _guard_duplicate_handlers(self._logger)

        # Filters
        run_filter = RunIdFilter(self.run_id)
        mask_filter = MaskingFilter()

        # Standard file handler
        fh = logging.FileHandler(self.log_file_path, mode="w", encoding="utf-8")
        fh.setFormatter(_StandardMaskingFormatter())
        fh.addFilter(run_filter)
        fh.addFilter(mask_filter)
        self._logger.addHandler(fh)

        # Console handler
        if console:
            ch = logging.StreamHandler(sys.stdout)
            ch.setFormatter(_StandardMaskingFormatter())
            ch.addFilter(run_filter)
            ch.addFilter(mask_filter)
            self._logger.addHandler(ch)

        # Optional JSON handler
        if json_mode:
            json_file = log_dir_path / ("%s.jsonl" % program_name)
            jh = logging.handlers.RotatingFileHandler(
                json_file, maxBytes=DEFAULT_MAX_BYTES,
                backupCount=DEFAULT_BACKUP_COUNT, encoding="utf-8",
            )
            jh.setFormatter(JsonFormatter(program_name, self.run_id))
            jh.addFilter(run_filter)
            jh.addFilter(mask_filter)
            self._logger.addHandler(jh)

        # Warning capture
        self._original_showwarning = warnings.showwarning
        warnings.showwarning = self._capture_warning

        # Emit header
        self._write_header()

    # ── Header / Footer ──────────────────────────────────────────

    def _write_header(self) -> None:
        user = os.environ.get("USER", os.environ.get("USERNAME", "unknown"))
        host = os.environ.get("HOSTNAME", os.environ.get("COMPUTERNAME", "unknown"))
        self._logger.info("=" * 70)
        self._logger.info("Program: %s | run_id: %s", self.program_name, self.run_id)
        self._logger.info(
            "Started: %s | User: %s | Host: %s | Env: %s",
            self.start_time.strftime("%Y-%m-%d %H:%M:%S"), user, host, self.env,
        )
        self._logger.info(
            "Python: %s | Working dir: %s",
            sys.version.split()[0], os.getcwd(),
        )
        self._logger.info("=" * 70)

    def finalize(self) -> None:
        """Write closing summary. Always call at end of script."""
        elapsed = time.time() - self.start_ts
        status = "SUCCESS" if self.error_count == 0 else "FAILED (%d errors)" % self.error_count
        self._logger.info("=" * 70)
        self._logger.info(
            "Program: %s — %s | run_id: %s",
            self.program_name, status, self.run_id,
        )
        self._logger.info(
            "Steps: %d | Errors: %d | Warnings: %d | Elapsed: %.2f seconds",
            self.step_counter, self.error_count, self.warning_count, elapsed,
        )
        self._logger.info("=" * 70)
        try:
            warnings.showwarning = self._original_showwarning
        except Exception:
            pass

    # ── Execute + Log (zero duplication) ─────────────────────────

    def run_query(
        self,
        table_name: str,
        sql: str,
        connection: Any,
        source: str = "database",
        params: Any = None,
    ) -> "pd.DataFrame":
        """Execute SELECT, log SQL + result, return DataFrame.

        Works with any DB-API connection: Teradata, Hive, SQL Server, Salesforce.

        Args:
            table_name: Logical name for the result table.
            sql: SELECT statement to execute.
            connection: Any DB-API connection or SQLAlchemy engine.
            source: Label for the data source.
            params: Optional query parameters for pd.read_sql.

        Returns:
            Query result as a pandas DataFrame.
        """
        import pandas as pd  # deferred import — module has no hard pandas dep

        self._logger.info("QUERY | table=%s | source=%s", table_name, source)
        sql_oneline = " ".join(sql.split())
        if len(sql_oneline) > 500:
            self._logger.info("  SQL: %s...", sql_oneline[:500])
        else:
            self._logger.info("  SQL: %s", sql_oneline)

        t0 = time.perf_counter()
        df = pd.read_sql(sql, connection, params=params)
        elapsed = time.perf_counter() - t0

        self._logger.info(
            "  Result | rows=%d | cols=%d | elapsed=%.2fs",
            len(df), len(df.columns), elapsed,
        )
        return df

    def run_execute(
        self,
        label: str,
        sql: str,
        connection: Any,
        source: str = "database",
    ) -> None:
        """Execute DDL/DML (CREATE TABLE, COLLECT STATS, etc.), log it.

        Args:
            label: Description for the log.
            sql: DDL/DML statement.
            connection: Any DB-API connection.
            source: Label for the data source.
        """
        self._logger.info("EXECUTE | label=%s | source=%s", label, source)
        sql_oneline = " ".join(sql.split())
        if len(sql_oneline) > 500:
            self._logger.info("  SQL: %s...", sql_oneline[:500])
        else:
            self._logger.info("  SQL: %s", sql_oneline)

        t0 = time.perf_counter()
        cursor = connection.cursor()
        cursor.execute(sql)
        elapsed = time.perf_counter() - t0

        self._logger.info("  Done | elapsed=%.2fs", elapsed)

    def run_insert(
        self,
        table_name: str,
        insert_sql: str,
        records: list,
        connection: Any,
        source: str = "SQL Server",
        database: Optional[str] = None,
    ) -> None:
        """Execute bulk INSERT via executemany, log row count.

        Args:
            table_name: Target table name.
            insert_sql: INSERT statement with placeholders.
            records: List of row tuples/lists.
            connection: Any DB-API connection.
            source: Label for the data source.
            database: Optional database name for the log.
        """
        db_prefix = "%s.dbo." % database if database else "dbo."
        full_name = "%s%s" % (db_prefix, table_name)

        self._logger.info(
            "INSERT | rows=%d | target=%s | source=%s",
            len(records), full_name, source,
        )

        t0 = time.perf_counter()
        cursor = connection.cursor()
        cursor.fast_executemany = True
        cursor.executemany(insert_sql, records)
        connection.commit()
        elapsed = time.perf_counter() - t0

        self._logger.info("  Done | elapsed=%.2fs", elapsed)

    # ── Log-only methods ─────────────────────────────────────────

    def log_dataset(
        self,
        name: str,
        df: Any,
        input_name: Optional[str] = None,
        input_nobs: Optional[int] = None,
        where_clause: Optional[str] = None,
        elapsed: Optional[float] = None,
    ) -> None:
        """Log a pandas transformation result.

        Args:
            name: Output dataset name.
            df: The result DataFrame.
            input_name: Optional source dataset name.
            input_nobs: Optional source row count.
            where_clause: Optional filter description.
            elapsed: Optional elapsed seconds.
        """
        nobs = len(df) if df is not None else 0
        nvars = len(df.columns) if df is not None and hasattr(df, "columns") else 0

        time_part = " | elapsed=%.2fs" % elapsed if elapsed is not None else ""
        self._logger.info(
            "DATASET | name=%s | rows=%d | cols=%d%s",
            name, nobs, nvars, time_part,
        )

        if input_name:
            read_count = input_nobs if input_nobs is not None else nobs
            self._logger.info("  Input: %s (%d rows)", input_name, read_count)
        if where_clause:
            self._logger.info("  WHERE: %s", where_clause)

    def log_export(
        self,
        target: str,
        nobs: Optional[int] = None,
        nvars: Optional[int] = None,
        elapsed: Optional[float] = None,
    ) -> None:
        """Log a file export.

        Args:
            target: File path or target name.
            nobs: Optional row count.
            nvars: Optional column count.
            elapsed: Optional elapsed seconds.
        """
        parts = ["EXPORT | target=%s" % target]
        if nobs is not None:
            parts.append("rows=%d" % nobs)
        if nvars is not None:
            parts.append("cols=%d" % nvars)
        if elapsed is not None:
            parts.append("elapsed=%.2fs" % elapsed)
        self._logger.info(" | ".join(parts))

    def log_note(self, msg: str) -> None:
        """General info message."""
        self._logger.info(msg)

    def log_warning(self, msg: str) -> None:
        """Warning (increments counter)."""
        self.warning_count += 1
        self._logger.warning(msg)

    def log_error(self, msg: str) -> None:
        """Error (increments counter)."""
        self.error_count += 1
        self._logger.error(msg)

    def log_put(self, **kwargs: Any) -> None:
        """Log variable values (pipe-delimited key=value)."""
        pairs = " | ".join("%s=%s" % (k, v) for k, v in kwargs.items())
        self._logger.info("VARS | %s", pairs)

    # ── Context manager — step() ─────────────────────────────────

    class _StepContext:
        """Context manager for a logical processing step with auto-timing."""

        def __init__(self, logger: "SASLogger", name: str) -> None:
            self._l = logger
            self._name = name
            self._start: float = 0.0

        def __enter__(self) -> "SASLogger._StepContext":
            self._l.step_counter += 1
            self._start = time.perf_counter()
            self._l._logger.info(
                "STEP START | step=%d | name=%s",
                self._l.step_counter, self._name,
            )
            return self

        def __exit__(self, exc_type: Any, exc_val: Any, exc_tb: Any) -> bool:
            elapsed = time.perf_counter() - self._start
            if exc_type:
                self._l.log_exception(exc_val, note=self._name)
                self._l._logger.info(
                    "STEP END | step=%d | name=%s | elapsed=%.2fs | status=FAILED",
                    self._l.step_counter, self._name, elapsed,
                )
            else:
                self._l._logger.info(
                    "STEP END | step=%d | name=%s | elapsed=%.2fs | status=SUCCESS",
                    self._l.step_counter, self._name, elapsed,
                )
            return False

        @property
        def elapsed(self) -> float:
            return time.perf_counter() - self._start

        # Proxy methods
        def run_query(self, *a: Any, **kw: Any) -> Any:
            return self._l.run_query(*a, **kw)

        def run_execute(self, *a: Any, **kw: Any) -> None:
            return self._l.run_execute(*a, **kw)

        def run_insert(self, *a: Any, **kw: Any) -> None:
            return self._l.run_insert(*a, **kw)

        def log_dataset(self, name: str, df: Any, **kw: Any) -> None:
            kw.setdefault("elapsed", self.elapsed)
            self._l.log_dataset(name, df, **kw)

        def log_export(self, target: str, **kw: Any) -> None:
            kw.setdefault("elapsed", self.elapsed)
            self._l.log_export(target, **kw)

        def log_note(self, msg: str) -> None:
            self._l.log_note(msg)

        def log_warning(self, msg: str) -> None:
            self._l.log_warning(msg)

        def log_error(self, msg: str) -> None:
            self._l.log_error(msg)

        def log_put(self, **kw: Any) -> None:
            self._l.log_put(**kw)

    def step(self, step_name: str) -> _StepContext:
        """Context manager for a logical step with auto-timing.

        Args:
            step_name: Description of the processing step.

        Example:
            with log.step("Pull tracking data") as s:
                df = s.run_query("tracking_all", sql, conn, source="Teradata")
        """
        return self._StepContext(self, step_name)

    # ── Exception handling ───────────────────────────────────────

    def log_exception(
        self,
        exc: BaseException,
        note: Optional[str] = None,
        re_raise: bool = False,
    ) -> None:
        """Log a caught exception with full traceback.

        Args:
            exc: The caught exception.
            note: Optional context description.
            re_raise: If True, re-raises after logging.
        """
        self.error_count += 1
        if note:
            self._logger.error(
                "EXCEPTION | context=%s | type=%s | msg=%s",
                note, type(exc).__name__, exc,
            )
        else:
            self._logger.error(
                "EXCEPTION | type=%s | msg=%s", type(exc).__name__, exc,
            )
        if hasattr(exc, "__traceback__") and exc.__traceback__:
            tb_lines = traceback.format_exception(type(exc), exc, exc.__traceback__)
            for line in tb_lines:
                for sub in line.rstrip().split("\n"):
                    self._logger.error("  %s", sub)
        if re_raise:
            raise exc

    # ── Data validation ──────────────────────────────────────────

    def validate_columns(
        self,
        df: Any,
        columns: list,
        report_period: str = "",
        null_threshold: float = NULL_PCT_WARN_THRESHOLD,
    ) -> None:
        """Check columns for null percentages and log results.

        Convenience wrapper around validate_column_check() using
        the SASLogger's internal logger.

        Args:
            df: pandas DataFrame to validate.
            columns: Column names to check.
            report_period: Reporting period label.
            null_threshold: Null percentage threshold.
        """
        validate_column_check(
            self._logger, df, columns, report_period, null_threshold,
        )

    # ── Warning capture ──────────────────────────────────────────

    def _capture_warning(
        self,
        message: Any,
        category: type,
        filename: str,
        lineno: int,
        file: Any = None,
        line: Any = None,
    ) -> None:
        self.warning_count += 1
        self._logger.warning(
            "%s: %s (File: %s, Line: %d)",
            category.__name__, message, filename, lineno,
        )
        if self._original_showwarning:
            try:
                self._original_showwarning(message, category, filename, lineno, file, line)
            except Exception:
                pass


