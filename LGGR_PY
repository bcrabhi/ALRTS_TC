class JsonFormatter(logging.Formatter):
    """Emits structured JSON log lines for production/SIEM ingestion.

    Args:
        report_name: Name of the regulatory report.
        run_id: Unique pipeline run identifier.
    """

    def __init__(self, report_name: str, run_id: str) -> None:
        super().__init__()
        self.report_name = report_name
        self.run_id = run_id

    def format(self, record: logging.LogRecord) -> str:
        payload = {
            "@timestamp": datetime.fromtimestamp(
                record.created, tz=timezone.utc
            ).isoformat(),
            "level": record.levelname,
            "report": self.report_name,
            "run_id": self.run_id,
            "logger": record.name,
            "module": record.module,
            "filename": record.filename,
            "lineno": record.lineno,
            "message": _mask(record.getMessage()),
        }
        if record.exc_info and record.exc_info[0] is not None:
            payload["exception"] = traceback.format_exception(*record.exc_info)
        return json.dumps(payload, ensure_ascii=False)


class _StandardMaskingFormatter(logging.Formatter):
    """Standard formatter with sensitive-data masking built in."""

    def __init__(self, fmt: str = LOG_FORMAT_STANDARD) -> None:
        super().__init__(fmt=fmt)

    def format(self, record: logging.LogRecord) -> str:
        return _mask(super().format(record))


