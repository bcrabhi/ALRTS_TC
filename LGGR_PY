class RunIdFilter(logging.Filter):
    """Attaches a run_id attribute to every log record.

    Args:
        run_id: Unique identifier for this pipeline run.
    """

    def __init__(self, run_id: str) -> None:
        super().__init__()
        self.run_id = run_id

    def filter(self, record: logging.LogRecord) -> bool:
        record.run_id = self.run_id  # type: ignore[attr-defined]
        return True  # never suppress


class MaskingFilter(logging.Filter):
    """Scrubs sensitive data patterns from log messages after formatting.

    Applied at the formatter level, not on raw args, to avoid breaking
    %-style format specifiers like %d and %.2f.
    """

    def filter(self, record: logging.LogRecord) -> bool:
        # Only mask the msg string itself (not args — those need to stay
        # as their original types for % formatting to work)
        if isinstance(record.msg, str):
            record.msg = _mask(record.msg)
        return True


