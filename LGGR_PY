"""
logger.py - Reusable logging module for SAS-to-Python migration scripts.

Version : 3.0
Audience: Migration Engineers, Regulatory Reporting Division
Deploy  : Place alongside common.py in the shared modules directory.

Architecture:
    TIER 1 - MANDATORY STANDARD (use in every script)
    TIER 2 - OPTIONAL EXTENDED (use when needed)

Usage (minimum):
    from logger import init_logger, log_query, log_dataset, log_export,
                       log_step, log_exception, log_summary

    logger = init_logger("C86_PA_Client360", log_dir="path/to/logs")
    with log_step(logger, "Pull tracking data"):
        df = log_query(logger, "tracking_all", sql, conn, source="Teradata")
    log_dataset(logger, "c360_detail", df)
    log_export(logger, "/path/to/output.xlsx", nobs=len(df))
    log_summary(logger)
"""

