def log_note(logger, msg):
    logger.info(msg)

def log_vars(logger, **kwargs):
    pairs = " | ".join("%s=%s" % (k, v) for k, v in kwargs.items())
    logger.info("VARS | %s", pairs)

def log_validate(logger, df, columns, period="", threshold=_NULL_THRESHOLD):
    n = len(df)
    if n == 0:
        logger.warning("Validation skipped - DataFrame is empty | period=%s", period)
        return
    for col in columns:
        if col not in df.columns:
            logger.warning("Column not found | col=%s", col)
            continue
        null_count = int(df[col].isna().sum())
        null_pct = null_count / n * 100
        if null_pct == 0:
            logger.debug("Null check PASSED | col=%s", col)
        elif null_pct < threshold:
            logger.warning("Null check | col=%s | null_pct=%.2f | rows=%d", col, null_pct, null_count)
        else:
            logger.error("Null check | col=%s | null_pct=%.2f | rows=%d", col, null_pct, null_count)
    logger.info("Data validation complete | period=%s | rows=%d", period, n)

def log_header(logger, config):
    logger.info("CONFIGURATION PARAMETERS")
    for key, val in config.items():
        logger.info("  %-24s : %s", key, val)


