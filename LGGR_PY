"""
sas_logger.py — Production-grade logging for SAS-to-Python migration scripts.

Version: 2.0
Audience: Migration Engineers, Regulatory Reporting Division
Module: Shared across all migrated scripts (deploy alongside common.py)

Design:
  - Python-native log format with SAS-equivalent information
  - Zero duplication: run_query() executes AND logs in one call
  - Source-agnostic: Teradata, Hive/Spark, SQL Server, Salesforce, any DB-API
  - Sensitive data masking: SSN, CC, email, password auto-scrubbed
  - Production features: log rotation, JSON logging, run IDs, data validation
  - Thread-safe: duplicate-handler guards on all logger creation

Usage (minimal):
    from sas_logger import SASLogger

    log = SASLogger("C86_PA_Client360", log_dir="path/to/logs")
    df = log.run_query("tracking_all", sql, conn, source="Teradata")
    log.log_dataset("c360_detail", df)
    log.log_export("/path/to/file.xlsx", nobs=len(df), nvars=len(df.columns))
    log.finalize()

Usage (production JSON):
    from sas_logger import get_json_logger, log_stage, log_run_header

    logger = get_json_logger("C86_PA_Client360", log_dir="path/to/logs")
    log_run_header(logger, {"report": "C86", "env": "PROD"})
    with log_stage(logger, "Pull tracking data", source="Teradata"):
        df = pd.read_sql(sql, conn)
"""

from __future__ import annotations

# ═══════════════════════════════════════════════════════════════════
# ANTI-PATTERN GUARDS — do NOT use these in any converted script:
#   1. print() for logging        — use logger methods instead
#   2. f-strings in logger args   — use lazy % formatting
#   3. bare except:               — always catch specific exceptions
#   4. logging.basicConfig()      — use SASLogger or get_*_logger()
#   5. PII in log messages        — masking handles known patterns,
#                                   but never log raw customer data
# ═══════════════════════════════════════════════════════════════════

