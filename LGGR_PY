import json
import logging
import logging.handlers
import os
import re
import sys
import time
import traceback
import uuid
import warnings
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Generator, Optional

__all__ = [
    "init_logger",
    "log_query", "log_execute", "log_insert",
    "log_dataset", "log_export",
    "log_step",
    "log_warn", "log_error", "log_exception",
    "log_summary",
    "log_note", "log_vars", "log_validate", "log_header",
]

_LOG_FORMAT = "%(asctime)s | %(levelname)-8s | %(name)s | %(message)s"
_MAX_BYTES = 50 * 1024 * 1024
_BACKUP_COUNT = 10
_NULL_THRESHOLD = 5.0

_MASK_PATTERNS = [
    re.compile(r"\b\d{3}-\d{2}-\d{4}\b"),
    re.compile(r"\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b"),
    re.compile(r"\b(?:4\d{12}(?:\d{3})?|5[1-5]\d{14}|3[47]\d{13})\b"),
    re.compile(r"(?i)password\s*[:=]\s*\S+"),
    re.compile(r"(?i)pwd\s*[:=]\s*\S+"),
]

def _mask(text):
    for pat in _MASK_PATTERNS:
        text = pat.sub("***MASKED***", text)
    return text

class _MaskFormatter(logging.Formatter):
    def format(self, record):
        return _mask(super().format(record))

_run_state = {}

def _state(logger):
    name = logger.name
    if name not in _run_state:
        _run_state[name] = {
            "start_ts": time.time(), "start_dt": datetime.now(),
            "steps": 0, "errors": 0, "warnings": 0,
            "run_id": str(uuid.uuid4()),
        }
    return _run_state[name]

