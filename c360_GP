def _load_to_sql_server(cfg, excel_path, log: SASLogger):
    if pyodbc is None:
        raise RuntimeError("pyodbc not installed")
    with open(cfg.sql_secrets_json, "r", encoding="utf-8") as f:
        secrets = json.load(f)
    sql_server = secrets["SQL_SERVER"]
    sql_database = secrets["SQL_DATABASE"]
    uid = secrets["SQL_UID"]
    pwd = secrets["SQL_PWD"]
    conn = None
    cursor = None
    try:
        conn = pyodbc.connect(
            f"DRIVER={{ODBC Driver 17 for SQL Server}};"
            f"SERVER={sql_server};DATABASE={sql_database};"
            f"UID={uid};PWD={pwd};TrustServerCertificate=Yes;Connection Timeout=10;")
        cursor = conn.cursor()
        cursor.execute(f"select top 1 * from {sql_database}.dbo.{cfg.sql_table}")
        expected_columns = [col[0] for col in cursor.description]
        if "RowID" in expected_columns:
            expected_columns.remove("RowID")

        df_load = pd.read_excel(str(excel_path))
        rename_map = {"Control Risk": "ControlRisk", "segment": "Segment", "segment2": "Segment2",
                      "segment3": "Segment3", "segment4": "Segment4", "segment5": "Segment5",
                      "segment6": "Segment6", "segment7": "Segment7", "segment8": "Segment8",
                      "segment9": "Segment9", "segment10": "Segment10",
                      "Commentcode": "CommentCode", "comments": "Comments"}
        df_load.rename(columns=rename_map, inplace=True)
        for col in expected_columns:
            if col not in df_load.columns:
                df_load[col] = np.nan
        df_load = df_load[expected_columns]
        df_load = df_load.map(lambda x: None if pd.isna(x) or str(x).strip() == "" else x)

        placeholders = ", ".join(["?"] * len(expected_columns))
        columns_str = ", ".join([f"[{c}]" for c in expected_columns])
        insert_sql = f"INSERT INTO dbo.{cfg.sql_table} ({columns_str}) VALUES ({placeholders})"
        records = df_load.where(pd.notnull(df_load), None).values.tolist()

        log.run_insert(cfg.sql_table, insert_sql, records, conn,
                       source="SQL Server", database=sql_database)
    except Exception as e:
        log.log_exception(e, note="SQL Server load failed")
        raise
    finally:
        if cursor: cursor.close()
        if conn: conn.close()
        log.log_note("Database connection closed.")


