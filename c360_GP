def configure_s3a(spark: SparkSession) -> SparkSession:
    hconf = spark.sparkContext._jsc.hadoopConfiguration()
    hconf.set("fs.s3a.endpoint", S3_ENDPOINT)
    hconf.set("fs.s3a.connection.ssl.enabled", "true")
    hconf.set("fs.s3a.path.style.access", "true")
    hconf.set("fs.s3a.impl", "org.apache.hadoop.fs.s3a.S3AFileSystem")
    return spark


def get_spark_session(app_name: str = "C86_PA_Client360") -> SparkSession:
    spark = SparkSession.builder.master("yarn").appName(app_name).getOrCreate()
    configure_s3a(spark)
    return spark


def s3_path(folder: str, *parts: str) -> str:
    base = S3_FOLDERS.get(folder, folder)
    return "/".join([base.rstrip("/")] + list(parts))


def upload_file_to_s3(spark, local_path, s3_uri, log: SASLogger):
    sc = spark.sparkContext
    jvm = sc._jvm
    conf = sc._jsc.hadoopConfiguration()
    local_fs_path = jvm.org.apache.hadoop.fs.Path(f"file://{os.path.abspath(local_path)}")
    s3_fs_path = jvm.org.apache.hadoop.fs.Path(s3_uri)
    fs = s3_fs_path.getFileSystem(conf)
    fs.copyFromLocalFile(False, True, local_fs_path, s3_fs_path)
    log.log_note(f"Uploaded to S3 -> {s3_uri}")


def _normalize_column_types(df: pd.DataFrame) -> pd.DataFrame:
    date_columns = ("DateCompleted", "SnapDate")
    string_exact_columns = (
        "RegulatoryName", "LOB", "ReportName", "ControlRisk",
        "TestType", "TestPeriod", "ProductType", "RDE",
        "HoldoutFlag", "CommentCode", "Comments",
    )
    numeric_columns = ("Volume", "Amount")
    for col in df.columns:
        if col in date_columns:
            df[col] = pd.to_datetime(df[col], errors="coerce")
        elif col.startswith("segment") or col in string_exact_columns:
            df[col] = df[col].fillna("").astype(str)
        elif col in numeric_columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
    for col in df.columns:
        if df[col].dtype == "object":
            sample = df[col].dropna().head(1)
            if len(sample) > 0 and isinstance(sample.iloc[0], date):
                df[col] = pd.to_datetime(df[col], errors="coerce")
            else:
                df[col] = df[col].fillna("").astype(str)
    return df


def write_parquet_to_s3(spark, df, s3_uri, log: SASLogger):
    import time as _t
    t0 = _t.time()
    df = _normalize_column_types(df.copy())
    sdf = spark.createDataFrame(df)
    sdf.write.mode("overwrite").parquet(s3_uri)
    log.log_export(s3_uri, nobs=len(df), elapsed=_t.time() - t0)


# ── Teradata connection ───────────────────────────────────────────

def get_teradata_connection(conn_file: Path, log: SASLogger) -> teradatasql.TeradataConnection:
    if not conn_file.exists():
        log.log_error(f"Connection file not found at: {conn_file.resolve()}")
        raise FileNotFoundError(f"Connection file not found at: {conn_file.resolve()}")
    with open(conn_file, "r", encoding="utf-8") as f:
        conn_details = json.load(f)
    url = conn_details.get("url")
    user = conn_details.get("user")
    pwd = conn_details.get("password")
    log.log_note(f"Connecting to Teradata URL: {url} with user: {user} using LDAP...")
    try:
        conn = teradatasql.connect(host=url, user=user, password=pwd, logmech="LDAP")
        log.log_note("Teradata connection successful.")
        return conn
    except Exception as e:
        log.log_exception(e, note="Failed to connect to Teradata")
        raise


# ── Date helpers ──────────────────────────────────────────────────

def check_ini_run(outpath, autocomplete_filename, log: SASLogger):
    autocomplete_file = Path(outpath) / autocomplete_filename
    autocomplete_backup = Path(outpath) / f"{autocomplete_file.stem}_backup{autocomplete_file.suffix}"
    if autocomplete_file.exists():
        log.log_note(f"Found existing autocomplete file: {autocomplete_file}")
        try:
            shutil.copy(autocomplete_file, autocomplete_backup)
            log.log_note(f"Backed up to: {autocomplete_backup}")
        except Exception as e:
            log.log_warning(f"Could not create backup: {e}")
        return "N"
    log.log_note("Autocomplete file not found. Setting ini_run = 'Y'.")
    return "Y"


def setup_dates(ini_run, log: SASLogger):
    tday = date.today()
    runday = tday.strftime("%Y%m%d")
    days_to_wednesday = (tday.weekday() - 2) % 7
    intnx_week4_b = tday - timedelta(days=days_to_wednesday)
    week_start_dt = intnx_week4_b - timedelta(days=12)
    week_end_dt = intnx_week4_b - timedelta(days=6)
    fmt = lambda d: f"'{d:%Y-%m-%d}'"
    dates = {}
    if ini_run.upper() == "Y":
        log.log_note("ini_run = 'Y'. Using initial launch dates.")
        dates["wk_start"] = fmt(date(2023, 5, 7))
        dates["wk_start_min14"] = fmt(date(2023, 4, 23))
        dates["wk_end"] = fmt(week_end_dt)
    else:
        log.log_note("ini_run = 'N'. Using rolling weekly dates.")
        dates["wk_start"] = fmt(week_start_dt)
        dates["wk_start_min14"] = fmt(week_start_dt - timedelta(days=14))
        dates["wk_end"] = fmt(week_end_dt)
    dates["runday"] = runday
    dates["tday"] = runday
    log.log_put(WK_START=dates['wk_start'], WK_END=dates['wk_end'],
                RUNDAY=runday, INI_RUN=f"'{ini_run}'",
                TDAY=dates['tday'], WK_START_MIN14=dates['wk_start_min14'])
    return dates, week_end_dt


def validate_rationale(text):
    if pd.isna(text) or not isinstance(text, str):
        return "Invalid", 1, 1, 1
    x = " ".join(text.split()).upper()
    xfail_chars_gt5 = 0 if len(x) > 5 else 1
    x2 = x.replace(x[0], "") if len(x) > 0 else ""
    xfail_rep_char = 0 if len(x2) > 0 else 1
    x3 = re.sub(r"[^A-Za-z0-9]", "", x)
    xfail_ge_2_alnum = 0 if len(x3) > 2 else 1
    is_valid = (xfail_chars_gt5 + xfail_rep_char + xfail_ge_2_alnum) == 0
    return ("Valid" if is_valid else "Invalid"), xfail_chars_gt5, xfail_rep_char, xfail_ge_2_alnum


