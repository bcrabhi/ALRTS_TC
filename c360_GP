def process_c86_pa_client360(ss, job_conf) -> None:
    cfg = Config()

    # ── Initialize logger (replaces setup_logging + manual header) ──
    log = SASLogger(
        program_name="C86_PA_Client360.sas",
        log_dir=cfg.logpath,
        env="PROD",
    )

    # ── Spark init ──
    with log.step("Initialize Spark") as s:
        spark = get_spark_session("C86_PA_Client360")
        s.log_note(f"Spark session initialized. Master: {spark.sparkContext.master}")
        s.log_note(f"S3 endpoint: {S3_ENDPOINT}, Bucket: {S3_BUCKET}")

    # ── Directories (libref equivalents) ──
    cfg.outpath.mkdir(parents=True, exist_ok=True)
    log.log_libref("AC", str(cfg.outpath))
    ac_path = cfg.outpath

    # ── ini_check + dates ──
    with log.step("ini_check and date setup") as s:
        ini_run = check_ini_run(ac_path, cfg.persistent_ac_file, log)
        s.log_put(INI_RUN=f"'{ini_run}'")
        dates, _week_end_dt = setup_dates(ini_run, log)
        runday = dates["runday"]

        dataout_path = cfg.outpath / runday
        dataout_path.mkdir(parents=True, exist_ok=True)
        s.log_directory_created(str(dataout_path))
        s.log_libref("DATAOUT", str(dataout_path))

    # ── Pull tracking data — SQL written ONCE ──
    sql_tracking_all = """
        SELECT *
        FROM DDWV01.EVNT_PROD_TRACK_LOG
        WHERE advr_selt_typ = 'Advice Tool'
        AND EVNT_DT > (CAST({wk_start} AS DATE) - 90)
    """.format(wk_start=dates['wk_start'])

    with log.step("pull data from tracking") as s:
        with get_teradata_connection(cfg.teradata_conn_json, log) as conn:
            tracking_all = s.run_query("tracking_all", sql_tracking_all, conn, source="Teradata")

    # ── Process tracking data (3 PROC SQL steps) ──
    with log.step("create tracking_tool_use_distinct") as s:
        tracking_all_filtered = tracking_all.dropna(subset=["OPPOR_ID", "ADVC_TOOL_NM"]).copy()
        tracking_all_filtered["ADVC_TOOL_NM"] = tracking_all_filtered["ADVC_TOOL_NM"].astype(str).str.upper()

        tracking_tool_use_distinct = tracking_all_filtered[["OPPOR_ID", "ADVC_TOOL_NM"]].drop_duplicates()
        s.log_dataset("tracking_tool_use_distinct", tracking_tool_use_distinct,
                      input_name="tracking_all", input_nobs=len(tracking_all_filtered))

    with log.step("create tracking_count_tool_use_pre2") as s:
        tracking_count_tool_use_pre2 = (
            tracking_all_filtered.groupby("OPPOR_ID")["ADVC_TOOL_NM"]
            .nunique().reset_index(name="count_unique_tool_used")
            .sort_values(by="count_unique_tool_used", ascending=False)
        )
        s.log_dataset("tracking_count_tool_use_pre2", tracking_count_tool_use_pre2)

    with log.step("create tracking_tool_use") as s:
        tracking_tool_use = tracking_count_tool_use_pre2[
            tracking_count_tool_use_pre2["count_unique_tool_used"] > 0
        ][["OPPOR_ID"]].copy()
        tracking_tool_use["tool_used"] = "Tool Used"
        s.log_dataset("tracking_tool_use", tracking_tool_use,
                      input_name="tracking_count_tool_use_pre2", input_nobs=len(tracking_count_tool_use_pre2))

    # ── Pull C360 detail (volatile table + select) ──
    sql_create_vt = """
        CREATE MULTISET VOLATILE TABLE c360_short AS (
            SELECT evnt_id, CAST(rbc_oppor_own_id AS INTEGER) AS emp_id, evnt_dt AS snap_dt
            FROM DDWV01.evnt_prod_oppor
            WHERE rbc_oppor_own_id IS NOT NULL AND evnt_dt IS NOT NULL AND evnt_id IS NOT NULL
            AND evnt_dt BETWEEN {wk_start} AND {wk_end}
        ) WITH DATA PRIMARY INDEX (emp_id, snap_dt) ON COMMIT PRESERVE ROWS
    """.format(wk_start=dates['wk_start'], wk_end=dates['wk_end'])

    sql_stats = "COLLECT STATISTICS COLUMN (emp_id, snap_dt) ON c360_short"

    sql_c360_detail_pre = """
        SELECT c360.*, emp.org_unt_no, emp.hr_posn_titl_en,
               emp.posn_strt_dt, emp.posn_end_dt, emp.occpt_job_cd
        FROM DDWV01.evnt_prod_oppor AS c360
        LEFT JOIN (
            SELECT c3.evnt_id, e1.org_unt_no, e1.hr_posn_titl_en,
                   e2.posn_strt_dt, e2.posn_end_dt, e1.occpt_job_cd
            FROM c360_short AS c3
            INNER JOIN DDWV01.emp AS e1 ON e1.emp_id = c3.emp_id
                AND c3.snap_dt >= e1.captr_dt AND c3.snap_dt < e1.chg_dt
            INNER JOIN DDWV01.empl_reltn AS e2 ON e2.emp_id = c3.emp_id
                AND c3.snap_dt >= e2.captr_dt AND c3.snap_dt < e2.chg_dt
        ) AS emp ON emp.evnt_id = c360.evnt_id
        WHERE c360.evnt_id IS NOT NULL
          AND c360.evnt_dt BETWEEN {wk_start} AND {wk_end}
    """.format(wk_start=dates['wk_start'], wk_end=dates['wk_end'])

    with log.step("pull C360 detail data") as s:
        with get_teradata_connection(cfg.teradata_conn_json, log) as conn:
            s.run_execute("create volatile table c360_short", sql_create_vt, conn, source="Teradata")
            s.run_execute("collect statistics on c360_short", sql_stats, conn, source="Teradata")
            c360_detail_pre = s.run_query("c360_detail_pre", sql_c360_detail_pre, conn, source="Teradata")

    # ── Join tool info ──
    with log.step("join tool info") as s:
        c360_detail = pd.merge(c360_detail_pre, tracking_tool_use, on="OPPOR_ID", how="left")
        c360_detail["TOOL_USED"] = c360_detail["tool_used"].fillna("Tool Not Used")
        c360_detail = c360_detail.drop(columns=["tool_used"])
        if "LOB" not in c360_detail.columns:
            c360_detail["LOB"] = "Retail"
        else:
            c360_detail["LOB"] = c360_detail["LOB"].fillna("Retail")
        s.log_dataset("c360_detail", c360_detail,
                      input_name="c360_detail_pre", input_nobs=len(c360_detail_pre))

    # ── Pull AOT data ──
    sql_aot_all_oppor = """
        SELECT oppor_id, COUNT(*) AS count_aot
        FROM DDWV01.evnt_prod_aot
        WHERE ess_src_evnt_dt BETWEEN {wk_start_min14} AND {wk_end}
          AND oppor_id IS NOT NULL
        GROUP BY 1
    """.format(wk_start_min14=dates['wk_start_min14'], wk_end=dates['wk_end'])

    with log.step("pull data from AOT") as s:
        with get_teradata_connection(cfg.teradata_conn_json, log) as conn:
            aot_all_oppor = s.run_query("aot_all_oppor", sql_aot_all_oppor, conn, source="Teradata")

    with log.step("create aot_all_oppor_unique") as s:
        aot_all_oppor_unique = aot_all_oppor[["OPPOR_ID"]].drop_duplicates().copy()
        aot_all_oppor_unique.rename(columns={"OPPOR_ID": "aot_oppor_id"}, inplace=True)
        s.log_dataset("aot_all_oppor_unique", aot_all_oppor_unique,
                      input_name="aot_all_oppor", input_nobs=len(aot_all_oppor))

    # ── Link AOT ──
    with log.step("create c360_detail_link_aot") as s:
        c360_detail_link_aot = pd.merge(
            c360_detail, aot_all_oppor_unique, left_on="OPPOR_ID", right_on="aot_oppor_id", how="left")
        cond_prod = c360_detail_link_aot["PROD_CATG_NM"] == "Personal Accounts"
        cond_aot = c360_detail_link_aot["aot_oppor_id"].notna()
        c360_detail_link_aot["C360_PDA_Link_AOT"] = np.where(cond_prod & cond_aot, 1, 0)
        s.log_dataset("c360_detail_link_aot", c360_detail_link_aot,
                      input_name="c360_detail", input_nobs=len(c360_detail))

    # ── Filter + format ──
    with log.step("filter c360_detail_more_in") as s:
        log.log_format("$STAGEFMT")

        df_more = c360_detail_link_aot.copy()
        df_more["oppor_stage_nm_f"] = df_more["OPPOR_STAGE_NM"].map(STAGE_FORMAT_MAP)
        cond1 = df_more["ASCT_PROD_FMLY_NM"] != "Risk Protection"
        cond2 = df_more["LOB"] == "Retail"
        cond3 = df_more["C360_PDA_Link_AOT"] == 0
        cond4 = df_more["OPPOR_STAGE_NM"].isin(["Opportunity Won", "Opportunity Lost"])
        c360_detail_more_in = df_more[cond1 & cond2 & cond3 & cond4].copy()
        s.log_dataset("c360_detail_more_in", c360_detail_more_in,
                      input_name="c360_detail_link_aot", input_nobs=len(c360_detail_link_aot))

    # ── PA rationale validation ──
    with log.step("PA rationale validation") as s:
        pa_rationale_base = c360_detail_more_in[
            c360_detail_more_in["IS_PROD_APRP_FOR_CLNT"] == "Not Appropriate - Rationale"
        ].copy()
        pa_rationale = pa_rationale_base[["EVNT_ID", "IS_PROD_APRP_FOR_CLNT", "CLNT_RTNL_TXT"]].copy()
        validation_results = pa_rationale["CLNT_RTNL_TXT"].apply(
            lambda x: pd.Series(validate_rationale(x),
                                index=["prod_not_aprp_rtnl_txt_cat", "xfail_chars_gt5", "xfail_rep_char", "xfail_ge_2_alnum"]))
        pa_rationale = pd.concat([pa_rationale, validation_results], axis=1)
        s.log_dataset("pa_rationale", pa_rationale,
                      input_name="c360_detail_more_in", input_nobs=len(pa_rationale_base),
                      where_clause="IS_PROD_APRP_FOR_CLNT='Not Appropriate - Rationale'")

    # ── Join validation back ──
    with log.step("join PA rationale back to c360_detail_more_in") as s:
        c360_detail_more_in = pd.merge(
            c360_detail_more_in,
            pa_rationale.drop(columns=["IS_PROD_APRP_FOR_CLNT", "CLNT_RTNL_TXT"]),
            on="EVNT_ID", how="left")
        conds = [c360_detail_more_in["IS_PROD_APRP_FOR_CLNT"].isna(),
                 c360_detail_more_in["IS_PROD_APRP_FOR_CLNT"] != "Not Appropriate - Rationale"]
        choices = ["Not Available", "Not Applicable"]
        c360_detail_more_in["prod_not_aprp_rtnl_txt_cat"] = np.select(
            conds, choices, default=c360_detail_more_in["prod_not_aprp_rtnl_txt_cat"])
        s.log_dataset("c360_detail_more_in", c360_detail_more_in)

    # ── Sort + dedup ──
    with log.step("sort and dedup by OPPOR_ID") as s:
        tmp0 = c360_detail_more_in.sort_values(by="OPPOR_ID").copy()
        tmp0["level_oppor"] = tmp0.groupby("OPPOR_ID").cumcount() + 1
        s.log_sort("c360_detail_more_in", "tmp0", tmp0, by_cols="OPPOR_ID",
                   input_nobs=len(c360_detail_more_in))

    # ── Build base AC table ──
    with log.step("create tmp_pa_c360_4ac") as s:
        tmp_pa_c360_4ac = tmp0[tmp0["level_oppor"] == 1].copy()
        tmp_pa_c360_4ac["EVNT_DT"] = pd.to_datetime(tmp_pa_c360_4ac["EVNT_DT"], errors="coerce")
        day_of_week = tmp_pa_c360_4ac["EVNT_DT"].dt.weekday
        days_to_friday = 4 - day_of_week
        days_to_friday = days_to_friday.where(days_to_friday >= 0, 7 + days_to_friday)
        snapdate_series = tmp_pa_c360_4ac["EVNT_DT"] + pd.to_timedelta(days_to_friday, unit="d")
        tmp_pa_c360_4ac = tmp_pa_c360_4ac.assign(
            RegulatoryName="C86", LOB="Retail",
            ReportName="C86 Client360 Product Appropriateness",
            ControlRisk="Completeness", TestType="Anomaly", TestPeriod="Origination",
            ProductType=tmp_pa_c360_4ac["PROD_CATG_NM"],
            RDE="PA002_Client360_Completeness_RDE", segment="Account Open",
            segment2=tmp_pa_c360_4ac["ASCT_PROD_FMLY_NM"],
            segment3=tmp_pa_c360_4ac["PROD_SRVC_NM"],
            segment6=tmp_pa_c360_4ac["OPPOR_STAGE_NM"],
            segment7=tmp_pa_c360_4ac["TOOL_USED"],
            segment10=tmp_pa_c360_4ac["EVNT_DT"].dt.strftime("%Y%m"),
            CommentCode="COM13", Comments=CS_CMT_MAP["COM13"], HoldoutFlag="N",
            SnapDate=snapdate_series.dt.date,
            DateCompleted=pd.to_datetime(dates["tday"], format="%Y%m%d").date(),
        )
        s.log_dataset("tmp_pa_c360_4ac", tmp_pa_c360_4ac,
                      input_name="tmp0", input_nobs=len(tmp0), where_clause="level_oppor=1")

    # ── Tool use assessment (PA002) ──
    with log.step("create tmp_pa_c360_ac_assessment") as s:
