            table_name="tracking_count_tool_use_pre2",
            sql="SELECT OPPOR_ID,\n       COUNT(DISTINCT UPCASE(ADVC_TOOL_NM)) AS count_unique_tool_used\nFROM tracking_all\nWHERE OPPOR_ID IS NOT NULL AND ADVC_TOOL_NM IS NOT NULL\nGROUP BY OPPOR_ID\nORDER BY count_unique_tool_used DESC",
