def _pull_tracking_data(cfg: Config, dates: Dict[str, str]) -> pd.DataFrame:
    """Pull tracking data from DDWV01.EVNT_PROD_TRACK_LOG."""
    logging.info("Pulling data from tracking_all (DDWV01.EVNT_PROD_TRACK_LOG)...")
    sql_tracking_all = """
        SELECT *
        FROM DDWV01.EVNT_PROD_TRACK_LOG
        WHERE advr_selt_typ = 'Advice Tool'
        AND EVNT_DT > (CAST({wk_start} AS DATE) - 90)
    """.format(wk_start=dates["wk_start"])

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        tracking_all = pd.read_sql(sql_tracking_all, conn)
    logging.info("Loaded %d rows into tracking_all.", len(tracking_all))
    return tracking_all


def _process_tracking_data(tracking_all: pd.DataFrame) -> pd.DataFrame:
    """Process tracking data and return tool_use DataFrame."""
    logging.info("Processing tracking data (replicating 3 PROC SQL steps)...")

    tracking_all_filtered = tracking_all.dropna(subset=["OPPOR_ID", "ADVC_TOOL_NM"]).copy()
    tracking_all_filtered["ADVC_TOOL_NM"] = (
        tracking_all_filtered["ADVC_TOOL_NM"].astype(str).str.upper()
    )

    tracking_tool_use_distinct = tracking_all_filtered[
        ["OPPOR_ID", "ADVC_TOOL_NM"]
    ].drop_duplicates()
    logging.info("Created tracking_tool_use_distinct: %d rows", len(tracking_tool_use_distinct))

    tracking_count_tool_use_pre2 = (
        tracking_all_filtered.groupby("OPPOR_ID")["ADVC_TOOL_NM"]
        .nunique()
        .reset_index(name="count_unique_tool_used")
        .sort_values(by="count_unique_tool_used", ascending=False)
    )
    logging.info("Created tracking_count_tool_use_pre: %d rows", len(tracking_count_tool_use_pre2))

    tracking_tool_use = tracking_count_tool_use_pre2[
        tracking_count_tool_use_pre2["count_unique_tool_used"] > 0
    ][["OPPOR_ID"]].copy()
    tracking_tool_use["tool_used"] = "Tool Used"
    logging.info("Created tracking_tool_use: %d rows", len(tracking_tool_use))

    return tracking_tool_use


def _pull_c360_detail(cfg: Config, dates: Dict[str, str]) -> pd.DataFrame:
    """Pull C360 detail data using volatile table approach."""
    logging.info("Pulling C360 detail data (using Volatile Table)...")

    sql_create_vt = """
        CREATE MULTISET VOLATILE TABLE c360_short AS
        (
            SELECT
                evnt_id,
                CAST(rbc_oppor_own_id AS INTEGER) AS emp_id,
                evnt_dt AS snap_dt
            FROM DDWV01.evnt_prod_oppor
            WHERE rbc_oppor_own_id IS NOT NULL
            AND evnt_dt IS NOT NULL
            AND evnt_id IS NOT NULL
            AND evnt_dt BETWEEN {wk_start} AND {wk_end}
        ) WITH DATA
        PRIMARY INDEX (emp_id, snap_dt)
        ON COMMIT PRESERVE ROWS;
    """.format(wk_start=dates["wk_start"], wk_end=dates["wk_end"])

    sql_stats = "COLLECT STATISTICS COLUMN (emp_id, snap_dt) ON c360_short;"

    sql_select = """
        SELECT c360.*,
                emp.org_unt_no,
                emp.hr_posn_titl_en,
                emp.posn_strt_dt,
                emp.posn_end_dt,
                emp.occpt_job_cd
        FROM DDWV01.evnt_prod_oppor AS c360
        LEFT JOIN
        (
            SELECT c3.evnt_id,
                    e1.org_unt_no,
                    e1.hr_posn_titl_en,
                    e2.posn_strt_dt,
                    e2.posn_end_dt,
                    e1.occpt_job_cd
            FROM c360_short AS c3
            INNER JOIN DDWV01.emp AS e1
                ON e1.emp_id = c3.emp_id
                AND c3.snap_dt >= e1.captr_dt
                AND c3.snap_dt <  e1.chg_dt
            INNER JOIN DDWV01.empl_reltn AS e2
                ON e2.emp_id = c3.emp_id
                AND c3.snap_dt >= e2.captr_dt
                AND c3.snap_dt <  e2.chg_dt
        ) AS emp
        ON emp.evnt_id = c360.evnt_id
        WHERE c360.evnt_id IS NOT NULL
            AND c360.evnt_dt BETWEEN {wk_start} AND {wk_end};
    """.format(wk_start=dates["wk_start"], wk_end=dates["wk_end"])

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        cursor = conn.cursor()
        cursor.execute(sql_create_vt)
        cursor.execute(sql_stats)
        c360_detail_pre = pd.read_sql(sql_select, conn)
    logging.info("Loaded %d rows into c360_detail_pre.", len(c360_detail_pre))

    # Fill LOB default
    if "LOB" not in c360_detail_pre.columns:
        c360_detail_pre["LOB"] = "Retail"
    else:
        c360_detail_pre["LOB"] = c360_detail_pre["LOB"].fillna("Retail")

    logging.info("Created c360_detail: %d rows", len(c360_detail_pre))
    logging.info("PROC FREQ for c360_detail['LOB']:\n%s", c360_detail_pre["LOB"].value_counts(dropna=False))
    return c360_detail_pre


def _pull_aot_data(cfg: Config, dates: Dict[str, str]) -> pd.DataFrame:
    """Pull AOT data and return unique oppor IDs."""
    logging.info("Pulling AOT data (DDWV01.evnt_prod_aot)...")
    sql_aot = """
        SELECT
            oppor_id,
            COUNT(*) AS count_aot
        FROM DDWV01.evnt_prod_aot
        WHERE ess_src_evnt_dt BETWEEN {wk_start_min14} AND {wk_end}
            AND oppor_id IS NOT NULL
        GROUP BY 1
    """.format(wk_start_min14=dates["wk_start_min14"], wk_end=dates["wk_end"])

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        aot_all_oppor = pd.read_sql(sql_aot, conn)
    logging.info("Loaded %d rows into aot_all_oppor.", len(aot_all_oppor))

    aot_unique = aot_all_oppor[["OPPOR_ID"]].drop_duplicates().copy()
    aot_unique.rename(columns={"OPPOR_ID": "aot_oppor_id"}, inplace=True)
    logging.info("Created aot_all_oppor_unique: %d rows", len(aot_unique))
    return aot_unique


def _link_aot_and_filter(
    c360_detail: pd.DataFrame,
    aot_unique: pd.DataFrame,
    stage_format_map: Dict[str, str],
) -> pd.DataFrame:
    """Link AOT data to C360 and apply business filters."""
    logging.info("Creating c360_detail_link_aot...")
    c360_link = pd.merge(
        c360_detail,
        aot_unique,
        left_on="OPPOR_ID",
        right_on="aot_oppor_id",
        how="left",
        validate="many_to_one",
    )
    cond_prod = c360_link["PROD_CATG_NM"] == "Personal Accounts"
    cond_aot = c360_link["aot_oppor_id"].notna()
    c360_link["C360_PDA_Link_AOT"] = np.where(cond_prod & cond_aot, 1, 0)
    logging.info("Created c360_detail_link_aot: %d rows", len(c360_link))

    # Filter
    logging.info("Filtering to c360_detail_more_in_pre...")
    c360_link["oppor_stage_nm_f"] = c360_link["OPPOR_STAGE_NM"].map(stage_format_map)

    cond1 = c360_link["ASCT_PROD_FMLY_NM"] != "Risk Protection"
    cond2 = c360_link["LOB"] == "Retail"
    cond3 = c360_link["C360_PDA_Link_AOT"] == 0
    cond4 = c360_link["OPPOR_STAGE_NM"].isin(["Opportunity Won", "Opportunity Lost"])
    all_conditions = cond1 & cond2 & cond3 & cond4

    result = c360_link[all_conditions].copy()
    logging.info("Created c360_detail_more_in: %d rows", len(result))
    return result


def _build_autocomplete_data(c360_detail_more_in: pd.DataFrame) -> pd.DataFrame:
    """Build autocomplete count/tool datasets."""
    seg4_map_count = {
        PA_NOT_APPROPRIATE_RATIONALE: PA_PRODUCT_NOT_APPROPRIATE,
        PA_CLIENT_DECLINED: PA_CLIENT_DECLINED_SHORT,
        PA_PRODUCT_APPROPRIATE: PA_PRODUCT_APPROPRIATE,
        PA_ASSESSED_OUTSIDE_C360: PA_ASSESSED_OUTSIDE_C360,
    }

    df_agg = c360_detail_more_in.copy()
    df_agg["segment9"] = ""
    df_agg["segment4"] = df_agg["IS_PROD_APRP_FOR_CLNT"].map(seg4_map_count).fillna("Missing")
    df_agg["RDE"] = "PA003_Client360_Completeness_Tool"
    df_agg["segments5"] = df_agg["prod_not_aprp_rtnl_txt_cat"]

    group_by_cols = [
        "RegulatoryName", "LOB", "ReportName", "ControlRisk",
        "TestType", "TestPeriod", "ProductType", "RDE",
        "segment", "segment2", "segment3", "segment4", "segment5",
        "segment6", "segment7", "segment8", "segment9", "segment10",
        "HoldoutFlag", "CommentCode", "Comments",
        "DateCompleted", "SnapDate",
    ]

    fill_cols = [c for c in group_by_cols if c != "segment9"]
    df_agg[fill_cols] = df_agg[fill_cols].fillna("Missing")

    result = (
        df_agg.groupby(group_by_cols, dropna=False)
        .size()
        .reset_index(name="Volume")
    )
    result["Amount"] = np.nan
    result["DateCompleted"] = pd.to_datetime(result["DateCompleted"], errors="coerce")
    result["SnapDate"] = pd.to_datetime(result["SnapDate"], errors="coerce")

    logging.info("Created pa_c360_autocomplete_count_tool: %d rows", len(result))

    # Combine (extend concat list if tool_use df exists)
    if "segment9" not in result.columns:
        result["segment9"] = ""

    combined = pd.concat([result], ignore_index=True)
    combined["DateCompleted"] = pd.to_datetime(combined["DateCompleted"], errors="coerce")
    combined["SnapDate"] = pd.to_datetime(combined["SnapDate"], errors="coerce")
    logging.info("Created combine_pa_autocomplete: %d rows", len(combined))

    return combined


def _save_autocomplete_outputs(
    spark: SparkSession,
    cfg: Config,
    ac_path: Path,
    ac_data: pd.DataFrame,
) -> None:
    """Save autocomplete data to local parquet, S3 parquet, and Excel."""
    logging.info("Appending and saving autocomplete data...")
    autocomplete_path = ac_path / cfg.persistent_ac_file
    ac_data.to_parquet(autocomplete_path, index=False)
    logging.info("Saved persistent file: %s", autocomplete_path)

    # Write parquet to S3
    s3_ac_parquet = s3_path("output", cfg.persistent_ac_file)
    write_parquet_to_s3(spark, ac_data, s3_ac_parquet)

    # Export to Excel
    logging.info("Exporting autocomplete to Excel...")
    excel_path = ac_path / cfg.excel_autocomplete_file
    with pd.ExcelWriter(
        excel_path,
        engine="openpyxl",
        datetime_format="{} H:MM:SS".format(DATE_FORMAT_MDY),
        date_format=DATE_FORMAT_MDY,
    ) as writer:
        ac_data.to_excel(writer, sheet_name="autocomplete", index=False)
    logging.info("Exported autocomplete Excel: %s", excel_path)

    # Upload Excel to S3
    s3_ac_excel = s3_path("output", cfg.excel_autocomplete_file)
    upload_file_to_s3(spark, str(excel_path), s3_ac_excel)


