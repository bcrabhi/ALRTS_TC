# SQL — same joins / filters as the three PROC SQL steps

SAMPLE_SQL = """
SELECT COB_MRRMIP_MR.snap_dt,
       COUNT(*) AS [count]
FROM dbo.COB_MRRMIP_MR AS COB_MRRMIP_MR
INNER JOIN dbo.tracker_report AS tracker_report
        ON COB_MRRMIP_MR.reportid = tracker_report.reportid
WHERE exclude = 0
GROUP BY COB_MRRMIP_MR.snap_dt
"""


ACTION_TAKEN_SQL = """
SELECT a.snap_dt,
       cde.CDEName,
       b.ActionTaken,
       COUNT(*) AS [count]
FROM dbo.COB_MRRMIP_MR AS a
INNER JOIN dbo.tracker_report AS tracker_report
        ON a.reportid = tracker_report.reportid
LEFT JOIN dbo.cdetracker AS b
       ON a.reportid = b.ReportId
LEFT JOIN dbo.[Option] AS ORes
       ON ORes.OptionID = b.ResolutionOptionId
LEFT JOIN dbo.[Option] AS ORoot
       ON ORoot.OptionID = b.RootCauseOptionId
LEFT JOIN dbo.[Option] AS OAct
       ON OAct.OptionID = b.ActionTaken
LEFT JOIN dbo.CDE AS cde
       ON cde.CDEId = b.CDEId
WHERE a.snap_dt >= ?
  AND exclude = 0
GROUP BY a.snap_dt, cde.CDEName, b.ActionTaken
"""

DETAILS_SQL = """
SELECT a.snap_dt AS Snap_Date,
       a.ar_id AS AR_ID,
       a.ip_id AS SRF,
       a.Activation_date,
       b.ActionTaken,
       ORes.[value] AS Resolution,
       ORoot.[value] AS Rootcause,
       b.comments
FROM dbo.COB_MRRMIP_MR AS a
INNER JOIN dbo.tracker_report AS tracker_report
        ON a.reportid = tracker_report.reportid
LEFT JOIN dbo.cdetracker AS b
       ON a.reportid = b.ReportId
LEFT JOIN dbo.[Option] AS ORes
       ON ORes.OptionID = b.ResolutionOptionId
LEFT JOIN dbo.[Option] AS ORoot
       ON ORoot.OptionID = b.RootCauseOptionId
LEFT JOIN dbo.[Option] AS OAct
       ON OAct.OptionID = b.ActionTaken
LEFT JOIN dbo.CDE AS cde
       ON cde.CDEId = b.CDEId
WHERE a.snap_dt >= ?
  AND exclude = 0
ORDER BY a.snap_dt
"""



# Path resolution — ENV switch + makedirs (the COB_MRR_MIP_RS.py pattern)

def configure_paths() -> Tuple[Path, Path]:
    """Resolve the ENV-specific log/export directories and create them.

    Mirrors the SAS production-vs-dev path switch. Both directories are made
    with ``parents=True, exist_ok=True`` so a missing folder no longer raises
    -- this is what previously broke the log FileHandler and the Excel export
    on the Linux container. Wrapped in a function (rather than run at import)
    so importing the module for testing has no filesystem side effects.

    Returns:
        Tuple of (log_dir, export_dir); both are guaranteed to exist on return.
    """
    sub = "production" if ENV == "PROD" else "dev"
    base = Path(BASE_PATH) / sub / "MRRMIP"
    log_dir = base / "log"
    export_dir = base / "export"
    for directory in (log_dir, export_dir):
        try:
            directory.mkdir(parents=True, exist_ok=True)
        except OSError as exc:
            # e.g. PermissionError when an absolute BASE_PATH like /sas/broc/COB
            # is not creatable on the container. Fail with one clear line
            # instead of a recursive pathlib traceback.
            raise RuntimeError(
                f"Cannot create {directory} (BASE_PATH={BASE_PATH!r}, ENV={ENV}): "
                f"{exc}. Set COB_BASE_PATH to a writable location, e.g. "
                f"`export COB_BASE_PATH=$HOME/cob_mrrmip`."
            ) from exc
    return log_dir, export_dir



# Connection — replaces the SAS Windows DSN; portable across environments

def _odbc_quote(value: str) -> str:

    if value and (any(c in value for c in ";{}") or value != value.strip()):
        return "{" + value.replace("}", "}}") + "}"
    return value


def mask_pwd(conn_str: str) -> str:

    return re.sub(
        r"(PWD=)(\{(?:[^}]|\}\})*\}|[^;]*)", r"\1***", conn_str, flags=re.IGNORECASE
    )


def _find_sql_config() -> Path:

    candidates = []
    env_path = os.environ.get(SQL_CONFIG_ENV_VAR)
    if env_path:
        candidates.append(Path(env_path))
    candidates.append(Path(__file__).resolve().parent / SQL_CONFIG_FILENAME)
    candidates.append(Path.cwd() / SQL_CONFIG_FILENAME)

    for candidate in candidates:
        if candidate.is_file():
            return candidate
    searched = ", ".join(str(c) for c in candidates)
    raise RuntimeError(
        f"Could not find {SQL_CONFIG_FILENAME}. Looked in: {searched}. "
        f"Create it or point {SQL_CONFIG_ENV_VAR} at its full path."
    )


def load_sql_config(path: Optional[Path] = None) -> Dict[str, Any]:

    cfg_path = path or _find_sql_config()
    try:
        raw = json.loads(cfg_path.read_text(encoding="utf-8"))
    except FileNotFoundError as exc:
        raise RuntimeError(f"{SQL_CONFIG_FILENAME} not found at {cfg_path}.") from exc
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"{cfg_path} is not valid JSON: {exc}.") from exc
    if not isinstance(raw, dict):
        raise RuntimeError(f"{cfg_path} must contain a JSON object, got {type(raw).__name__}.")

    # Lower-case the incoming keys once, then map each canonical field.
    lowered = {str(k).lower(): v for k, v in raw.items()}
    normalised: Dict[str, Any] = {}
    for canonical, aliases in CONFIG_ALIASES.items():
        for alias in aliases:
            if alias in lowered and lowered[alias] not in (None, ""):
                normalised[canonical] = lowered[alias]
                break
    normalised["_source"] = str(cfg_path)
    return normalised


def build_connection_string(cfg: Dict[str, Any]) -> Tuple[str, str]:

    pwd = cfg.get("pwd", "")

    # Mode 1 — full connection string provided verbatim (allow ${PWD} subst).
    if cfg.get("conn"):
        return str(cfg["conn"]).replace("${PWD}", pwd), f"conn string ({cfg['_source']})"

    # Mode 2 — named DSN (only if the container actually defines it).
    if cfg.get("dsn"):
        uid = cfg.get("uid", "")
        return (
            f"DSN={cfg['dsn']};UID={_odbc_quote(str(uid))};"
            f"PWD={_odbc_quote(str(pwd))}",
            f"DSN={cfg['dsn']}",
        )

    # Mode 3 — DSN-less driver connection (the expected/default mode).
    missing = [f for f in ("host", "uid", "pwd", "database") if not cfg.get(f)]
    if missing:
        raise RuntimeError(
            f"{cfg.get('_source', SQL_CONFIG_FILENAME)} is missing required "
            f"field(s): {', '.join(missing)}. Provide host, database, uid and "
            f"pwd (or a 'conn'/'dsn' entry)."
        )
    host = str(cfg["host"])
    if cfg.get("port") and "," not in host and "\\" not in host:
        host = f"{host},{cfg['port']}"  # SQL Server uses host,port (comma)
    driver = cfg.get("driver", DEFAULT_ODBC_DRIVER)
    parts = [
        f"DRIVER={{{driver}}}",
        f"SERVER={host}",
        f"DATABASE={cfg['database']}",
        f"UID={_odbc_quote(str(cfg['uid']))}",
        f"PWD={_odbc_quote(str(pwd))}",
        "TrustServerCertificate=yes",  # needed for Driver 18 (Encrypt=yes default)
    ]
    return ";".join(parts), "driver (DSN-less)"


def _resolve_from_sql_json() -> Tuple[str, str]:

    sql_cfg = load_sql_config()
    LOGGER.info("Loaded connection settings from %s", sql_cfg["_source"])
    return build_connection_string(sql_cfg)


def _resolve_from_cob_utils() -> Tuple[str, str]:

    if _utils_conn_string is None:
        raise RuntimeError(
            "COB_CONN_SOURCE=cob_utils but the cob_utils package is not "
            "importable. Install the utils package, or use "
            "COB_CONN_SOURCE=sql_json for now."
        )
    try:
        conn = _utils_conn_string(TRACKER_CONNECTION_NAME)
    except Exception as exc:
        # cob_utils raises its own types (SecretError, UnknownConnection...)
        # which we cannot import unconditionally; wrap at this boundary.
        raise RuntimeError(
            f"cob_utils could not resolve connection "
            f"{TRACKER_CONNECTION_NAME!r}: {exc}"
        ) from exc
    return conn, f"cob_utils registry [{TRACKER_CONNECTION_NAME}]"


def resolve_connection() -> Tuple[str, str]:

    LOGGER.info("Connection source: %s", CONNECTION_SOURCE)
    if CONNECTION_SOURCE == "sql_json":
        return _resolve_from_sql_json()
    if CONNECTION_SOURCE == "cob_utils":
        return _resolve_from_cob_utils()
    if CONNECTION_SOURCE == "auto":
        if _utils_conn_string is not None:
            return _resolve_from_cob_utils()
        return _resolve_from_sql_json()
    raise RuntimeError(
        f"Unknown COB_CONN_SOURCE={CONNECTION_SOURCE!r} "
        f"(expected 'sql_json', 'cob_utils', or 'auto')."
    )



# Date helpers — replicate the SAS data _null_ / intnx block

def month_end(anchor: date, months_back: int) -> date:
    """Replicate SAS ``intnx('month', anchor, -months_back, 'E')``.

    Args:
        anchor: Reference date (SAS used &sysdate9, i.e. the run date).
        months_back: Number of whole months to step back.

    Returns:
        The last calendar day of the resulting month.
    """
    months = anchor.year * 12 + (anchor.month - 1) - months_back
    year, month = divmod(months, 12)
    month += 1
    return date(year, month, calendar.monthrange(year, month)[1])


def get_run_dates(run_date: date) -> Tuple[date, str, str, date]:

    pre_mon_end = month_end(run_date, 1)
    last_12_month = month_end(run_date, 12)
    pre_mon_end3 = pre_mon_end.strftime("%Y%m")    # YYMMn6.
    pre_mon_end4 = pre_mon_end.strftime("%Y%m%d")  # YYMMDDn8.
    return pre_mon_end, pre_mon_end3, pre_mon_end4, last_12_month



# Logging — replicates proc printto log="...MRR_MIP_Dashboard_<ts>.log" new

def setup_logging(log_dir: Path) -> Path:

    # SAS: %sysfunc(today(),yymmddn8.)_%sysfunc(compress(%sysfunc(time(),time.),:))
    log_dir.mkdir(parents=True, exist_ok=True)  # belt-and-suspenders vs FileHandler error
    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    log_path = log_dir / f"MRR_MIP_Dashboard_{stamp}.log"
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s %(message)s",
        handlers=[
            logging.FileHandler(log_path, mode="w", encoding="utf-8"),
            logging.StreamHandler(sys.stdout),
        ],
    )
    return log_path



# Transformations

def decode_action_taken(code: object) -> str:

    if pd.isna(code):
        return ACTION_TAKEN_DEFAULT
    try:
        return ACTION_TAKEN_MAP.get(int(code), ACTION_TAKEN_DEFAULT)
    except (TypeError, ValueError):
        return ACTION_TAKEN_DEFAULT


def strip_leading_zeros(value: object) -> object:

    if value is None or (isinstance(value, float) and pd.isna(value)):
        return value
    return re.sub(r"^(0*)", " ", str(value), count=1)


def build_action_taken_summary(raw: pd.DataFrame) -> pd.DataFrame:

    out = raw.copy()
    out["ActionTaken"] = out["ActionTaken"].map(decode_action_taken)
    return (
        out.groupby(["snap_dt", "CDEName", "ActionTaken"], dropna=False)["count"]
        .sum()
        .reset_index()
    )


def build_details(raw: pd.DataFrame) -> pd.DataFrame:

    out = raw.copy()
    out["Action_Taken"] = out["ActionTaken"].map(decode_action_taken)
    return out[
        [
            "Snap_Date",
            "AR_ID",
            "SRF",
            "Activation_date",
            "Action_Taken",
            "Resolution",
            "Rootcause",
            "comments",
        ]
    ]



# Export — replicates proc export dbms=xlsx replace

def export_to_excel(df: pd.DataFrame, path: Path, sheet_name: str) -> None:
    with pd.ExcelWriter(
        path,
        engine="xlsxwriter",
        date_format="mm/dd/yyyy",
        datetime_format="mm/dd/yyyy",
    ) as writer:
        df.to_excel(writer, sheet_name=sheet_name, index=False)
    LOGGER.info("Exported %d rows to %s [sheet=%s]", len(df), path, sheet_name)



# Main

def main() -> int:

    try:
        log_dir, export_dir = configure_paths()
    except RuntimeError as exc:
        # Logging isn't set up yet (no log dir), so report to stderr and exit.
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1
    log_path = setup_logging(log_dir)
    LOGGER.info(
        ">>>>>>>>>> This program is starting running at %s by %s <<<<<<<<<<",
        datetime.now().strftime("%d%b%Y:%H:%M:%S").upper(),
        USER,
    )
    LOGGER.info(">>>>>>>>>> Prod/Dev? - %s <<<<<<<<<<", ENV)
    LOGGER.info("Log file:   %s", log_path)
    LOGGER.info("Export dir: %s", export_dir)

    run_date = date.today()  # SAS &sysdate9
    pre_mon_end, pre_mon_end3, pre_mon_end4, last_12_month = get_run_dates(run_date)
    LOGGER.info("pre_mon_end   = %s", pre_mon_end.strftime("%d%b%Y").upper())
    LOGGER.info("pre_mon_end3  = %s", pre_mon_end3)
    LOGGER.info("pre_mon_end4  = %s", pre_mon_end4)
    LOGGER.info("last_12_month = %s", last_12_month.strftime("%d%b%Y").upper())

    try:
        conn_str, mode = resolve_connection()
    except RuntimeError as exc:
        LOGGER.error("%s", exc)
        return 1
    LOGGER.info("Connecting to tracker via %s", mode)
    LOGGER.info("Connection string: %s", mask_pwd(conn_str))

    try:
        with pyodbc.connect(conn_str) as conn:
            LOGGER.info("Step 1 - sample: monthly sample counts (exclude = 0)")
            sample = pd.read_sql(SAMPLE_SQL, conn)
            LOGGER.info("sample: %d rows", len(sample))

            LOGGER.info("Step 2 - Action_Taken: counts by snap_dt / CDE / action")
            action_raw = pd.read_sql(
                ACTION_TAKEN_SQL, conn, params=[last_12_month]
            )
            action_taken = build_action_taken_summary(action_raw)
            LOGGER.info("Action_Taken: %d rows", len(action_taken))

            LOGGER.info("Step 3 - Details: review-level detail, last 12 months")
            details_raw = pd.read_sql(DETAILS_SQL, conn, params=[last_12_month])
            details = build_details(details_raw)
            LOGGER.info("Details: %d rows", len(details))
    except pyodbc.Error as exc:
        LOGGER.error("Database step failed: %s", exc)
        raise

    # Details2: strip leading zeros from AR_ID (SAS prxchange), then export.
    details2 = details.copy()
    details2["AR_ID"] = details2["AR_ID"].map(strip_leading_zeros)
    export_to_excel(
        details2,
        export_dir / f"COB_Control_dashboard_{pre_mon_end3}.xlsx",
        sheet_name="ReviewResult",
    )


    error = details[
        details["Action_Taken"].str.contains("Error Found", regex=False, na=False)
        & (pd.to_datetime(details["Snap_Date"]) == pd.Timestamp(pre_mon_end))
    ]
    # SAS proc export without SHEET= names the sheet after the data set.
    export_to_excel(
        error,
        export_dir / f"MRR_Fail_Detail_{pre_mon_end4}.xlsx",
        sheet_name="Error",
    )

    LOGGER.info(
        ">>>>>>>>>> Program completed at %s <<<<<<<<<<",
        datetime.now().strftime("%d%b%Y:%H:%M:%S").upper(),
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
