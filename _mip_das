# Configuration — ENV-driven paths (mirrors the SAS libnames / output paths)


ENV = os.environ.get("ENV", "PROD")          # 'PROD' or anything else => dev
USER = os.environ.get("USER", getpass.getuser())


BASE_PATH = os.environ.get("COB_BASE_PATH", "/sas/broc/COB")

# ODBC connection — SAS: Libname sql ODBC DSN="DYOF_Tracker" ...
ODBC_DSN = "DYOF_Tracker"
ODBC_UID = "DataIntegrity"
