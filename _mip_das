# BASE_PATH mirrors the SAS libname root (/sas/broc/COB). The default is the
# RELATIVE "sas/broc/COB" (matching COB_MRR_MIP_RS.py) so it resolves under the
# current working directory on the container, which is writable. Set an
# ABSOLUTE COB_BASE_PATH for production, e.g. the real mount /sas/broc/COB, or
# any writable location such as $HOME/cob_mrrmip.
#   NOTE: an absolute default like /sas/broc/COB fails on the dev container —
#   mkdir(parents=True) walks up to /sas, which jovyan cannot create
#   (PermissionError [Errno 13]). Keep it relative or override the env var.
BASE_PATH = os.environ.get("COB_BASE_PATH", "sas/broc/COB")

# ODBC connection. SAS used a Windows DSN: Libname sql ODBC DSN="DYOF_Tracker"
# schema=dbo. That DSN does not exist on the Linux container. Connection
# details are now read from a JSON config file (sql.json) instead of env vars.
#
# Expected sql.json (driver-based connection, the mode confirmed working on the
# container — "ODBC Driver 18 for SQL Server" is installed):
#     {
#         "driver":   "ODBC Driver 18 for SQL Server",
#         "host":     "your_sqlserver_host,1433",
#         "database": "DYOF_Tracker",
#         "uid":      "DataIntegrity",
#         "pwd":      "your_password"
#     }
# Alternatively the file may carry a ready-made "conn" string, or a "dsn" name.
# Key names are matched case-insensitively and accept common aliases (see the
# CONFIG_ALIASES map below), so an existing sql.json with slightly different
# keys (server/password/user/db) will still work.
#
# Path search order: the SQL_CONFIG env var, else sql.json next to this script,
# else sql.json in the current working directory.
SQL_CONFIG_ENV_VAR = "SQL_CONFIG"
SQL_CONFIG_FILENAME = "sql.json"

# Default driver if sql.json does not specify one (Driver 18 confirmed present).
DEFAULT_ODBC_DRIVER = "ODBC Driver 18 for SQL Server"

# Canonical field -> accepted aliases (all compared lower-cased).
CONFIG_ALIASES: Dict[str, Tuple[str, ...]] = {
    "driver": ("driver",),
    "host": ("host", "server", "hostname"),
    "port": ("port",),
    "database": ("database", "db", "initial catalog"),
    "uid": ("uid", "user", "username", "userid"),
    "pwd": ("pwd", "password", "passwd", "pass"),
    "dsn": ("dsn",),
    "conn": ("conn", "connection_string", "connectionstring"),
}

