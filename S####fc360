def main(ss, job_conf) -> None:
    cfg = Config()

    ymd = datetime.now().strftime("%Y%m%d")
    log_file_name = "C86_pa_client360_{}.log".format(ymd)
    setup_logging(cfg.logpath, log_file_name)

    logging.info("=" * 50)
    logging.info("SAS to Python Migration: C86_pa_client360 Starting...")
    logging.info("Script running as user: %s", os.environ.get('USER', 'Unknown'))
    logging.info("Platform: %s", os.environ.get('HOSTNAME', 'Unknown'))

    # Initialize PySpark session with S3 connectivity
    spark = get_spark_session("C86_PA_Client360")
    logging.info("Spark session initialized. Master: %s", spark.sparkContext.master)
    logging.info("S3 endpoint: %s, Bucket: %s", S3_ENDPOINT, S3_BUCKET)

    # Ensure output directory
    cfg.outpath.mkdir(parents=True, exist_ok=True)
    logging.info("Ensured output directory exists: %s", cfg.outpath)

    ac_path = cfg.outpath

    # Ini-check + date setup
    ini_run = check_ini_run(ac_path, cfg.persistent_ac_file)
    logging.info("ini_run determined: '%s'", ini_run)

    dates, _week_end_dt = setup_dates(ini_run)
    runday = dates["runday"]

    dataout_path = cfg.outpath / runday
    dataout_path.mkdir(parents=True, exist_ok=True)
    logging.info("Ensured runday output directory exists: %s", dataout_path)

    # Pull tracking data ─
    logging.info("Pulling data from tracking_all (DDWV01.EVNT_PROD_TRACK_LOG)...")
    sql_tracking_all = """
        SELECT *
        FROM DDWV01.EVNT_PROD_TRACK_LOG
        WHERE advr_selt_typ = 'Advice Tool'
        AND EVNT_DT > (CAST({wk_start} AS DATE) - 90)
    """.format(wk_start=dates['wk_start'])

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        tracking_all = pd.read_sql(sql_tracking_all, conn)
    logging.info("Loaded %d rows into tracking_all.", len(tracking_all))

    tracking_tool_use, tracking_tool_use_distinct = _process_tracking_data(tracking_all)

#     Pull C360 detail data 
    c360_detail = _pull_c360_detail(cfg, dates, tracking_tool_use)

#     Pull AOT data
    logging.info("Pulling AOT data (DDWV01.evnt_prod_aot)...")
    sql_aot_all_oppor = """
        SELECT
            oppor_id,
            COUNT(*) AS count_aot
        FROM DDWV01.evnt_prod_aot
        WHERE ess_src_evnt_dt BETWEEN {wk_start_min14} AND {wk_end}
            AND oppor_id IS NOT NULL
        GROUP BY 1
    """.format(
        wk_start_min14=dates['wk_start_min14'],
        wk_end=dates['wk_end'],
    )

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        aot_all_oppor = pd.read_sql(sql_aot_all_oppor, conn)
    logging.info("Loaded %d rows into aot_all_oppor.", len(aot_all_oppor))

    aot_all_oppor_unique = aot_all_oppor[["OPPOR_ID"]].drop_duplicates().copy()
    aot_all_oppor_unique.rename(columns={"OPPOR_ID": "aot_oppor_id"}, inplace=True)
    logging.info("Created aot_all_oppor_unique: %d rows", len(aot_all_oppor_unique))

    # Link AOT and filter 
    c360_detail_more_in = _link_aot_and_filter(
        c360_detail, aot_all_oppor_unique, STAGE_FORMAT_MAP
    )

    # Build autocomplete dataset 
    ac_pa_client360_autocomplete, tmp_pa_c360_4ac_count_pre = _build_autocomplete_dataset(
        c360_detail_more_in, tracking_tool_use_distinct, dates
    )

    # Export autocomplete 
    _export_autocomplete(spark, ac_pa_client360_autocomplete, ac_path, cfg, dates)

    # Export detail
    _export_detail(spark, tmp_pa_c360_4ac_count_pre, dataout_path, runday)

    # Export pivot 
    _export_pivot(spark, ac_pa_client360_autocomplete, ac_path, cfg)

    logging.info("=" * 50)
    logging.info("Python script execution completed successfully.")
    logging.info("All outputs saved locally AND to S3.")
    logging.info("=" * 50)

    spark.stop()
    logging.info("Spark session stopped.")

    #Optional: SQL Server load
    do_sql_load = False  # flip to True when ready
    if do_sql_load:
        excel_path = ac_path / cfg.excel_autocomplete_file
        _load_to_sql_server(cfg, excel_path)


