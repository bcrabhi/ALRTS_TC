def configure_s3a(spark: SparkSession) -> SparkSession:
    hconf = spark.sparkContext._jsc.hadoopConfiguration()
    hconf.set("fs.s3a.endpoint",                S3_ENDPOINT)
    hconf.set("fs.s3a.connection.ssl.enabled",  "true")
    hconf.set("fs.s3a.path.style.access",       "true")
    hconf.set("fs.s3a.impl",                    "org.apache.hadoop.fs.s3a.S3AFileSystem")
    return spark


def get_spark_session(app_name: str = "C86_PA_Client360") -> SparkSession:
    """Returns a Spark session already wired up for S3."""
    spark = (
        SparkSession.builder
        .master("yarn")
        .appName(app_name)
        .getOrCreate()
    )
    configure_s3a(spark)
    return spark


def s3_path(folder: str, *parts: str) -> str:
    base = S3_FOLDERS.get(folder, folder)
    return "/".join([base.rstrip("/")] + list(parts))


def upload_file_to_s3(spark: SparkSession, local_path: str, s3_uri: str) -> None:
    sc = spark.sparkContext
    jvm = sc._jvm
    conf = sc._jsc.hadoopConfiguration()

    local_fs_path = jvm.org.apache.hadoop.fs.Path("file://{}".format(os.path.abspath(local_path)))
    s3_fs_path = jvm.org.apache.hadoop.fs.Path(s3_uri)
    fs = s3_fs_path.getFileSystem(conf)

    fs.copyFromLocalFile(False, True, local_fs_path, s3_fs_path)
    logging.info("Uploaded to S3 -> %s", s3_uri)


def _normalize_column_types(df: pd.DataFrame) -> pd.DataFrame:
    
    date_columns = ("DateCompleted", "SnapDate")
    string_exact_columns = (
        "RegulatoryName", "LOB", "ReportName", "ControlRisk",
        "TestType", "TestPeriod", "ProductType", "RDE",
        "HoldoutFlag", "CommentCode", "Comments",
    )

    for col in df.columns:
        if col in date_columns:
            df[col] = pd.to_datetime(df[col], errors="coerce")
        elif col.startswith("segment") or col in string_exact_columns:
            df[col] = df[col].fillna("").astype(str)

    for col in df.columns:
        if df[col].dtype == "object":
            df[col] = df[col].fillna("").astype(str)
        elif df[col].apply(type).nunique() > 1:
            try:
                df[col] = pd.to_datetime(df[col], errors="coerce")
            except Exception:
                df[col] = df[col].fillna("").astype(str)

    return df


def write_parquet_to_s3(spark: SparkSession, df: pd.DataFrame, s3_uri: str) -> None:
    df = df.copy()
    df = _normalize_column_types(df)

    sdf = spark.createDataFrame(df)
    sdf.write.mode("overwrite").parquet(s3_uri)
    logging.info("Wrote parquet to S3 -> %s", s3_uri)


def s3_file_exists(spark: SparkSession, s3_uri: str) -> bool:
    sc = spark.sparkContext
    jvm = sc._jvm
    path = jvm.org.apache.hadoop.fs.Path(s3_uri)
    fs = path.getFileSystem(sc._jsc.hadoopConfiguration())
    return fs.exists(path)



#  Helper functions (Connections, Date Logic, Rationale)


def get_teradata_connection(conn_file: Path) -> teradatasql.TeradataConnection:
    if not conn_file.exists():
        logging.error("Connection file not found at: %s", conn_file.resolve())
        raise FileNotFoundError("Connection file not found at: {}".format(conn_file.resolve()))

    with open(conn_file, "r", encoding="utf-8") as f:
        conn_details = json.load(f)

    url = conn_details.get("url")
    user = conn_details.get("user")
    pwd = conn_details.get("password")

    logging.info("Connecting to Teradata URL: %s with user: %s using LDAP...", url, user)
    try:
        conn = teradatasql.connect(host=url, user=user, password=pwd, logmech="LDAP")
        logging.info("Teradata connection successful.")
        return conn
    except Exception as e:
        logging.error("Failed to connect to Teradata: %s", e)
        raise


def check_ini_run(outpath: Path, autocomplete_filename: str) -> str:
    autocomplete_file = Path(outpath) / autocomplete_filename
    autocomplete_backup = Path(outpath) / "{}_backup{}".format(
        autocomplete_file.stem, autocomplete_file.suffix
    )

    if autocomplete_file.exists():
        logging.info("Found existing autocomplete file: %s", autocomplete_file)
        try:
            shutil.copy(autocomplete_file, autocomplete_backup)
            logging.info("Backed up to: %s", autocomplete_backup)
        except Exception as e:
            logging.warning("Could not create backup of autocomplete file: %s", e)
        return "N"

    logging.info("Autocomplete file not found. Setting ini_run = 'Y'.")
    return "Y"


def _calculate_week_dates(tday: date) -> Tuple[date, date]:
    
    days_to_wednesday = (tday.weekday() - 2) % 7
    intnx_week4_b = tday - timedelta(days=days_to_wednesday)
    week_start_dt = intnx_week4_b - timedelta(days=12)
    week_end_dt = intnx_week4_b - timedelta(days=6)
    return week_start_dt, week_end_dt


def _format_date_for_sql(dt: date) -> str:
    
    return "'{}'".format(dt.strftime('%Y-%m-%d'))


def setup_dates(ini_run: str) -> Tuple[Dict[str, str], date]:
    tday = date.today()
    runday = tday.strftime("%Y%m%d")

    week_start_dt, week_end_dt = _calculate_week_dates(tday)

    dates: Dict[str, str] = {}

    if ini_run.upper() == "Y":
        logging.info("ini_run = 'Y'. Using initial launch dates.")
        launch_dt = date(2023, 5, 7)
        launch_dt_min14 = date(2023, 4, 23)
        dates["wk_start"] = _format_date_for_sql(launch_dt)
        dates["wk_start_min14"] = _format_date_for_sql(launch_dt_min14)
        dates["wk_end"] = _format_date_for_sql(week_end_dt)
    else:
        logging.info("ini_run = 'N'. Using rolling weekly dates.")
        dates["wk_start"] = _format_date_for_sql(week_start_dt)
        dates["wk_start_min14"] = _format_date_for_sql(
            week_start_dt - timedelta(days=14)
        )
        dates["wk_end"] = _format_date_for_sql(week_end_dt)

    dates["runday"] = runday
    dates["tday"] = runday

    logging.info("Dates calculated: %s", dates)
    return dates, week_end_dt


def _check_rationale_length(text: str) -> int:
  
    return 0 if len(text) > 5 else 1


def _check_rationale_repeated_chars(text: str) -> int:
  
    if len(text) == 0:
        return 1
    remaining = text.replace(text[0], "")
    return 0 if len(remaining) > 0 else 1


def _check_rationale_alphanumeric(text: str) -> int:
    
    alnum_only = re.sub(r"[^A-Za-z0-9]", "", text)
    return 0 if len(alnum_only) > 2 else 1


def validate_rationale(text: object) -> Tuple[str, int, int, int]:
    if pd.isna(text) or not isinstance(text, str):
        return "Invalid", 1, 1, 1

    x = " ".join(text.split()).upper()

    xfail_chars_gt5 = _check_rationale_length(x)
    xfail_rep_char = _check_rationale_repeated_chars(x)
    xfail_ge_2_alnum = _check_rationale_alphanumeric(x)

    is_valid = (xfail_chars_gt5 + xfail_rep_char + xfail_ge_2_alnum) == 0
    category = "Valid" if is_valid else "Invalid"
    return category, xfail_chars_gt5, xfail_rep_char, xfail_ge_2_alnum



# Data Processing Helpers 


def _process_tracking_data(
    tracking_all: pd.DataFrame,
) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Returns (tracking_tool_use, tracking_tool_use_distinct)."""
    logging.info("Processing tracking data (replicating 3 PROC SQL steps)...")

    tracking_all_filtered = tracking_all.dropna(subset=["OPPOR_ID", "ADVC_TOOL_NM"]).copy()
    tracking_all_filtered["ADVC_TOOL_NM"] = (
        tracking_all_filtered["ADVC_TOOL_NM"].astype(str).str.upper()
    )

    tracking_tool_use_distinct = tracking_all_filtered[
        ["OPPOR_ID", "ADVC_TOOL_NM"]
    ].drop_duplicates()
    logging.info(
        "Created tracking_tool_use_distinct: %d rows", len(tracking_tool_use_distinct)
    )

    tracking_count_tool_use_pre2 = (
        tracking_all_filtered.groupby("OPPOR_ID")["ADVC_TOOL_NM"]
        .nunique()
        .reset_index(name="count_unique_tool_used")
        .sort_values(by="count_unique_tool_used", ascending=False)
    )
    logging.info(
        "Created tracking_count_tool_use_pre: %d rows", len(tracking_count_tool_use_pre2)
    )

    tracking_tool_use = tracking_count_tool_use_pre2[
        tracking_count_tool_use_pre2["count_unique_tool_used"] > 0
    ][["OPPOR_ID"]].copy()
    tracking_tool_use["tool_used"] = "Tool Used"
    logging.info("Created tracking_tool_use: %d rows", len(tracking_tool_use))

    return tracking_tool_use, tracking_tool_use_distinct


def _pull_c360_detail(
    cfg: Config,
    dates: Dict[str, str],
    tracking_tool_use: pd.DataFrame,
) -> pd.DataFrame:
    """Pulls C360 detail via volatile table, then joins tracking_tool_use."""
    logging.info("Pulling C360 detail data (using Volatile Table)...")

    sql_create_vt = """
        CREATE MULTISET VOLATILE TABLE c360_short AS
        (
            SELECT
                evnt_id,
                CAST(rbc_oppor_own_id AS INTEGER) AS emp_id,
                evnt_dt AS snap_dt
            FROM DDWV01.evnt_prod_oppor
            WHERE rbc_oppor_own_id IS NOT NULL
            AND evnt_dt IS NOT NULL
            AND evnt_id IS NOT NULL
            AND evnt_dt BETWEEN {wk_start} AND {wk_end}
        ) WITH DATA
        PRIMARY INDEX (emp_id, snap_dt)
        ON COMMIT PRESERVE ROWS;
    """.format(wk_start=dates['wk_start'], wk_end=dates['wk_end'])

    sql_stats = "COLLECT STATISTICS COLUMN (emp_id, snap_dt) ON c360_short;"

    sql_select = """
        SELECT c360.*,
                emp.org_unt_no,
                emp.hr_posn_titl_en,
                emp.posn_strt_dt,
                emp.posn_end_dt,
                emp.occpt_job_cd
        FROM DDWV01.evnt_prod_oppor AS c360
        LEFT JOIN
        (
            SELECT c3.evnt_id,
                    e1.org_unt_no,
                    e1.hr_posn_titl_en,
                    e2.posn_strt_dt,
                    e2.posn_end_dt,
                    e1.occpt_job_cd
            FROM c360_short AS c3
            INNER JOIN DDWV01.emp AS e1
                ON e1.emp_id = c3.emp_id
                AND c3.snap_dt >= e1.captr_dt
                AND c3.snap_dt <  e1.chg_dt
            INNER JOIN DDWV01.empl_reltn AS e2
                ON e2.emp_id = c3.emp_id
                AND c3.snap_dt >= e2.captr_dt
                AND c3.snap_dt <  e2.chg_dt
        ) AS emp
        ON emp.evnt_id = c360.evnt_id
        WHERE c360.evnt_id IS NOT NULL
            AND c360.evnt_dt BETWEEN {wk_start} AND {wk_end};
    """.format(wk_start=dates['wk_start'], wk_end=dates['wk_end'])

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        with conn.cursor() as cursor:
            logging.info("Executing: CREATE VOLATILE TABLE c360_short...")
            cursor.execute(sql_create_vt)
            logging.info("Executing: COLLECT STATISTICS...")
            cursor.execute(sql_stats)

        logging.info("Executing: SELECT c360_detail_pre...")
        c360_detail_pre = pd.read_sql(sql_select, conn)
    logging.info("Loaded %d rows into c360_detail_pre.", len(c360_detail_pre))

    # Step 7: Join tool info (left join)
    c360_detail = pd.merge(c360_detail_pre, tracking_tool_use, on="OPPOR_ID", how="left")
    c360_detail["TOOL_USED"] = c360_detail["tool_used"].fillna("Tool Not Used")
    c360_detail = c360_detail.drop(columns=["tool_used"])

    if "LOB" not in c360_detail.columns:
        c360_detail["LOB"] = "Retail"
    else:
        c360_detail["LOB"] = c360_detail["LOB"].fillna("Retail")

    logging.info("Created c360_detail: %d rows", len(c360_detail))
    logging.info(
        "PROC FREQ for c360_detail['LOB']:\n%s",
        c360_detail['LOB'].value_counts(dropna=False),
    )
    return c360_detail


def _link_aot_and_filter(
    c360_detail: pd.DataFrame,
    aot_all_oppor_unique: pd.DataFrame,
    stage_format_map: Dict[str, str],
) -> pd.DataFrame:
    """Steps 12-15: link AOT, filter, validate rationale, join back."""
    logging.info("Creating c360_detail_link_aot...")
    c360_detail_link_aot = pd.merge(
        c360_detail,
        aot_all_oppor_unique,
        left_on="OPPOR_ID",
        right_on="aot_oppor_id",
        how="left",
    )
    cond_prod = c360_detail_link_aot["PROD_CATG_NM"] == "Personal Accounts"
    cond_aot = c360_detail_link_aot["aot_oppor_id"].notna()
    c360_detail_link_aot["C360_PDA_Link_AOT"] = np.where(cond_prod & cond_aot, 1, 0)
    logging.info("Created c360_detail_link_aot: %d rows", len(c360_detail_link_aot))

    # Step 13: Filter
    logging.info("Filtering to c360_detail_more_in_pre...")
    df_more = c360_detail_link_aot.copy()
    df_more["oppor_stage_nm_f"] = df_more["OPPOR_STAGE_NM"].map(stage_format_map)

    cond1 = df_more["ASCT_PROD_FMLY_NM"] != "Risk Protection"
    cond2 = df_more["LOB"] == "Retail"
    cond3 = df_more["C360_PDA_Link_AOT"] == 0
    cond4 = df_more["OPPOR_STAGE_NM"].isin(["Opportunity Won", "Opportunity Lost"])
    all_conditions = cond1 & cond2 & cond3 & cond4

    c360_detail_more_in = df_more[all_conditions].copy()
    logging.info("Created c360_detail_more_in: %d rows", len(c360_detail_more_in))

    # Step 14: PA rationale validation
    logging.info("Running PA Rationale validation...")
    pa_rationale_base = c360_detail_more_in[
        c360_detail_more_in["IS_PROD_APRP_FOR_CLNT"] == "Not Appropriate - Rationale"
    ].copy()

    pa_rationale = pa_rationale_base[["EVNT_ID", "IS_PROD_APRP_FOR_CLNT", "CLNT_RTNL_TXT"]].copy()
    validation_results = pa_rationale["CLNT_RTNL_TXT"].apply(
        lambda x: pd.Series(
            validate_rationale(x),
            index=["prod_not_aprp_rtnl_txt_cat", "xfail_chars_gt5", "xfail_rep_char", "xfail_ge_2_alnum"],
        )
    )
    pa_rationale = pd.concat([pa_rationale, validation_results], axis=1)
    logging.info("Validated %d rationale entries", len(pa_rationale))

    # Step 15: Join validation results back
    logging.info("Joining validation results back...")
    c360_detail_more_in = pd.merge(
        c360_detail_more_in,
        pa_rationale.drop(columns=["IS_PROD_APRP_FOR_CLNT", "CLNT_RTNL_TXT"]),
        on="EVNT_ID",
        how="left",
    )

    conds = [
        c360_detail_more_in["IS_PROD_APRP_FOR_CLNT"].isna(),
        c360_detail_more_in["IS_PROD_APRP_FOR_CLNT"] != "Not Appropriate - Rationale",
    ]
    choices = ["Not Available", "Not Applicable"]
    c360_detail_more_in["prod_not_aprp_rtnl_txt_cat"] = np.select(
        conds,
        choices,
        default=c360_detail_more_in["prod_not_aprp_rtnl_txt_cat"],
    )
    logging.info("Updated prod_not_aprp_rtnl_txt_cat on c360_detail_more_in")

    return c360_detail_more_in


