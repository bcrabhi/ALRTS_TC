"""Diagnose a SQL Server 18456 'Login failed' by isolating the cause.

Reads driver/host/uid/pwd from sql.json (so no secret is typed on the command
line) and attempts to connect three ways that differ ONLY in the target
database:

    1. the configured database (e.g. DFES_Tracker)
    2. master
    3. no database specified (server default)

Interpreting the results:
    * all fail                      -> wrong username/password, or the login is
                                       disabled / password expired. Fix the
                                       credential in sql.json.
    * master/no-db pass, configured
      database fails                -> the login is valid but cannot open that
                                       database (permissions / default DB). A
                                       DBA grant is needed; not a code issue.

Usage:
    python diagnose_login.py [path/to/sql.json]

The password is never printed.
"""

from __future__ import annotations

import json
import sys
from pathlib import Path
from typing import Any, Dict, Optional, Tuple

import pyodbc

DEFAULT_DRIVER = "ODBC Driver 18 for SQL Server"
# Same key aliases the dashboard's loader accepts.
ALIASES = {
    "driver": ("driver",),
    "host": ("host", "server", "hostname"),
    "database": ("database", "db", "initial_catalog"),
    "uid": ("uid", "user", "username", "user_id"),
    "pwd": ("pwd", "password", "pass"),
    "port": ("port",),
}


def _pick(raw: Dict[str, Any], names: Tuple[str, ...]) -> Optional[Any]:
    """Return the first present value among the given keys (case-insensitive)."""
    lower = {str(k).lower(): v for k, v in raw.items()}
    for name in names:
        if name in lower and lower[name] not in ("", None):
            return lower[name]
    return None


def _odbc_quote(value: str) -> str:
    """Brace-quote a value containing ';', '{', '}', or edge spaces."""
    if value and (any(c in value for c in ";{}") or value != value.strip()):
        return "{" + value.replace("}", "}}") + "}"
    return value


def _find_config(arg: Optional[str]) -> Path:
    """Locate sql.json: explicit arg, then ./sql.json, then ~/sql.json."""
    candidates = []
    if arg:
        candidates.append(Path(arg))
    candidates += [Path.cwd() / "sql.json", Path.home() / "sql.json"]
    for path in candidates:
        if path.is_file():
            return path
    raise SystemExit(
        f"Could not find sql.json. Looked in: {', '.join(str(c) for c in candidates)}"
    )


def _build(driver: str, host: str, uid: str, pwd: str, database: Optional[str]) -> str:
    """Assemble a DSN-less connection string, optionally without a database."""
    parts = [f"DRIVER={{{driver}}}", f"SERVER={host}"]
    if database:
        parts.append(f"DATABASE={database}")
    parts += [
        f"UID={_odbc_quote(uid)}",
        f"PWD={_odbc_quote(pwd)}",
        "TrustServerCertificate=yes",
    ]
    return ";".join(parts)


def _list_databases(conn_str: str) -> Optional[list]:
    """Connect and return the database names visible to this login.

    Args:
        conn_str: A connection string that should reach at least master.

    Returns:
        Sorted list of database names, or None if listing failed.
    """
    try:
        with pyodbc.connect(conn_str, timeout=10) as cn:
            cur = cn.cursor()
            cur.execute("SELECT name FROM sys.databases ORDER BY name")
            return [row[0] for row in cur.fetchall()]
    except pyodbc.Error as exc:
        print(f"  (could not list databases: {exc})")
        return None


def _attempt(label: str, conn_str: str) -> bool:
    """Try one connection and print PASS/FAIL with the SQLSTATE on failure."""
    try:
        with pyodbc.connect(conn_str, timeout=10):
            print(f"  PASS  {label}")
            return True
    except pyodbc.Error as exc:
        sqlstate = exc.args[0] if exc.args else "?"
        message = str(exc.args[1]) if len(exc.args) > 1 else str(exc)
        # Keep it to the salient bit of the driver message.
        snippet = message.split("]")[-1].strip() or message
        print(f"  FAIL  {label}  [{sqlstate}] {snippet[:120]}")
        return False


def main(argv: list) -> int:
    """Run the three connection attempts and print a verdict."""
    cfg_path = _find_config(argv[1] if len(argv) > 1 else None)
    raw = json.loads(cfg_path.read_text())
    driver = _pick(raw, ALIASES["driver"]) or DEFAULT_DRIVER
    host = _pick(raw, ALIASES["host"])
    uid = _pick(raw, ALIASES["uid"])
    pwd = _pick(raw, ALIASES["pwd"])
    database = _pick(raw, ALIASES["database"])
    port = _pick(raw, ALIASES["port"])
    if port and "," not in str(host) and "\\" not in str(host):
        host = f"{host},{port}"

    missing = [n for n, v in (("host", host), ("uid", uid), ("pwd", pwd)) if not v]
    if missing:
        raise SystemExit(f"{cfg_path} is missing: {', '.join(missing)}")

    print(f"Config: {cfg_path}")
    print(f"Driver: {driver}")
    print(f"Server: {host}")
    print(f"Login : {uid}   (password length: {len(str(pwd))} chars)")
    print(f"Database in config: {database!r}\n")
    print("Connection attempts (password never shown):")

    db_ok = _attempt(
        f"DATABASE={database}", _build(driver, host, uid, pwd, database)
    ) if database else None
    master_ok = _attempt("DATABASE=master", _build(driver, host, uid, pwd, "master"))
    nodb_ok = _attempt("no DATABASE (server default)", _build(driver, host, uid, pwd, None))

    # If a server-level login works, list databases to confirm the real name.
    db_present: Optional[bool] = None
    if master_ok or nodb_ok:
        names = _list_databases(_build(driver, host, uid, pwd, "master"))
        if names is not None:
            print(f"\nDatabases visible to {uid!r}:")
            for name in names:
                same = database and name.lower() == str(database).lower()
                print(f"  - {name}{'   <-- your configured database' if same else ''}")
            db_present = bool(database) and any(
                name.lower() == str(database).lower() for name in names
            )
            if database and not db_present:
                print(f"  NOTE: {database!r} is NOT in this list.")

    print("\nVerdict:")
    if not master_ok and not nodb_ok:
        print(
            "  The username/password is being rejected outright (login itself "
            "fails). Most likely a wrong/stale password in sql.json, or the "
            f"login {uid!r} is disabled or its password has expired.\n"
            "  -> Verify the password matches what SAS used (&trackp). Check for "
            "a stray trailing space or newline in the JSON value."
        )
    elif (master_ok or nodb_ok) and db_ok is False:
        wrong_name = db_present is False
        print(
            f"  The login {uid!r} is VALID (master/default connect succeeds) but "
            f"cannot open {database!r}. "
            + (
                "That database name is not even in the list above, so it is "
                "most likely the WRONG NAME — pick the correct one from the list."
                if wrong_name
                else "The name exists but this login lacks access to it — a DBA "
                "grant is needed."
            )
        )
    elif db_ok:
        print("  Connected to the configured database successfully. The "
              "credential and access are fine; re-run the dashboard.")
    else:
        print("  Mixed/unclear result; see the per-attempt lines above.")

    print(
        "\nFor the definitive cause, a DBA can read the 18456 State in the SQL "
        "Server error log (8=bad password, 5=no such login, 38=cannot open db, "
        "18=password must change, 1=disabled/locked)."
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
