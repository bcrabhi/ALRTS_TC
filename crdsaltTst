# ── Config helpers ───────────────────────────────────────────────────────────

def cfg(job_conf, key: str, default, logger: logging.Logger = None):
    """Read `key` from the flat YAML job_conf dict, falling back to `default`.

    job_conf is the load_config() output — a flat dict keyed exactly as the YAML
    (trino_host, trino_catalog, S3_BUCKET, ...). Missing/empty -> default, logged
    at DEBUG (not WARNING) since falling back to a PROD constant is expected, not
    alarming.
    """
    val = None
    if job_conf is not None:
        try:
            val = job_conf.get(key) if hasattr(job_conf, "get") else getattr(job_conf, key, None)
        except Exception:  # noqa: BLE001 — config read must never break the job
            val = None
    if val is None or val == "":
        if logger:
            logger.debug("Config key '%s' absent; using default: %s", key, default)
        return default
    return val


def parse_s3_uri(uri: str, default_bucket: str, default_prefix: str):

    if not uri:
        return default_bucket, default_prefix
    stripped = uri
    for scheme in ("s3a://", "s3n://", "s3://"):
        if stripped.startswith(scheme):
            stripped = stripped[len(scheme):]
            break
    parts = stripped.strip("/").split("/", 1)
    bucket = parts[0] if parts and parts[0] else default_bucket
    prefix = parts[1] if len(parts) > 1 and parts[1] else default_prefix
    return bucket, prefix


# ── Logging ──────────────────────────────────────────────────────────────────

def setup_logging(log_path: Path) -> logging.Logger:
    """Configure file + console logging."""
    log_path.parent.mkdir(parents=True, exist_ok=True)
    logger = logging.getLogger("C86_CardsSample")
    logger.setLevel(logging.INFO)
    if not logger.handlers:
        fh = logging.FileHandler(log_path)
        ch = logging.StreamHandler(sys.stdout)
        fmt = logging.Formatter("%(asctime)s [%(levelname)s] - %(message)s",
                                datefmt="%Y-%m-%d %H:%M:%S")
        fh.setFormatter(fmt)
        ch.setFormatter(fmt)
        logger.addHandler(fh)
        logger.addHandler(ch)
    return logger


# ── Credentials (read from env; vault.secrets.env already loaded by main.py) ──

def get_credentials(logger: logging.Logger) -> dict:
    """Resolve credentials from the environment. The vault init container writes
    vault.secrets.env and main.py loads it via load_dotenv() before this runs,
    so the values are already in os.environ here."""
    required = {
        "trino_user": "TRINO_USERNAME",
        "trino_pass": "TRINO_PASSWORD",
    }
    required_multi = {
        "s3_access_key": ("RYU0_S3_ACCESS_KEY_ID", "AWS_ACCESS_KEY_ID"),
        "s3_secret_key": ("RYU0_S3_SECRET_ACCESS_KEY", "AWS_SECRET_ACCESS_KEY"),
    }

    resolved: dict = {}
    missing = []
    for key, env_name in required.items():
        val = os.environ.get(env_name)
        if not val:
            missing.append(env_name)
        resolved[key] = val

    for key, env_names in required_multi.items():
        val = next((os.environ[n] for n in env_names if os.environ.get(n)), None)
        if not val:
            missing.append(" or ".join(env_names))
        resolved[key] = val

    if missing:
        raise RuntimeError(
            "Missing required credential env var(s): "
            + ", ".join(missing)
            + ". Vault init container may not have written vault.secrets.env, "
            "or ocp_secret_mapping.yaml is mismapped."
        )

    logger.info(
        "Credentials resolved: user=%s pass=%s s3_access=%s s3_secret=%s "
        "(trino_host comes from config, injected later)",
        "SET" if resolved["trino_user"] else "MISSING",
        "SET" if resolved["trino_pass"] else "MISSING",
        "SET" if resolved["s3_access_key"] else "MISSING",
        "SET" if resolved["s3_secret_key"] else "MISSING",
    )
    return resolved


# ── Date logic (from original) ───────────────────────────────────────────────

def compute_dates(today: Optional[date] = None) -> dict:
    if not today:
        today = date.today()

    start_dt_ini = date(2022, 6, 30)
    week_end_dt_ini = date(2022, 7, 25)

    weekday = today.weekday()
    days_since_friday = (weekday - 4) % 7
    week_start_friday = today - timedelta(days=days_since_friday)
    end_dt = week_start_friday - timedelta(days=2)

    if end_dt < week_end_dt_ini:
        start_dt = start_dt_ini
    else:
        start_dt = end_dt - timedelta(days=6)

    return {
        "report_dt": today,
        "week_start_dt": start_dt,
        "week_end_dt": end_dt,
        "week_end_dt_p1": end_dt + timedelta(days=1),
        "pardt": start_dt - timedelta(days=7),
        "label": today.strftime("%Y%m%d"),
    }


# ── SQL helpers (from original) ──────────────────────────────────────────────

def _SAFE_TS(expr: str) -> str:
    return f"""
    TRY(
      CAST(
        from_iso8601_timestamp(
          regexp_replace(
            regexp_replace({expr}, ' ', 'T'),
            'Z$', '+00:00'
          )
        ) AS timestamp
      )
    )
    """.strip()


ESS_PROCESS_TS = _SAFE_TS("element_at(eventAttributes, 'ess_process_timestamp')")
ESS_SRC_TS = _SAFE_TS("element_at(eventAttributes, 'ess_src_event_timestamp')")
SRC_HDR = "TRY(json_parse(element_at(eventAttributes, 'SourceEventHeader')))"
EVT_PAYLOAD = "TRY(json_parse(element_at(eventAttributes, 'eventPayload')))"
EVT_ID = f"TRY(json_extract_scalar({SRC_HDR}, '$.eventId'))"
EVT_TS = _SAFE_TS(f"json_extract_scalar({SRC_HDR}, '$.eventTimestamp')")


def q_xb80_cards(schema: str, week_start: date, week_end_p1: date, pardt: date) -> str:
    """Query 1: xb80 cards events (triple-underscore table name is quoted)."""
    return f"""
    WITH cards AS (
     SELECT
       event_activity_type,
       source_event_id,
       partition_date,
       TRY(date_parse(partition_date, '%Y%m%d')) AS partition_date_parsed,
       {ESS_PROCESS_TS} AS ess_process_timestamp,
       {ESS_SRC_TS}    AS ess_src_event_timestamp,
       {EVT_ID}        AS eventId,
       {EVT_TS}        AS eventTimestamp,
       {EVT_PAYLOAD}   AS eventPayload
     FROM {schema}."xb80___credit_card_system_interface"
    )
    SELECT
      event_activity_type,
      source_event_id,
      partition_date,
      ess_process_timestamp,
      ess_src_event_timestamp,
      eventId,
      eventTimestamp,
      TRY(json_extract_scalar(eventPayload, '$.accountId'))      AS accountId,
      TRY(json_extract_scalar(eventPayload, '$.alertType'))      AS alertType,
      TRY(CAST(json_extract_scalar(eventPayload, '$.thresholdAmount') AS DECIMAL(12,2))) AS thresholdAmount,
      TRY(json_extract_scalar(eventPayload, '$.customerID'))     AS customerID,
      TRY(json_extract_scalar(eventPayload, '$.accountCurrency')) AS accountCurrency,
      TRY(CAST(json_extract_scalar(eventPayload, '$.creditLimit') AS DECIMAL(12,2)))     AS creditLimit,
      TRY(json_extract_scalar(eventPayload, '$.maskedAccount'))  AS maskedAccount,
      TRY(json_extract_scalar(eventPayload, '$.decisionId'))     AS decisionId,
      TRY(CAST(json_extract_scalar(eventPayload, '$.alertAmount') AS DECIMAL(12,2)))     AS alertAmount
    FROM cards
    WHERE
      partition_date_parsed > DATE '{pardt.isoformat()}'
      AND event_activity_type = 'Alert Decision Cards'
      AND TRY(json_extract_scalar(eventPayload, '$.alertType')) = 'AVAIL_CREDIT_REMAINING'
      AND {_SAFE_TS("CAST(eventTimestamp AS varchar)")}
        BETWEEN TIMESTAMP '{week_start.isoformat()} 00:00:00'
          AND TIMESTAMP '{week_end_p1.isoformat()} 00:00:00'
    """


# ── Trino ────────────────────────────────────────────────────────────────────

def get_trino_connection(creds: dict, logger: logging.Logger,
                         catalog: str = TRINO_CATALOG, db_schema: str = TRINO_SCHEMA,
                         source: str = TRINO_SOURCE):
    auth = BasicAuthentication(creds["trino_user"], creds["trino_pass"]) if creds["trino_pass"] else None
    logger.info("Connecting to Trino: host=%s user=%s", creds["trino_host"], creds["trino_user"])
    return trino.dbapi.connect(
        host=creds["trino_host"],
        port=TRINO_PORT,
        user=creds["trino_user"],
        http_scheme="https",
        auth=auth,
        catalog=catalog,
        schema=db_schema,
        source=source,
    )


def read_full_df(conn, sql: str, logger: logging.Logger, chunksize: int = READ_CHUNKSIZE) -> pd.DataFrame:
    """Full read of the query result, streamed in chunks and concatenated."""
    logger.info("Running query 1 (q_xb80_cards), full read...")
    chunks = pd.read_sql(sql, conn, chunksize=chunksize)
    df = pd.concat(chunks, ignore_index=True)
    logger.info("Full read complete: %d rows, %d cols", len(df), df.shape[1])
    return df


# ── S3 ───────────────────────────────────────────────────────────────────────

def get_s3_client(creds: dict, endpoint: str = S3_ENDPOINT):
    return boto3.client(
        "s3",
        endpoint_url=endpoint,
        aws_access_key_id=creds["s3_access_key"],
        aws_secret_access_key=creds["s3_secret_key"],
        config=BotoConfig(signature_version="s3v4", retries={"max_attempts": 3}),
    )


def upload_file_to_s3(creds: dict, local_path: str, s3_key: str, logger: logging.Logger,
                      bucket: str = S3_BUCKET, endpoint: str = S3_ENDPOINT) -> str:
    s3 = get_s3_client(creds, endpoint=endpoint)
    s3.upload_file(local_path, bucket, s3_key)
    uri = f"s3://{bucket}/{s3_key}"
    logger.info("Uploaded to %s", uri)
    return uri


# ── Tyr/Helios entry point ───────────────────────────────────────────────────

def process_C86_alerts_cards(ss, job_conf):
    """Tyr/Helios job entry point.

    Args:
        ss: SparkSession injected by the framework. Unused by this job (Trino
            read + boto3 write), but kept to match the dispatcher signature.
        job_conf: Job configuration passed through by the framework. Credentials
            are read from the environment (vault init container + main.py
            load_dotenv), not from job_conf.

    Raises:
        On any failure (credentials, Trino read, Excel write, S3 upload). Raising
        rather than returning a code is deliberate: the framework's main.py does
        not inspect the return value, so a returned 1 was being reported as
        SUCCESS. An uncaught exception produces a real FAILURE / non-zero exit.
    """
    log_file = Path(LOCAL_LOG_DIR) / f"C86_Alerts_Cards_{date.today():%Y%m%d}.log"
    logger = setup_logging(log_file)

    logger.info("=" * 70)
    logger.info("C86 Alerts Cards — Query 1 sample -> Excel -> S3")
    logger.info("Start: %s", datetime.now().isoformat())
    logger.info("Vault env loaded from: %s", _vault_loaded)
    logger.info("Spark master: %s", getattr(getattr(ss, "sparkContext", None), "master", "n/a"))
    logger.info("=" * 70)

    # Resolve credentials from environment (vault.secrets.env loaded at import).
    # get_credentials raises on a miss; we log and re-raise so the framework
    # records a FAILURE rather than swallowing it into a return code.
    try:
        creds = get_credentials(logger)
    except Exception:
        logger.exception("Credential resolution FAILED — aborting job.")
        raise

    # Resolve config from job_conf (flat YAML dict), falling back to PROD
    # constants. Keys match the c86-alerts-cards: section of the config file.
    trino_host = cfg(job_conf, "trino_host", TRINO_HOST, logger)
    catalog = cfg(job_conf, "trino_catalog", TRINO_CATALOG, logger)
    db_schema = cfg(job_conf, "trino_schema", TRINO_SCHEMA, logger)
    trino_source = cfg(job_conf, "trino_source", TRINO_SOURCE, logger)
    s3_endpoint = cfg(job_conf, "S3_ENDPOINT", S3_ENDPOINT, logger)
    out_root = cfg(job_conf, "local_output_path", LOCAL_OUT_DIR, logger)

    # S3 bucket+prefix: single source of truth is the s3_output_folder URI in
    # config (e.g. s3a://ryu0-s3-sas-migration/output/c86_alerts_cards/dev).
    # Parse it into bucket + prefix for boto3 (which rejects a scheme in the key).
    s3_output_folder = cfg(job_conf, "s3_output_folder", "", logger)
    s3_bucket, s3_prefix = parse_s3_uri(
        s3_output_folder,
        default_bucket=cfg(job_conf, "S3_BUCKET", S3_BUCKET, logger),
        default_prefix=S3_OUTPUT_PREFIX,
    )

    # Trino host comes from config (it is a hostname, not a secret). Only
    # username/password come from vault. Inject the host into creds here.
    creds["trino_host"] = trino_host

    dt = compute_dates()
    label = dt["label"]
    schema = f"{catalog}.{db_schema}"
    logger.info("Trino host=%s catalog=%s schema=%s source=%s",
                trino_host, catalog, db_schema, trino_source)
    logger.info("S3 endpoint=%s bucket=%s prefix=%s", s3_endpoint, s3_bucket, s3_prefix)
    logger.info("Local out=%s", out_root)
    logger.info("Week window: %s to %s | label=%s",
                dt["week_start_dt"], dt["week_end_dt"], label)

    # 1. Run query 1, full read.
    try:
        with get_trino_connection(creds, logger, catalog=catalog, db_schema=db_schema,
                                  source=trino_source) as conn:
            sql = q_xb80_cards(schema, dt["week_start_dt"], dt["week_end_dt_p1"], dt["pardt"])
            df_cards = read_full_df(conn, sql, logger)
    except Exception:
        logger.exception("Trino read FAILED — aborting job.")
        raise

    if df_cards.empty:
        logger.warning("Query returned 0 rows — nothing to sample. Writing an empty file anyway.")

    # 2. Trim to first N rows in pandas.
    df_sample = df_cards.head(SAMPLE_ROWS).copy()
    logger.info("Sampled first %d rows (got %d).", SAMPLE_ROWS, len(df_sample))

    # 3. Write the sample to a local .xlsx.
    out_dir = Path(out_root) / label
    out_dir.mkdir(parents=True, exist_ok=True)
    filename = f"cards_query1_sample_{label}.xlsx"
    local_path = out_dir / filename
    try:
        df_sample.to_excel(local_path, sheet_name="cards_sample", index=False)
        logger.info("Wrote local Excel: %s (%d rows)", local_path, len(df_sample))
    except Exception:
        logger.exception("Excel write FAILED — aborting job.")
        raise

    # 4. Upload to S3.
    try:
        s3_key = f"{s3_prefix}/{label}/{filename}"
        uri = upload_file_to_s3(creds, str(local_path), s3_key, logger,
                                bucket=s3_bucket, endpoint=s3_endpoint)
    except (BotoCoreError, ClientError):
        logger.exception("S3 upload FAILED (boto) — aborting job.")
        raise
    except Exception:
        logger.exception("S3 upload FAILED — aborting job.")
        raise

    logger.info("=" * 70)
    logger.info("DONE — sample written and uploaded.")
    logger.info("  rows written : %d", len(df_sample))
    logger.info("  local file   : %s", local_path)
    logger.info("  s3 uri       : %s", uri)
    logger.info("=" * 70)
    # Success is "ran without raising" — no return code for the framework to
    # misread. Any failure above raises and the task is marked FAILED.


