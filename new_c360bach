# (Separate notebook cell — loads autocomplete Excel into SQL Server staging)
# =============================================================================

def load_to_sql_server():
    """
    Reads the autocomplete Excel file and bulk-inserts into
    STG_REG_AUTOCOMPLETE_C86 on SQL Server via pyodbc.
    """
    import pyodbc

    SQL_TABLE       = "STG_REG_AUTOCOMPLETE_C86"
    identity_column = 'RowID'
    excel_path      = r"sas/RSD/REG_DEV/C86/output/product_appropriateness/client360/pa_client360_autocomplete.xlsx"

    try:
        with log_step(logger, "SQL Server load - STG_REG_AUTOCOMPLETE_C86 - read config"):
            with open(r'sql.json', "r") as f:
                secrets = json.load(f)

            SQL_SERVER   = secrets["SQL_SERVER"]
            SQL_DATABASE = secrets["SQL_DATABASE"]
            UID          = secrets["SQL_UID"]
            PWD          = secrets["SQL_PWD"]

            conn_str = (
                f'DRIVER={{ODBC Driver 17 for SQL Server}};'
                f'SERVER={SQL_SERVER};'
                f'DATABASE={SQL_DATABASE};'
                f'UID={UID};'
                f'PWD={PWD};'
                f'TrustServiceCertificate=Yes;'
                f'Connection Timeout=10;'
            )

        with log_step(logger, "SQL Server load - discover target schema"):
            conn_probe   = pyodbc.connect(conn_str)
            cursor_probe = conn_probe.cursor()
            cursor_probe.execute(
                f"SELECT TOP 1 * FROM {SQL_DATABASE}.dbo.{SQL_TABLE}"
            )
            expected_columns_raw = [col[0] for col in cursor_probe.description]
            expected_columns     = [col[0] for col in cursor_probe.description]
            cursor_probe.close()
            conn_probe.close()

            if identity_column in expected_columns:
                expected_columns.remove(identity_column)
            if identity_column in expected_columns_raw:
                expected_columns_raw.remove(identity_column)

            logger.info("Target columns (excl. identity): %s", expected_columns_raw)

        with log_step(logger, "SQL Server load - read and prepare Excel"):
            if not os.path.exists(excel_path):
                log_error(logger, f"File not found: {excel_path}")
                return

            df = pd.read_excel(excel_path)
            log_dataset(logger, "autocomplete_excel_raw", df)

            column_rename_map = {
                'ControlRisk': 'Control Risk',
                'segment':     'Segment',
                'segment2':    'Segment2',
                'segment3':    'Segment3',
                'segment4':    'Segment4',
                'segment5':    'Segment5',
                'segment6':    'Segment6',
                'segment7':    'Segment7',
                'segment8':    'Segment8',
                'segment9':    'Segment9',
                'segment10':   'Segment10',
                'segment11':   'Segment11',
                'segment12':   'Segment12',
                'segment13':   'Segment13',
                'segment14':   'Segment14',
                'segment15':   'Segment15',
                'segment16':   'Segment16',
                'segment17':   'Segment17',
                'segment18':   'Segment18',
                'segment19':   'Segment19',
                'segment20':   'Segment20',
                'Commentcode': 'CommentCode',
                'Comments':    'comments',
            }
            df.rename(columns=column_rename_map, inplace=True)

            if 'Amount' in df.columns:
                df['Amount']        = pd.to_numeric(df['Amount'], errors='coerce')
                df['Volume']        = pd.to_numeric(df['Volume'], errors='coerce')
                df['DateCompleted'] = pd.to_datetime(df['DateCompleted'], errors='coerce')
                df['SnapDate']      = pd.to_datetime(df['SnapDate'], errors='coerce')

            # Ensure all expected columns present; reorder to match DDL
            for col in expected_columns:
                if col not in df.columns:
                    df[col] = np.nan
            df = df[expected_columns]

            # Clean empty strings / NaN → None for pyodbc
            df = df.map(lambda x: None if pd.isna(x) or str(x).strip() == '' else x)

            # Truncate Segment3 to 99 chars
            df['Segment3'] = df['Segment3'].astype(str).str.slice(0, 99)
            df['Segment3'] = df['Segment3'].replace({'nan': None, 'NaT': None})

            records = df.where(pd.notnull(df), None).values.tolist()
            log_dataset(logger, "autocomplete_ready_for_insert", df)

        with log_step(logger, "SQL Server load - bulk insert"):
            placeholders = ', '.join(['?'] * len(expected_columns_raw))
            columns_str  = ', '.join([f'[{col}]' for col in expected_columns_raw])
            insert_sql   = (
                f"INSERT INTO dbo.{SQL_TABLE} ({columns_str}) "
                f"VALUES ({placeholders})"
            )

            conn = pyodbc.connect(conn_str)
            try:
                log_insert(logger, SQL_TABLE, insert_sql, records, conn,
                           source="SQL Server", database=SQL_DATABASE)
            finally:
                conn.close()
                logger.info("SQL Server connection closed.")

    except Exception as e:
        log_exception(logger, e, note="load_to_sql_server")


