def make_autosum(df, cntl_flag, cob_num, qa_format, cmt_format, ctrk_format, DE_I_format):
    """Creates summary statistics for one control flag."""
    parts = cntl_flag.split("_")
    control_type = parts[0]
    de_name = "_".join(parts[1:])
    control_risk = ctrk_format.get(control_type, control_type)

    if parts[1] == "Num":
        test_type = "Distribution"
    elif control_type == "Time":
        test_type = "Reconciliation"
    else:
        test_type = "Anomaly"

    rde = f"{cob_num}_{DE_I_format.get(de_name, de_name)}"

    df_copy = df.copy()
    df_copy["CommentCode"] = df_copy[cntl_flag].apply(lambda v: apply_qa_format(v, qa_format)) if cntl_flag in df_copy.columns else "COM18"
    df_copy["Comments"] = df_copy["CommentCode"].map(cmt_format)

    if "_Num_" in cntl_flag:
        df_copy["Segment"] = df_copy[cntl_flag].apply(lambda x: "NA" if pd.isna(x) else str(int(x)))
        df_copy["CommentCode"] = "COM12"
        df_copy["Comments"] = cmt_format.get("COM12", "")
    else:
        df_copy["Segment"] = ""

    if "_Accuracy_RDE" in cntl_flag:
        df_copy["CommentCode"] = np.where(df_copy["CommentCode"] == "COM11", "COM18", df_copy["CommentCode"])
        df_copy["Comments"] = df_copy["CommentCode"].map(cmt_format)

    group_cols = [
        "RegulatoryName", "LOB", "ReportName", "TestPeriod", "ProductType",
        "upstreamEventIds", "Segment3", "Segment4", "Segment5", "Segment6", "Segment7",
        "DateCompleted", "SnapDate", "Segment", "CommentCode", "Comments",
    ]
    available_cols = [c for c in group_cols if c in df_copy.columns]

    summary = df_copy.groupby(available_cols, dropna=False).agg(
        Volume=("xid", "size"), Bal=("rpt_bal", "sum"),
    ).reset_index()

    summary["ControlRisk"] = control_risk
    summary["TestType"] = test_type
    summary["RDE"] = rde
    summary["HoldoutFlag"] = "N"
    summary["Segment2"] = summary.get("upstreamEventIds", "")

    return summary


