    df["clientNumber"] = df["srfnumber_q"]
    df["eventID"] = df["eventID_q"]
    df["productID"] = df["productID_q"]
    df["segmentNumber"] = df["segmentNumber_q"]
    df["srfnumber"] = df["srfnumber_q"]
    df["transactionID"] = df["transactionID_q"]
    df["transitNumber"] = df["transitNumber_q"]

    df["RegulatoryName"] = "COB"
    df["LOB"] = "PL"
    df["ReportName"] = "COB CASPER Report"
    df["TestPeriod"] = "Origination"
    df["ProductType"] = "Loans"
    df["Segment3"] = df["Application_Type"]
    df["Segment4"] = ""
    df["Segment7"] = "4946,S4946"

    df["eventDate"] = pd.to_datetime(df["eventDate"])
    df["SnapDate"] = df["eventDate"].apply(lambda x: get_next_weekday(x, "fri"))
    df["DateCompleted"] = pd.to_datetime(runday, errors="raise").date()

    logging.info(f"Final output: {len(df)} rows")
    return df


def expand_to_borrower_level(df: pd.DataFrame) -> pd.DataFrame:
    """Expand to borrower level (one row per SRF number)."""
    logging.info("Step 13: Expanding to borrower level...")
    expanded_rows = []

    for idx, row in df.iterrows():
        srfnumbers = str(row.get("srfnumber_q", "")).split(";")
        clientNames = str(row.get("clientName_q", "")).split(";")

        for k, (srf, name) in enumerate(zip(srfnumbers, clientNames)):
            if not srf or srf == "nan":
                break
            new_row = row.copy()
            new_row["srfnumber9"] = srf
            new_row["ClientName9"] = name
            new_row["clientNumber_mask"] = "_NA_" if srf == "_NA_" else "******" + srf[-3:]
            new_row["Segment5"] = "P" if k == 0 else "A"
            new_row["Segment6"] = "M" if k == 0 else "S"
            expanded_rows.append(new_row)

    result = pd.DataFrame(expanded_rows)
    logging.info(f"Expanded to borrower level: {len(result)} rows")
    return result


