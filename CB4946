def add_srf_indicators(df: pd.DataFrame) -> pd.DataFrame:
    """Add no_srfs_ind and no_nams_ind indicators via in-memory SQLite."""
    logging.info("Step 5: Adding SRF/NAM indicators...")
    conn_sql = sqlite3.connect(":memory:")
    try:
        df.to_sql("tmp1", conn_sql, index=False, if_exists="replace")
        query = """
        SELECT dta.*, srf.no_srfs_ind, srf.no_nams_ind
        FROM tmp1 AS dta
        LEFT JOIN (
            SELECT eventID,
                   COUNT(*) AS count,
                   SUM(CASE WHEN srfnumber IS NULL OR TRIM(srfnumber) = '' THEN 1 ELSE 0 END) AS no_srfs_ind,
                   SUM(CASE WHEN clientName IS NULL OR TRIM(clientName) = '' THEN 1 ELSE 0 END) AS no_nams_ind
            FROM tmp1
            GROUP BY eventID
        ) AS srf ON srf.eventID = dta.eventID
        """
        df2 = pd.read_sql_query(query, conn_sql)
    finally:
        conn_sql.close()
    logging.info(f"SRF indicators added: {len(df2)} rows")
    return df2


def process_population_data(df: pd.DataFrame) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Create dta_4946s — process population, mask PII, split valid/invalid."""
    logging.info("Step 6: Processing population data...")
    df = df.copy()

    df["Application_Type"] = df["applicationID"].apply(
        lambda x: "Native Open" if pd.to_numeric(x, errors="coerce") == 0 else "Origination"
    )
    df["srcSysCd"] = df["srcSysCd"].str.upper()
    df["srfnumber"] = df["srfnumber"].fillna("").str.replace(";", ",")
    df["clientName"] = df["clientName"].fillna("").str.replace(";", ",")
    df["srfnumber"] = df["srfnumber"].apply(lambda x: "_NA_" if x == "" else x)
    df["clientName"] = df["clientName"].apply(lambda x: "_NA_" if x == "" else x)
    df["srfnumber"] = df["srfnumber"].apply(lambda srf: srf if srf == "_NA_" else srf.zfill(27))
    df["srfnumber2"] = df["srfnumber"].apply(
        lambda x: "_NA_" if x == "_NA_" else "******" + x[-3:]
    )
    df["clientName2"] = df["clientName"].apply(
        lambda x: "_NA_" if x == "_NA_" else (x[0] + "*****" if len(x) > 0 else "_NA_")
    )

    if "statementDate" in df.columns:
        df["statementDate"] = pd.to_datetime(df["statementDate"]).dt.date

    df["xid"] = df["applicationID"].astype(str) + "+" + df["productID"].astype(str)

    dta_4946s = df[df["applicationID"] != "99999999999"].copy()
    dta_4946s9s = df[df["applicationID"] == "99999999999"].copy()

    logging.info(f"Valid: {len(dta_4946s)} rows, Invalid (9s): {len(dta_4946s9s)} rows")
    return dta_4946s, dta_4946s9s


