def aggregate_by_event(df: pd.DataFrame) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    """Aggregate by eventID — concatenate srfnumber and clientName."""
    logging.info("Step 7: Aggregating by eventID...")
    df = df.sort_values(["eventID", "srfnumber", "clientName"])

    agg_funcs = {
        col: "last" for col in df.columns
        if col not in ["srfnumber", "srfnumber2", "clientName", "clientName2"]
    }
    grouped = df.groupby("eventID", as_index=False).agg({
        **agg_funcs,
        "srfnumber": lambda x: ";".join(x.astype(str)),
        "srfnumber2": lambda x: ";".join(x.astype(str)),
        "clientName": lambda x: ";".join(x.astype(str)),
        "clientName2": lambda x: ";".join(x.astype(str)),
    })
    grouped["n_srfs"] = df.groupby("eventID").size().values

    dta_4946a_a = grouped.copy()
    dta_4946a_q = grouped[grouped["srcSysCd"] == "CASPER_QUADIENT"].copy()
    dta_4946a_h = grouped[grouped["srcSysCd"] == "CASPER_HOST"].copy()

    logging.info(f"Aggregated — All: {len(dta_4946a_a)}, Quadient: {len(dta_4946a_q)}, Host: {len(dta_4946a_h)}")
    return dta_4946a_a, dta_4946a_q, dta_4946a_h


def get_latest_events(df_q: pd.DataFrame, df_h: pd.DataFrame) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Get latest Quadient and Host events per xid."""
    logging.info("Step 8: Getting latest events per xid...")
    if len(df_q) > 0:
        df_q = df_q.sort_values(["xid", "docGeneratedDateTimeStamp", "eventID"], ascending=[True, False, True])
        df_q = df_q.drop_duplicates(subset="xid", keep="first")
    if len(df_h) > 0:
        df_h = df_h.sort_values(["xid", "eventTimestamp", "eventID"], ascending=[True, False, True])
        df_h = df_h.drop_duplicates(subset="xid", keep="first")
    logging.info(f"Latest events — Quadient: {len(df_q)}, Host: {len(df_h)}")
    return df_q, df_h


def merge_quadient_host(df_q: pd.DataFrame, df_h: pd.DataFrame,
                        all_vars: List[str]) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Merge Quadient and Host data on xid."""
    logging.info("Step 9: Merging Quadient and Host data...")
    cols_to_rename = [c for c in all_vars if c in df_q.columns]
    rename_q = {c: f"{c}_q" for c in cols_to_rename}
    rename_h = {c: f"{c}_h" for c in cols_to_rename}
    rename_q["srfnumber2"] = "srfnumber2_q"
    rename_q["clientName2"] = "clientName2_q"
    rename_h["srfnumber2"] = "srfnumber2_h"
    rename_h["clientName2"] = "clientName2_h"

    df_q_renamed = df_q.rename(columns=rename_q)
    df_h_renamed = df_h.rename(columns=rename_h)

    merged = df_q_renamed.merge(df_h_renamed, on="xid", how="outer", indicator=True)

    if "eventTimestamp_q" in merged.columns and "eventTimestamp_h" in merged.columns:
        merged["eventTimestamp_q"] = pd.to_datetime(merged["eventTimestamp_q"])
        merged["eventTimestamp_h"] = pd.to_datetime(merged["eventTimestamp_h"])
        merged["time_dif_o"] = (merged["eventTimestamp_q"] - merged["eventTimestamp_h"]).dt.total_seconds()
        merged["time_dif_a"] = merged["time_dif_o"].abs()

    dta_4946a_qh = merged[merged["_merge"] == "both"].drop(columns="_merge")
    dta_4946a_qh_nomap = merged[merged["_merge"] != "both"].drop(columns="_merge")

    logging.info(f"Merged: {len(dta_4946a_qh)}, No match: {len(dta_4946a_qh_nomap)}")
    return dta_4946a_qh, dta_4946a_qh_nomap


def get_closest_matches(df: pd.DataFrame) -> pd.DataFrame:
    """Keep closest time match per xid."""
    logging.info("Step 10: Getting closest matches...")
    if len(df) == 0:
        return df
    df = df.sort_values(["xid", "time_dif_a"])
    df = df.drop_duplicates(subset="xid", keep="first")
    logging.info(f"Closest matches: {len(df)}")
    return df


def perform_accuracy_checks(df: pd.DataFrame) -> pd.DataFrame:
    """All accuracy checks — preserved exactly from original."""
    logging.info("Step 11: Performing accuracy checks...")
    df = df.copy()

    # Annual Interest Rate (AccuC_annualRt)
    df["annualInterestRat2_h"] = np.where(
        df["interestRate_h"].notna() & df["primeRate_h"].notna(),
        np.round(df["interestRate_h"] + df["primeRate_h"], 7), np.nan,
    )
    df["annualInterestRate_d"] = np.where(
        df["interestRate_q"].notna() & df["annualInterestRat2_h"].notna(),
        np.round(
            (df["annualInterestRat2_h"] * 1000).astype(int) / 1000
            - (df["interestRate_q"] * 1000).astype(int) / 1000, 3
        ), np.nan,
    )
    df["AccuC_annualRt"] = np.select(
        [df["annualInterestRat2_h"].isna(), df["interestRate_q"].isna(),
         df["annualInterestRate_d"].abs() >= 0.001],
        [np.nan, 1, 1], default=0,
    )

    # Interest Rate (AccuM_interestRate)
    df["interestRate_d"] = np.where(
        df["interestRate_q"].notna() & df["annualInterestRate_h"].notna(),
        np.round(df["annualInterestRate_h"] - df["interestRate_q"], 7), np.nan,
    )
    df["AccuM_interestRate"] = np.select(
        [df["annualInterestRate_h"].isna(), df["interestRate_q"].isna(),
         df["interestRate_d"].abs() >= 1e-6],
        [np.nan, 1, 1], default=0,
    )

    # Prime Rate (AccuM_primeRate)
    df["primeRate_d"] = np.where(
        df["primeRate_q"].notna() & df["primeRate_h"].notna(),
        np.round(df["primeRate_h"] - df["primeRate_q"], 7), np.nan,
    )
    df["AccuM_primeRate"] = np.select(
        [df["primeRate_h"].isna(), df["primeRate_q"].isna(),
         df["primeRate_d"].abs() >= 1e-6],
        [np.nan, 1, 1], default=0,
    )

    # Statement Date (AccuM_statementDate)
    df["statementDate_q"] = pd.to_datetime(df["statementDate_q"], errors="coerce")
    df["statementDate_h"] = pd.to_datetime(df["statementDate_h"], errors="coerce")
    df["statementDate_d"] = (df["statementDate_h"] - df["statementDate_q"]).dt.days
    df["AccuM_statementDate"] = np.select(
        [df["statementDate_h"].isna(), df["statementDate_q"].isna(),
         df["statementDate_d"].abs() >= 1],
        [np.nan, 1, 1], default=0,
    )

    # Payment Due Date (AccuM_paymentDueDate)
    df["paymentDueDate_q"] = pd.to_datetime(df["paymentDueDate_q"], errors="coerce")
    df["paymentDueDate_h"] = pd.to_datetime(df["paymentDueDate_h"], errors="coerce")
    df["paymentDueDate_d"] = (df["paymentDueDate_h"] - df["paymentDueDate_q"]).dt.days
    df["AccuM_paymentDueDate"] = np.select(
        [df["paymentDueDate_h"].isna(), df["paymentDueDate_q"].isna(),
         df["paymentDueDate_d"].abs() >= 1],
        [np.nan, 1, 1], default=0,
    )

    # Principal Amount (AccuM_prinAmt)
    df["principalAmount_d"] = np.where(
        df["principalAmount_h"].notna() & df["principalAmount_q"].notna(),
        np.round(df["principalAmount_h"] - df["principalAmount_q"], 2), np.nan,
    )
    df["AccuM_prinAmt"] = np.select(
        [df["principalAmount_h"].isna(), df["principalAmount_q"].isna(),
         df["principalAmount_d"].abs() >= 0.01],
        [np.nan, 1, 1], default=0,
    )

    # Account Number (AccuM_accountNumber)
    df["accountNumber_h"] = df["accountNumber_h"].astype(str).str.strip()
    df["accountNumber_q"] = df["accountNumber_q"].astype(str).str.strip()
    df["accountNumber_h0"] = df["accountNumber_h"].str.zfill(16)
    df["accountNumber_q0"] = df["accountNumber_q"].str.zfill(16)
    df["AccuM_accountNumber"] = np.select(
        [df["accountNumber_h"].isin(["", "nan", "None"]),
         df["accountNumber_q"].isin(["", "nan", "None"]),
         df["accountNumber_h0"] == df["accountNumber_q0"]],
        [np.nan, 1, 0], default=1,
    )

    # Transit Number (AccuM_transitNumber)
    df["transitNumber_h"] = df["transitNumber_h"].astype(str).str.strip()
    df["transitNumber_q"] = df["transitNumber_q"].astype(str).str.strip()
    df["transitNumber_h0"] = df["transitNumber_h"].str.zfill(5)
    df["transitNumber_q0"] = df["transitNumber_q"].str.zfill(5)
    df["AccuM_transitNumber"] = np.select(
        [df["transitNumber_h"].isin(["", "nan", "None"]),
         df["transitNumber_q"].isin(["", "nan", "None"]),
         df["transitNumber_h0"] == df["transitNumber_q0"]],
        [np.nan, 1, 0], default=1,
    )

    # Fee checks helper
    def check_fee(df, fee_name):
        h_col, q_col, d_col = f"{fee_name}_h", f"{fee_name}_q", f"{fee_name}_d"
        df[d_col] = np.where(
            df[h_col].notna() & df[q_col].notna(),
            np.round(df[h_col] - df[q_col], 2), np.nan,
        )
        return np.select(
            [df[h_col].isna(), df[q_col].isna(), df[d_col].abs() >= 0.01],
            [np.nan, 1, 1], default=0,
        )

    df["AccuM_chequeFee"] = check_fee(df, "chequeFee")

    # Processing Fee (special logic with scheduleAInd)
    df["scheduleAIn2_q"] = df["scheduleAInd_q"].str.upper().isin(["Y", "YES"])
    df["processingFee_d"] = np.where(
        df["processingFee_h"].notna() & df["processingFee_q"].notna(),
        np.round(df["processingFee_h"] - df["processingFee_q"], 2), np.nan,
    )
    df["AccuM_processingFee"] = np.where(
        ~df["scheduleAIn2_q"],
        np.where(df["processingFee_q"] == 0, 0, 1), np.nan,
    )

    df["AccuM_stopPaymentFee"] = check_fee(df, "stopPaymentFee")
    df["AccuM_documentFee"] = check_fee(df, "documentFee")

    logging.info(f"Accuracy checks completed: {len(df)} rows")
    return df


def create_final_output(df: pd.DataFrame, runday) -> pd.DataFrame:
    """Create final output dataset with aggregate failure counts."""
    logging.info("Step 12: Creating final output dataset...")
    df = df.copy()

    accu_m_cols = [c for c in df.columns if c.startswith("AccuM_") and not c.endswith("_Fail") and not c.endswith("_RDE")]
    accu_c_cols = [c for c in df.columns if c.startswith("AccuC_") and not c.endswith("_Fail") and not c.endswith("_RDE")]

    df["AccuM_Num_Of_Fail"] = df[accu_m_cols].replace(9, np.nan).sum(axis=1, skipna=True, min_count=1)
    df["AccuM_Accuracy_RDE"] = np.select(
        [df["AccuM_Num_Of_Fail"].isna(), df["AccuM_Num_Of_Fail"] == 0],
        [np.nan, 0], default=1,
    )
    df["AccuM_Num_Of_Fail"] = df[accu_m_cols].replace(9, np.nan).sum(axis=1, skipna=True)

    df["AccuC_Num_Of_Fail"] = df[accu_c_cols].replace(9, np.nan).sum(axis=1, skipna=True, min_count=1)
    df["AccuC_Accuracy_RDE"] = np.select(
        [df["AccuC_Num_Of_Fail"].isna(), df["AccuC_Num_Of_Fail"] == 0],
        [np.nan, 0], default=1,
    )
    df["AccuC_Num_Of_Fail"] = df[accu_c_cols].replace(9, np.nan).sum(axis=1, skipna=True)

    df["Accu_Num_Of_Fail"] = df["AccuM_Num_Of_Fail"] + df["AccuC_Num_Of_Fail"]
    df["Accu_Accuracy_RDE"] = np.maximum(df["AccuM_Accuracy_RDE"], df["AccuC_Accuracy_RDE"])

    # Set reporting fields
    df["rpt_bal"] = df["principalAmount_q"]
    df["eventDate"] = df["eventDate_q"]
    df["statementDate"] = df["statementDate_q"]
    df["Application_Type"] = df["Application_Type_q"]
