def check_add_missing_cols(df, required_cols, reorder=True):
    """Ensure required_cols all exist in df; add missing with NaN."""
    df = df.copy()
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        df[missing] = np.nan
        logging.info(f"Added missing columns with NaN: {missing}")
    if reorder:
        df = df.reindex(columns=required_cols)
    return df, missing


def check_required_notnull(df, required_cols, treat_empty_as_missing=True):
    """Check if required_cols contain nulls and report."""
    report = []
    for col in required_cols:
        if col not in df.columns:
            report.append({"column": col, "status": "MISSING_COLUMN",
                           "missing_count": None, "empty_count": None, "total_missing": None})
            continue
        missing_count = int(df[col].isna().sum())
        empty_count = 0
        if treat_empty_as_missing:
            empty_count = int((df[col].astype(str).str.strip() == "").sum())
        total_missing = missing_count + empty_count
        status = "OK" if total_missing == 0 else "MISSING"
        report.append({"column": col, "status": status, "missing_count": missing_count,
                        "empty_count": empty_count, "total_missing": total_missing})

    rep_df = pd.DataFrame(report)
    n_issues = int((rep_df["total_missing"] > 0).sum())
    logging.info(f"Non-null check: {n_issues} column(s) with issues\n{rep_df.to_string(index=False)}")
    return rep_df


