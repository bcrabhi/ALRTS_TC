def get_prev_weekday(ref_date, weekday_name: str) -> date:
    """
    Returns the most recent occurrence of `weekday_name` on or before `ref_date`.
    Replicates c_m.get_prev_weekday from the common module.
    """
    day_map = {"mon": 0, "tue": 1, "wed": 2, "thu": 3, "fri": 4, "sat": 5, "sun": 6}
    target = day_map[weekday_name.lower()[:3]]
    if isinstance(ref_date, datetime):
        ref_date = ref_date.date()
    days_back = (ref_date.weekday() - target) % 7
    if days_back == 0:
        days_back = 0  # include today if it matches
    return ref_date - timedelta(days=days_back)


def get_next_weekday(ref_date, weekday_name: str) -> date:
    """
    Returns the next occurrence of `weekday_name` on or after `ref_date`.
    Replicates c_m.get_next_weekday from the common module.
    """
    day_map = {"mon": 0, "tue": 1, "wed": 2, "thu": 3, "fri": 4, "sat": 5, "sun": 6}
    target = day_map[weekday_name.lower()[:3]]
    if isinstance(ref_date, datetime):
        ref_date = ref_date.date()
    if isinstance(ref_date, pd.Timestamp):
        ref_date = ref_date.date()
    days_fwd = (target - ref_date.weekday()) % 7
    return ref_date + timedelta(days=days_fwd)


def setup_date_parameters(sqlserver_engine, cfg: Config) -> Dict:
    """
    Replicates set_data_parameters().
    Running between Wednesday and Tuesday yields the same data extraction window.
    """
    runday = datetime.today()

    # Get last snapdate from database
    query = f"""
        SELECT max(t.snapDate) as snapDate
        FROM dbo.{cfg.sql_table} AS t
        WHERE t.segment7 LIKE '4946%'
    """
    try:
        loaded = pd.read_sql(query, sqlserver_engine)
        last_snap = pd.to_datetime(loaded["snapDate"]).dt.date.max()
        logging.info(f"Last snapDate from DB: {last_snap}")
    except Exception as e:
        logging.warning(f"Could not read last snapDate from DB: {e}. Treating as initial run.")
        last_snap = None

    ini_run = "Y"

    week_end = get_prev_weekday(runday, "wed") - timedelta(days=5)  # previous Friday
    prod_strt = week_end - timedelta(days=6)  # back to Saturday before

    if last_snap is None or pd.isna(last_snap):
        event_start = prod_strt
    else:
        event_start = prod_strt if ini_run == "Y" else last_snap + timedelta(days=1)

    evnt_strt = event_start.strftime("%Y-%m-%d")
    week_end_str = week_end.strftime("%Y-%m-%d")
    rundt = runday.strftime("%y%m%d")

    xbetween_start = f"'{evnt_strt} 00:00:00.000'"
    xbetween_end = f"'{week_end_str} 23:59:59.999'"
    xbetween = f"{xbetween_start} and {xbetween_end}"

    params = {
        "runday": runday,
        "last_snap": last_snap,
        "ini_run": ini_run,
        "week_end": week_end,
        "prod_strt": prod_strt,
        "event_start": event_start,
        "evnt_strt": evnt_strt,
        "week_end_str": week_end_str,
        "rundt": rundt,
        "xbetween_start": xbetween_start,
        "xbetween_end": xbetween_end,
        "xbetween": xbetween,
    }

    logging.info(f"Date parameters: evnt_strt={evnt_strt}, week_end={week_end_str}, "
                 f"ini_run={ini_run}, rundt={rundt}")
    logging.info(f"Data range between: {xbetween}")
    return params


