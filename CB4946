def get_cob_data(cob_engine, xbetween: str, database: str) -> pd.DataFrame:
    """Pulls raw COB data from the source database."""
    logging.info(f"Step 4: Pulling COB data from {database}...")

    sql_query = f"""
    SELECT  txn.formNumber
            ,app.applicationID
            ,txn.transactionID
            ,pr.productID
            ,app.srcSysCd
            ,el.upstreamEventIds
            ,app.statementDate
            ,txn.eventID
            ,pd.mortgageType
            ,txn.principalAmount
            ,pd.Term
            ,txn.dateOfAdvance
            ,txn.interestAdjustmentDate
            ,txn.applicationStatus
            ,pr.paymentAmount
            ,pd.paymentFrequency
            ,pd.amortizationPeriod
            ,pr.defaultInsurancePremium
            ,pr.defaultInsuranceTax
            ,pr.totalDefaultInsurance
            ,txn.availableAmount
            ,pd.maturityDate
            ,pr.balanceOwingMaturity
            ,pr.interestCostOverTerm
            ,pr.totalCOBTerm
            ,pr.totalPIPaymentsTerm
            ,pr.totalPaymentAmountMonthly
            ,pr.insuranceCostPerPayment
            ,pr.annualInterestRate
            ,pr.annualPercentageRate
            ,pr.interestRate
            ,pr.primeRate
            ,pr.rateReduction
            ,pr.clientPDPM
            ,pr.clientPDFactor
            ,pr.triggeringInterestRate
            ,pr.processingFee
            ,pr.documentFee
            ,pr.dischargeFee
            ,pr.ppsRegistrationFee
            ,pr.NSFChequeFee
            ,pr.stopPaymentFee
            ,pr.chequeFee
            ,pr.administrationFee
            ,pd.product
            ,pd.paymentDueDate
            ,aar.srfnumber
            ,aar.clientName
            ,aar.partnerType
            ,el.eventTimestamp
            ,CONVERT(date, el.eventTimestamp) as eventDate
            ,txn.docGeneratedDateTimeStamp
            ,txn.transitNumber
            ,txn.accountNumber
            ,txn.segmentNumber
            ,pd.scheduleAInd
            ,CASE WHEN aar.applicationID = '00000000000' THEN 'Native Open'
                  ELSE 'Origination' END as Application_Type
            ,pr.annualFee
            ,pr.collateralFee
            ,pr.loanPurposeCode
            ,pr.loanSubPurposeCode
            ,aar.clientEmploymentStatus
            ,aar.occupationCode
    FROM
        {database}.dbo.[Application]              as app,
        {database}.dbo.[Transaction]              as txn,
        {database}.dbo.[Pricing]                  as pr,
        {database}.dbo.[Payment_Details]           as pd,
        {database}.dbo.[Event_Log]                as el,
        {database}.dbo.[Application_Applicant_Rel] as aar
    WHERE
            app.eventID = txn.eventID
        and app.eventID = pr.eventID
        and app.eventID = pd.eventID
        and app.eventID = el.eventID
        and app.eventID = aar.eventID
        and (el.upstreamEventIds in ('RCLPBAgreementDigital'))
        and el.eventTimestamp between {xbetween}
        and app.srcSysCd in ('CASPER_Quadient', 'CASPER_Host')
    """

    dta_4946_0 = pd.read_sql(sql_query, cob_engine)
    logging.info(f"Loaded {len(dta_4946_0)} rows from COB source.")

    # Dispose engine if SQLAlchemy
    if hasattr(cob_engine, "dispose"):
        cob_engine.dispose()

    return dta_4946_0


