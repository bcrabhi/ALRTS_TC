def get_cob_connection(conn_file: Path):
    """
    Reads COB database connection details from JSON and returns a
    teradatasql or pyodbc connection depending on driver availability.
    JSON keys: server, database, user, password
    """
    if not conn_file.exists():
        logging.error(f"Connection file not found: {conn_file.resolve()}")
        raise FileNotFoundError(f"Connection file not found: {conn_file.resolve()}")

    with open(conn_file, "r", encoding="utf-8") as f:
        details = json.load(f)

    server = details["server"]
    database = details["database"]
    user = details["user"]
    password = details["password"]

    logging.info(f"Connecting to COB database: {server} / {database} as {user}...")

    conn_str = (
        "Driver={ODBC Driver 17 for SQL Server};"
        f"Server={server};"
        f"Database={database};"
        f"UID={user};PWD={password};"
    )

    if create_engine is not None:
        engine = create_engine(
            f"mssql+pyodbc:///?odbc_connect={quote_plus(conn_str)}",
            fast_executemany=True,
        )
        logging.info("COB connection created via SQLAlchemy engine.")
        return engine
    elif pyodbc is not None:
        conn = pyodbc.connect(conn_str)
        logging.info("COB connection created via pyodbc.")
        return conn
    else:
        raise RuntimeError("Neither SQLAlchemy+pyodbc nor pyodbc available.")


def get_sqlserver_engine(secrets_file: Path):
    """
    Creates a SQLAlchemy engine for the reporting SQL Server.
    JSON keys: server, database, user, password, table
    """
    if create_engine is None:
        raise RuntimeError("SQLAlchemy is required for SQL Server upload.")

    if not secrets_file.exists():
        logging.error(f"SQL secrets file not found: {secrets_file.resolve()}")
        raise FileNotFoundError(f"SQL secrets file not found: {secrets_file.resolve()}")

    with open(secrets_file, "r", encoding="utf-8") as f:
        secrets = json.load(f)

    server = secrets["server"]
    database = secrets["database"]
    uid = secrets["user"]
    pwd = secrets["password"]

    conn_str = (
        f"DRIVER={{ODBC Driver 17 for SQL Server}};"
        f"SERVER={server};"
        f"DATABASE={database};"
        f"UID={uid};"
        f"PWD={pwd};"
        f"TrustServiceCertificate=Yes;"
    )

    engine = create_engine(
        f"mssql+pyodbc:///?odbc_connect={quote_plus(conn_str)}",
        fast_executemany=True,
    )
    logging.info(f"SQL Server engine created: {server} / {database}")
    return engine


