def apply_qa_format(val, qa_format):
    if pd.isna(val):
        return qa_format.get(np.nan, qa_format.get("other", "COM18"))
    return qa_format.get(val, qa_format.get("other", "COM18"))


def apply_flag_format(val, flag_format):
    if pd.isna(val):
        return flag_format.get(np.nan, flag_format.get("other", "Not Applicable"))
    return flag_format.get(val, flag_format.get("other", "Not Applicable"))


