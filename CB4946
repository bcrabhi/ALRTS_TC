        ("AccuM_primeRate", "COB523"), ("AccuM_statementDate", "COB523"),
        ("AccuM_paymentDueDate", "COB523"), ("AccuM_prinAmt", "COB523"),
        ("AccuM_accountNumber", "COB523"), ("AccuM_transitNumber", "COB523"),
        ("AccuM_chequeFee", "COB523"), ("AccuM_processingFee", "COB523"),
        ("AccuM_stopPaymentFee", "COB523"), ("AccuM_documentFee", "COB523"),
        ("AccuM_Num_Of_Fail", "COB523"), ("AccuM_Accuracy_RDE", "COB523"),
        ("AccuC_Num_Of_Fail", "COB524"), ("AccuC_Accuracy_RDE", "COB524"),
        ("Accu_Num_Of_Fail", "COB522"), ("Accu_Accuracy_RDE", "COB522"),
    ]

    auto_summaries = []
    for flag_name, cob_num in autosum_flags:
        if flag_name in _4946_all_expanded.columns:
            summary = make_autosum(_4946_all_expanded, flag_name, cob_num,
                                   qa_format, cmt_format, ctrk_format, DE_I_format)
            if len(summary) > 0:
                auto_summaries.append(summary)

    if auto_summaries:
        autocomplete_all_new = pd.concat(auto_summaries, ignore_index=True)
    else:
        autocomplete_all_new = pd.DataFrame()
    logging.info(f"Autocomplete summary: {len(autocomplete_all_new)} rows")

    new_order = [
        "RegulatoryName", "LOB", "ReportName", "ControlRisk", "TestType", "TestPeriod",
        "ProductType", "RDE", "Segment", "Segment2", "Segment3", "Segment4", "Segment5",
        "Segment6", "Segment7", "Segment8", "Segment9", "segment10",
        "HoldoutFlag", "CommentCode", "Comments", "DateCompleted", "SnapDate", "Volume", "Bal",
    ]
    autocomplete_all_new = autocomplete_all_new.reindex(columns=new_order)

    # -------------------------------------------------------------------------
    # Step 16: Generate fail detail reports
    # -------------------------------------------------------------------------
    logging.info("Step 16: Generating fail detail reports...")
    detail_configs = [
        ("AccuC_annualRt", "annualInterestRate_q", "annualInterestRat2_h"),
        ("AccuM_interestRate", "interestRate_q", "annualInterestRate_h"),
        ("AccuM_primeRate", "primeRate_q", "primeRate_h"),
        ("AccuM_statementDate", "statementDate_q", "statementDate_h"),
        ("AccuM_paymentDueDate", "paymentDueDate_q", "paymentDueDate_h"),
        ("AccuM_prinAmt", "principalAmount_q", "principalAmount_h"),
        ("AccuM_chequeFee", "chequeFee_q", "chequeFee_h"),
        ("AccuM_processingFee", "processingFee_q", "processingFee_h"),
        ("AccuM_stopPaymentFee", "stopPaymentFee_q", "stopPaymentFee_h"),
        ("AccuM_documentFee", "documentFee_q", "documentFee_h"),
        ("AccuM_accountNumber", "accountNumber_q", "accountNumber_h"),
        ("AccuM_transitNumber", "transitNumber_q", "transitNumber_h"),
    ]

    detail_reports = []
    for rde_check, cob_col, cal_col in detail_configs:
        detail = make_detail(_4946_all_expanded, rde_check, cob_col, cal_col,
                             ctrk_format, DE_I_format, qa_format, cmt_format)
        detail_reports.append(detail)

    fail_det_all_4946 = pd.concat(detail_reports, ignore_index=True)
    logging.info(f"Fail detail: {len(fail_det_all_4946)} rows")

    # -------------------------------------------------------------------------
    # Step 17: Create final fail detail file
    # -------------------------------------------------------------------------
    logging.info("Step 17: Creating final fail detail file...")
    fd_cp = fail_det_all_4946.copy()
    fd_cp["loanNumber"] = fd_cp["segmentNumber"].apply(lambda x: str(x) if pd.notna(x) else np.nan)
    fd_cp["interestRate"] = fd_cp["interestRate_h"]
    fd_cp["primeRate"] = fd_cp["primeRate_h"]
    fd_cp["scheduleAInd"] = fd_cp["scheduleAInd_q"]

    grp_cols = [
        "RegulatoryName", "LOB", "ReportName", "ControlRisk", "TestPeriod", "ProductType",
        "DateCompleted", "COB_Date", "processingCenter", "transitNumber", "accountNumber",
        "loanNumber", "eventID", "upstreamEventIds", "clientNumber_mask", "Statement_Level",
        "Application_Type", "Event_Level", "Category", "FormNumber", "interestRate", "primeRate",
        "scheduleAInd", "statementDate", "applicationID", "transactionID", "productID",
    ]

    fd_cp_grp = fd_cp.groupby(grp_cols, dropna=False).agg(
        Failed_RDE=("RDE", "size"),
    ).reset_index()
    FailDetail = fd_cp.merge(fd_cp_grp, on=grp_cols, how="left")

    vars_oth1 = ["Failed_RDE"]
    vars_oth2 = ["RDE", "COB_Value", "Comparison_Value"]
    all_detail_vars = list(dict.fromkeys(grp_cols + vars_oth1 + vars_oth2))
    FailDetail = FailDetail.reindex(columns=all_detail_vars).sort_values(grp_cols + vars_oth2 + vars_oth1)
    logging.info(f"FailDetail: {len(FailDetail)} rows")

    # -------------------------------------------------------------------------
    # Step 18: Save output files locally and upload to S3
    # -------------------------------------------------------------------------
    logging.info("Step 18: Saving output files...")

    # Autocomplete Excel
    ac_excel_path = outpath / cfg.autocomplete_file
    autocomplete_all_new.to_excel(str(ac_excel_path), index=False)
    logging.info(f"Saved: {ac_excel_path} ({len(autocomplete_all_new)} rows)")

    s3_ac_excel = s3_path("output", "cob", "4946", cfg.autocomplete_file)
    upload_file_to_s3(spark, str(ac_excel_path), s3_ac_excel)

    # Autocomplete parquet to S3
    s3_ac_parquet = s3_path("output", "cob", "4946", cfg.persistent_ac_file)
    write_parquet_to_s3(spark, autocomplete_all_new, s3_ac_parquet)

    # Fail Detail Excel
    fd_excel_path = outpath / cfg.fail_detail_file
    FailDetail.to_excel(str(fd_excel_path), index=False)
    logging.info(f"Saved: {fd_excel_path} ({len(FailDetail)} rows)")

    s3_fd_excel = s3_path("output", "cob", "4946", cfg.fail_detail_file)
    upload_file_to_s3(spark, str(fd_excel_path), s3_fd_excel)

    # Fail Detail parquet to S3
    s3_fd_parquet = s3_path("output", "cob", "4946", "Fail_Detail_orig_4946.parquet")
    write_parquet_to_s3(spark, FailDetail, s3_fd_parquet)

    # Expanded borrower-level file
    expanded_filename = cfg.expanded_file_template.replace("{rundt}", rundt)
    exp_excel_path = dataout_path / expanded_filename
    _4946_all_expanded.to_excel(str(exp_excel_path), index=False)
    logging.info(f"Saved: {exp_excel_path} ({len(_4946_all_expanded)} rows)")

    s3_exp_excel = s3_path("output", "cob", "4946", ymd, expanded_filename)
    upload_file_to_s3(spark, str(exp_excel_path), s3_exp_excel)

    # Expanded parquet to S3
    s3_exp_parquet = s3_path("output", "cob", "4946", ymd, expanded_filename.replace(".xlsx", ".parquet"))
    write_parquet_to_s3(spark, _4946_all_expanded, s3_exp_parquet)

    # Upload log file to S3
    log_file = logpath / log_file_name
    if log_file.exists():
        s3_log = s3_path("logs", "cob", "4946", log_file_name)
        upload_file_to_s3(spark, str(log_file), s3_log)

    # -------------------------------------------------------------------------
    # Step 19: Prepare and upload to SQL Server
    # -------------------------------------------------------------------------
    logging.info("Step 19: Preparing data for SQL Server upload...")
    autocomplete_all_db = autocomplete_all_new.copy()
    autocomplete_all_db["comments"] = autocomplete_all_db["Comments"]
    autocomplete_all_db["Control Risk"] = autocomplete_all_db["ControlRisk"]

    db_cols_cob_ac = [
        "RegulatoryName", "LOB", "ReportName", "Control Risk", "TestType", "TestPeriod", "ProductType",
        "RDE", "SubDE", "Segment", "Segment2", "Segment3", "Segment4", "Segment5", "Segment6", "Segment7",
        "Segment8", "Segment9", "Segment10", "Segment11", "Segment12", "Segment13", "Segment14", "Segment15",
        "Segment16", "Segment17", "Segment18", "Segment19", "Segment20", "HoldoutFlag", "CommentCode",
        "comments", "Volume", "Bal", "Amount", "DateCompleted", "SnapDate",
    ]

    autocomplete_all_db, added = check_add_missing_cols(autocomplete_all_db, required_cols=db_cols_cob_ac, reorder=True)

    db_cols_cob_ac_notnull = [
        "RegulatoryName", "LOB", "ReportName", "Control Risk", "TestType", "TestPeriod", "ProductType",
        "RDE", "HoldoutFlag", "CommentCode", "comments", "Volume", "DateCompleted", "SnapDate",
    ]
    check_required_notnull(autocomplete_all_db, db_cols_cob_ac_notnull, treat_empty_as_missing=True)

    # -------------------------------------------------------------------------
    # Step 20: SQL Server upload (guarded — flip do_sql_upload to True when ready)
    # -------------------------------------------------------------------------
    do_sql_upload = False  # flip to True when ready for production upload
    if do_sql_upload:
        logging.info("Step 20: Uploading to SQL Server...")
        sqlserver_engine = get_sqlserver_engine(sql_secrets_json)
        try:
            num_cols = len(autocomplete_all_db.columns)
            safe_chunk_size = 2100 // num_cols

            df_to_upload = autocomplete_all_db.copy()
            df_to_upload = df_to_upload.rename(columns={"LOB": "lob"})

            df_to_upload.to_sql(
                name=cfg.sql_table, con=sqlserver_engine,
                if_exists="append", index=False, schema="dbo",
                method="multi", chunksize=safe_chunk_size,
            )
            logging.info(f"Uploaded {len(df_to_upload)} rows to dbo.{cfg.sql_table} "
                         f"(chunk size: {safe_chunk_size})")
        except Exception as e:
            logging.error(f"SQL Server upload failed: {e}")
            raise
        finally:
            sqlserver_engine.dispose()
    else:
        logging.info("Step 20: SQL Server upload SKIPPED (do_sql_upload=False)")

    # -------------------------------------------------------------------------
    # Done
    # -------------------------------------------------------------------------
    logging.info("=" * 60)
    logging.info("COB_Repository_Prod_4946 completed successfully.")
    logging.info("All outputs saved locally AND to S3.")
    logging.info("=" * 60)

    # NOTE: Do NOT call spark.stop() — main.py handles session teardown.


