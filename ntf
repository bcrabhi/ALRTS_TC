    RBI_INVST_GIC_DLY_S.STS_CD,
    INVSTMT_HLDNG_DLY_DELTA.DEP_TERM_IN_YRS  AS DEP_TERM_IN_YRS_13,
    INVSTMT_HLDNG_DLY_DELTA.DEP_TERM_IN_DAYS AS DEP_TERM_IN_DAYS_13,
    RB_CLNT_DLY.BSC,
    FUND_HOLDING_TXN.PLN_NO,
    CAST(FUND_HOLDING_TXN.PLN_NO AS CHAR(9))  AS plan_number
FROM
    ddwv01.RBI_INVST_GIC_DLY_S,
    ddwv01.FUND_HOLDING_TXN,
    ddwv01.CLNT_AR_RELTN_DLY
    LEFT JOIN ddwv01.INVSTMT_HLDNG_DLY_DELTA AS INVSTMT_HLDNG_DLY_DELTA
        ON  CLNT_AR_RELTN_DLY.AR_ID = INVSTMT_HLDNG_DLY_DELTA.AR_ID
        AND INVSTMT_HLDNG_DLY_DELTA.chg_dt  = '9999-12-31'
        AND INVSTMT_HLDNG_DLY_DELTA.SRVC_ID = 13
    LEFT JOIN ddwv01.RB_CLNT_DLY AS RB_CLNT_DLY
        ON  CLNT_AR_RELTN_DLY.CLNT_NO  = RB_CLNT_DLY.CLNT_NO
        AND CLNT_AR_RELTN_DLY.SNAP_DT  = RB_CLNT_DLY.SNAP_DT
WHERE
    RBI_INVST_GIC_DLY_S.SNAP_DT     = {wk_end}
    AND CLNT_AR_RELTN_DLY.SNAP_DT   = {wk_end}
    AND RBI_INVST_GIC_DLY_S.MTRTY_DT BETWEEN {wk_start} AND {mat_dt}
    AND RBI_INVST_GIC_DLY_S.STS_CD  <> 'T'
    AND RBI_INVST_GIC_DLY_S.AR_ID   IN ({ar_list})
    AND CLNT_AR_RELTN_DLY.CLNT_NO   IN ({clnt_list})
    AND RBI_INVST_GIC_DLY_S.AR_ID   = CLNT_AR_RELTN_DLY.AR_ID
    AND RBI_INVST_GIC_DLY_S.SRVC_ID = CLNT_AR_RELTN_DLY.DW_SRVC_ID
    AND RBI_INVST_GIC_DLY_S.SNAP_DT = CLNT_AR_RELTN_DLY.SNAP_DT
    AND FUND_HOLDING_TXN.AR_ID      = CLNT_AR_RELTN_DLY.AR_ID
    AND FUND_HOLDING_TXN.DW_SRVC_ID = CLNT_AR_RELTN_DLY.DW_SRVC_ID
ORDER BY 1, 2, 3, 5
"""

SQL_ARNGMNT_OPTION = """
SELECT DISTINCT
    ARNGMNT_OPTION.MIF_SRVC_ID,
    ARNGMNT_OPTION.CHOICE_CD_VAL_ID,
    ARNGMNT_OPTION.CHANGE_TMSTMP             AS PREF_CHANGE_TMSTMP,
    ARNGMNT_OPTION.DW_SRVC_ID               AS pln_DW_SRVC_ID,
    ARNGMNT_OPTION.PREF_ID,
    RIGHT(ARNGMNT_OPTION.AR_ID, 9)          AS plan_number
FROM
    ddwv01.ARNGMNT_OPTION
WHERE
    RIGHT(ARNGMNT_OPTION.AR_ID, 9) IN ({plan_list})
    AND ARNGMNT_OPTION.PREF_ID    IN (13001, 13004)
    AND ARNGMNT_OPTION.DW_SRVC_ID IN (10, 99)
ORDER BY 6
"""

SQL_BACKDATE = """
SELECT DISTINCT
    CLNT_AR_RELTN_DLY.AR_ID,
    MIN(CLNT_AR_RELTN_DLY.SNAP_DT) AS backdate_check
FROM
    ddwv01.CLNT_AR_RELTN_DLY
WHERE
    AR_ID IN ({ar_list})
    AND CLNT_AR_RELTN_DLY.SNAP_DT > {back_dt}
GROUP BY 1
ORDER BY 1
"""


def _quoted_list(values: pd.Series, quote: bool = True) -> str:
    """Build a SQL IN-list string from a Series."""
    unique = values.dropna().unique()
    if quote:
        return ", ".join(f"'{v}'" for v in unique)
    return ", ".join(str(v) for v in unique)


def _fetch_plan_preferences(
    conn: teradatasql.TeradataConnection,
    plan_list_sql: str,
) -> pd.DataFrame:
    """
    Query ARNGMNT_OPTION for delivery preferences and return the latest
    preference per plan_number.
    Mirrors the repeated all_plans14 / all_plans13 pattern.
    """
    sql  = SQL_ARNGMNT_OPTION.format(plan_list=plan_list_sql)
    df   = pd.read_sql(sql, conn)

    # Drop choice_cd_val_id in (17001, 17002)  →  exclude certain preference codes
    df = df[~df["CHOICE_CD_VAL_ID"].isin([17001, 17002])].copy()

    # Keep only latest preference per plan (mirrors PROC SORT nodupkey)
    df["PREF_CHANGE_TMSTMP"] = pd.to_datetime(df["PREF_CHANGE_TMSTMP"], errors="coerce")
    df = (
        df.sort_values(["plan_number", "PREF_CHANGE_TMSTMP"], ascending=[True, False])
          .drop_duplicates(subset=["plan_number"])
          .reset_index(drop=True)
    )
    return df


def find_fails(
    conn: teradatasql.TeradataConnection,
    fails: pd.DataFrame,
    dates: Dict[str, str],
) -> pd.DataFrame:
    """
    Replicate the SAS %find_fails macro.

    For each failing arrangement:
      1. Pull MIF14 / MIF13 data from Teradata
      2. Fetch plan delivery preferences (ARNGMNT_OPTION)
      3. Assign fail_reason where possible
      4. Check backdated arrangements for remaining unexplained fails
    """
    # -----------------------------------------------------------------------
    # SRVC_ID = 14 branch
    # -----------------------------------------------------------------------
    fails14 = fails[fails["SRVC_ID"] == 14].copy()
    logging.info("Fails for SRVC_ID=14: %d rows.", len(fails14))

    if not fails14.empty:
        ar_list14   = _quoted_list(fails14["AR_ID"],   quote=True)
        clnt_list14 = _quoted_list(fails14["CLNT_NO"], quote=False)

        logging.info("Pulling MIF14 data from Teradata...")
        mif14 = pd.read_sql(
            SQL_MIF14.format(
                wk_end=dates["wk_end"], wk_start=dates["wk_start"],
                mat_dt=dates["mat_dt"], ar_list=ar_list14, clnt_list=clnt_list14,
            ),
            conn,
        )
        logging.info("MIF14: %d rows.", len(mif14))

        if not mif14.empty:
            plan_list14 = _quoted_list(mif14["plan_number"], quote=True)
            pref14      = _fetch_plan_preferences(conn, plan_list14)

            # Join pref to mif
            mif14 = mif14.sort_values("plan_number")
            pref14 = pref14.sort_values("plan_number")
            mif14_pref = pd.merge(pref14, mif14, on="plan_number", how="right")

            # Join back to fails14
            mif14_pref = mif14_pref.sort_values(["AR_ID", "CLNT_NO"])
            fails14    = fails14.sort_values(["AR_ID", "CLNT_NO"])
            fails14 = pd.merge(
                fails14, mif14_pref,
                on=["AR_ID", "CLNT_NO"], how="left", suffixes=("", "_mif14"),
            )
        else:
            logging.warning("MIF14 returned 0 rows — skipping plan preference join for SRVC_ID=14.")
    else:
        logging.info("No fails for SRVC_ID=14.")

    # -----------------------------------------------------------------------
    # SRVC_ID = 13 branch
    # -----------------------------------------------------------------------
    fails13 = fails[fails["SRVC_ID"] == 13].copy()
    logging.info("Fails for SRVC_ID=13: %d rows.", len(fails13))

    mif13_pref = pd.DataFrame()
    if not fails13.empty:
        ar_list13   = _quoted_list(fails13["AR_ID"],   quote=True)
        clnt_list13 = _quoted_list(fails13["CLNT_NO"], quote=False)

        logging.info("Pulling MIF13 data from Teradata...")
        mif13 = pd.read_sql(
            SQL_MIF13.format(
                wk_end=dates["wk_end"], wk_start=dates["wk_start"],
                mat_dt=dates["mat_dt"], ar_list=ar_list13, clnt_list=clnt_list13,
            ),
            conn,
        )
        logging.info("MIF13: %d rows.", len(mif13))

        # Pad plan_number to 9 chars (mirrors: if length(plan_number)=8 …)
        mif13["plan_number"] = mif13["plan_number"].astype(str).str.zfill(9)

        if not mif13.empty:
            plan_list13 = _quoted_list(mif13["plan_number"], quote=True)
            pref13      = _fetch_plan_preferences(conn, plan_list13)

            mif13 = mif13.sort_values("plan_number")
            pref13 = pref13.sort_values("plan_number")
            mif13_pref = pd.merge(pref13, mif13, on="plan_number", how="right")
        else:
            logging.warning("MIF13 returned 0 rows.")
    else:
        logging.info("No fails for SRVC_ID=13.")

    # -----------------------------------------------------------------------
    # Combine fails14 and merge MIF13 preferences
    # Mirrors: data rbis_noti_compare_fails_all (merge fails14 + mif13_pref)
    # -----------------------------------------------------------------------
    fails_all = fails14.copy() if not fails14.empty else fails.copy()

    if not mif13_pref.empty:
        fails_all = fails_all.sort_values(["AR_ID", "CLNT_NO"])
        mif13_pref = mif13_pref.sort_values(["AR_ID", "CLNT_NO"])
        fails_all = pd.merge(
            fails_all, mif13_pref,
            on=["AR_ID", "CLNT_NO"], how="left", suffixes=("", "_mif13"),
        )

    # Backfill total_term_day where missing
    # mirrors: if total_term_day = . then …
    mask_missing = fails_all["total_term_day"].isna()
    cond14_mask  = mask_missing & (fails_all["SRVC_ID"] == 14)
    cond13_mask  = mask_missing & (fails_all["SRVC_ID"] == 13)

    fails_all.loc[cond14_mask, "total_term_day"] = (
        fails_all.loc[cond14_mask, "MTRTY_DT"] - fails_all.loc[cond14_mask, "DT_OPEN_mif14"]
    ).dt.days
    fails_all.loc[cond13_mask, "total_term_day"] = (
        fails_all.loc[cond13_mask, "MTRTY_DT"] - fails_all.loc[cond13_mask, "DT_OPEN_mif13"]
    ).dt.days

    # pref_date column
    if "PREF_CHANGE_TMSTMP" in fails_all.columns:
        fails_all["pref_date"] = pd.to_datetime(
            fails_all["PREF_CHANGE_TMSTMP"], errors="coerce"
        ).dt.date
    else:
        fails_all["pref_date"] = pd.NaT

    # fail_reason — term-length based
    fails_all["fail_reason"] = ""

    mask_21_mail = (fails_all["NOTIF_NO_OF_DYS"] == 21) & (fails_all["NOTIF_DELVRY_PREF"] == "P")
    mask_5_mail  = (fails_all["NOTIF_NO_OF_DYS"] == 5)  & (fails_all["NOTIF_DELVRY_PREF"] == "P")

    fails_all.loc[mask_21_mail & (fails_all["total_term_day"] < 32), "fail_reason"] = (
        "Failed due to term length being under regulatory SLA minimum range            "
    )
    fails_all.loc[mask_5_mail  & (fails_all["total_term_day"] < 16), "fail_reason"] = (
        "Failed due to term length being under regulatory SLA minimum range            "
    )

    # fail_reason — paper preference introduced near notification date
    pref_date_series = pd.to_datetime(fails_all["pref_date"], errors="coerce")
    notif_sent       = pd.to_datetime(fails_all["NOTIF_SENT_DT"], errors="coerce")
    days_diff        = (notif_sent - pref_date_series).dt.days.abs()

    mask_pref_fail = (
        (fails_all["fail_reason"] == "")
        & pref_date_series.notna()
        & (days_diff < 9)
    )
    fails_all.loc[mask_pref_fail, "fail_reason"] = (
        "Failed due to introduction of Paper Pref after regulatory SLA minimum range"
    )

    # -----------------------------------------------------------------------
    # Backdate check for remaining unexplained fails
    # (mirrors: data rbis_noti_compare_fails_all2 + backdated query)
    # -----------------------------------------------------------------------
    still_unexplained = fails_all[fails_all["fail_reason"] == ""].copy()
    logging.info("Unexplained fails before backdate check: %d rows.", len(still_unexplained))

    if not still_unexplained.empty:
        bd_ar_list = _quoted_list(still_unexplained["AR_ID"], quote=True)
        logging.info("Pulling backdate data from Teradata...")
        backdated = pd.read_sql(
            SQL_BACKDATE.format(ar_list=bd_ar_list, back_dt=dates["back_dt"]),
            conn,
        )
        logging.info("Backdated: %d rows.", len(backdated))

        fails_all = pd.merge(fails_all, backdated, on="AR_ID", how="left")

        bd_check_series = pd.to_datetime(fails_all["backdate_check"], errors="coerce")
        bd_days_diff    = (notif_sent - bd_check_series).dt.days.abs()

        mask_bd = (
            (fails_all["fail_reason"] == "")
            & bd_check_series.notna()
            & (bd_days_diff < 9)
        )
        fails_all.loc[mask_bd, "fail_reason"] = (
            "Failed due to introduction of backdated arrangement id              "
        )
    else:
        fails_all["backdate_check"] = pd.NaT

    logging.info("Fails final: %d rows.", len(fails_all))
    return fails_all



# Step 4 — Build autocomplete tables
# (mirrors four PROC SQL create table ac_time_rbis_noti_* statements)


# RDE codes per segment
_RDE_MAP = {
    ("R",  5):  "Notif014_Timeliness_SLA",
    ("R",  21): "Notif013_Timeliness_SLA",
    ("N",  5):  "Notif016_Timeliness_SLA",
    ("N",  21): "Notif015_Timeliness_SLA",
}

_SEGMENT3_MAP = {
    "R": "Registered GIC",
    "N": "Non-Registered GIC",
}


def _build_ac_table(
    df: pd.DataFrame,
    reg_ind: str,
    n_days: int,
    today2: str,
) -> pd.DataFrame:
    """
    Aggregate one segment into an autocomplete-style summary table.
    Mirrors a single PROC SQL create table ac_time_rbis_noti_* block.
    """
    rde      = _RDE_MAP[(reg_ind, n_days)]
    segment3 = _SEGMENT3_MAP[reg_ind]
    segment2 = f"{n_days} days"

    df = df.copy()
    df["SNAP_DT"] = pd.to_datetime(df["SNAP_DT"], errors="coerce")

    # SnapDate = next Monday after NOTIF_SENT_DT
    # mirrors: intnx('week.7', NOTIF_SENT_DT, 1, 'B')
    sent = pd.to_datetime(df["NOTIF_SENT_DT"], errors="coerce")
    days_to_monday = (7 - sent.dt.weekday) % 7
    days_to_monday = days_to_monday.where(days_to_monday > 0, 7)
    snap_date = (sent + pd.to_timedelta(days_to_monday, unit="d")).dt.date

    df["SnapDate"]       = snap_date
    df["DateCompleted"]  = pd.to_datetime(today2, format="%Y-%m-%d").date()
    df["segment10"]      = df["SNAP_DT"].dt.strftime("%Y%m")
    df["Segment9"]       = df["Total_days"].astype(str)

    group_cols = [
        "RegulatoryName", "LOB", "ReportName", "ProductType",
        "CommentCode", "Comments",
        "thirty_day_ind", "deliverypreference",
        "Segment9", "segment10",
        "SnapDate", "DateCompleted",
    ]

    agg = (
        df.groupby(group_cols, dropna=False)
          .size()
          .reset_index(name="Volume")
    )

    agg["ControlRisk"] = "Timeliness"
    agg["TestType"]    = "Anomaly"
    agg["TestPeriod"]  = "Portfolio"
    agg["RDE"]         = rde
    agg["SubDE"]       = ""
    agg["Segment"]     = "Renewals"
    agg["Segment2"]    = segment2
    agg["Segment3"]    = segment3
    agg["Segment4"]    = agg["thirty_day_ind"]
    agg["Segment5"]    = agg["deliverypreference"]
    agg["Segment6"]    = ""
    agg["Segment7"]    = ""
    agg["Segment8"]    = ""
    agg["HoldoutFlag"] = "N"
    agg["Bal"]         = np.nan
    agg["Amount"]      = np.nan

    agg["DateCompleted"] = pd.to_datetime(agg["DateCompleted"], errors="coerce")
    agg["SnapDate"]      = pd.to_datetime(agg["SnapDate"],      errors="coerce")

    return agg.sort_values(["RegulatoryName", "LOB", "SnapDate"])


def build_autocomplete_tables(
    segments: Dict[str, pd.DataFrame],
    dates: Dict[str, str],
) -> pd.DataFrame:
    """
    Build and stack the four autocomplete segment tables.
    Mirrors data notidata.renew_gic_ac_&rundt. / renew_gic_ac_curr.
    """
    today2 = dates["today2"]

    ac_parts = [
        _build_ac_table(segments["nonreg_05"], "N",  5, today2),
        _build_ac_table(segments["nonreg_21"], "N", 21, today2),
        _build_ac_table(segments["reg_05"],    "R",  5, today2),
        _build_ac_table(segments["reg_21"],    "R", 21, today2),
    ]
    combined = pd.concat(ac_parts, ignore_index=True)
    logging.info("Combined autocomplete table: %d rows.", len(combined))
    return combined



# Step 5 — Persist autocomplete (mirrors %Timeliness macro + proc export)


def persist_autocomplete(
    spark: SparkSession,
    curr: pd.DataFrame,
    dates: Dict[str, str],
    cfg: Config,
) -> pd.DataFrame:
    """
    Append current week's autocomplete rows to the persistent store.
    Mirrors the SAS %Timeliness macro (ini_run branch) and proc export.
    """
    local_ac = cfg.outpath / cfg.persistent_ac_file
    s3_ac    = s3_path("output", cfg.persistent_ac_file)
    ini_run  = dates.get("ini_run", "N")
    sasdt2   = dates["sasdt2"]   # week_end date string for dedup filter

    if ini_run == "Y" or not local_ac.exists():
        logging.info("Initial run — writing autocomplete from scratch.")
        combined = curr
    else:
        logging.info("Incremental run — appending to existing autocomplete.")
        existing = pd.read_parquet(local_ac)
        existing["SnapDate"] = pd.to_datetime(existing["SnapDate"], errors="coerce")
        # Remove current week's rows before appending (mirrors WHERE SnapDate ne &sasdt2)
        existing = existing[
            existing["SnapDate"].dt.strftime("%Y-%m-%d") != sasdt2
        ].copy()
        combined = pd.concat([existing, curr], ignore_index=True)

    logging.info("Persisting autocomplete: %d total rows.", len(combined))

    # Local save
    cfg.outpath.mkdir(parents=True, exist_ok=True)
    combined.to_parquet(local_ac, index=False)
    logging.info("Saved local parquet: %s", local_ac)

    # S3 save
    write_parquet_to_s3(spark, combined, s3_ac)

    # Excel export (mirrors proc export … dbms=xlsx)
    excel_path = cfg.outpath / cfg.excel_autocomplete_file
    with pd.ExcelWriter(excel_path, engine="openpyxl", date_format="YYYY-MM-DD") as writer:
        combined.to_excel(writer, sheet_name="renew_gic_autocomplete", index=False)
    logging.info("Exported autocomplete Excel: %s", excel_path)
    upload_file_to_s3(spark, str(excel_path), s3_path("output", cfg.excel_autocomplete_file))

    return combined



# Step 6 — Export fail detail file
# (mirrors data notidata.rbis_noti_time_fail_wk_&ymd. + proc export)


def export_fail_detail(
    spark: SparkSession,
    fails_final: pd.DataFrame,
    dates: Dict[str, str],
    cfg: Config,
) -> None:
    """
    Build and export the timeliness fail detail file.
    Mirrors the final DATA step that creates rbis_noti_time_fail_wk_&ymd.
    """
    df = fails_final[fails_final["Comments"].str.strip() == "Potential Fail"].copy()

    df["event_month"]               = df["NOTIF_SENT_DT"].dt.strftime("%Y%m")
    df["Notification_Delivery_Type"] = df["deliverypreference"]
    df["Certificate_number"]         = df["CERT_NO"]
    df["Type_of_Notification"]       = df["thirty_day_ind"]
    df["Account_number"]             = df["ACCT_NO"]
    df["Renewal_Date"]               = df["MTRTY_DT"]
    df["renewal_rule"]               = df["NOTIF_NO_OF_DYS"].map({21: "21 days", 5: "5 days "})
    df["clientid_mask"]              = df["CLNT_NO"].astype(str).str[6:9]
    df["date_completed"]             = pd.to_datetime(dates["today2"], format="%Y-%m-%d")
    df["event_week_ending"]          = (
        pd.to_datetime(df["NOTIF_SENT_DT"]) +
        pd.to_timedelta((6 - df["NOTIF_SENT_DT"].dt.weekday) % 7, unit="d")
    )
    df["product"] = np.where(
        df["RGSTR_NO_RGSTR_IND"] == "N", "Non-Registered GIC",
        np.where(df["RGSTR_NO_RGSTR_IND"] == "R", "Registered GIC ", np.nan),
    )

    keep_cols = [
        "event_month", "event_week_ending", "LOB", "product",
        "Type_of_Notification", "NOTIF_NO_OF_DYS", "AR_ID",
        "Notification_Delivery_Type", "clientid_mask", "Account_number",
        "Certificate_number", "Renewal_Date", "NOTIF_SENT_DT",
        "renewal_rule", "date_completed", "Total_days",
        "fail_reason", "DT_OPEN_mif14", "DT_OPEN_mif13",
        "pref_date", "backdate_check",
    ]
    existing_cols = [c for c in keep_cols if c in df.columns]
    df = df[existing_cols]

    rundt      = dates["rundt"]
    local_path = cfg.outpath / f"{cfg.excel_fail_detail_prefix}_{rundt}.xlsx"

    with pd.ExcelWriter(local_path, engine="openpyxl", date_format="YYYY-MM-DD") as writer:
        df.to_excel(writer, sheet_name="Notif_RBIS_Renew_Time", index=False)
    logging.info("Exported fail detail Excel: %s", local_path)

    upload_file_to_s3(
        spark, str(local_path),
        s3_path("output", f"{cfg.excel_fail_detail_prefix}_{rundt}.xlsx"),
    )

    # Parquet copy to S3
    write_parquet_to_s3(
        spark, df,
        s3_path("output", f"rbis_noti_time_fail_wk_{rundt}.parquet"),
    )



