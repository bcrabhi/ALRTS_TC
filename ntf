# Main entry point  (Tyr/Helios framework signature)


def main(ss: SparkSession, job_conf: Dict) -> None:
    """
    Main entry point for Tyr/Helios framework.

    Args:
        ss       : SparkSession provided by the framework.
        job_conf : Job configuration dictionary from Airflow/Tyr.
    """
    cfg = Config()

    # ── Logging ─────────────────────────────────────────────────────────────
    ymd           = datetime.now().strftime("%Y%m%d")
    log_file_name = f"C86_notification_rbis_{ymd}.log"
    setup_logging(cfg.logpath, log_file_name)

    logging.info("=" * 70)
    logging.info("C86 RBIS Renewal Notification — Python Migration Starting")
    logging.info("User    : %s", os.environ.get("USER", "unknown"))
    logging.info("Host    : %s", os.environ.get("HOSTNAME", "unknown"))
    logging.info("Started : %s", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))
    logging.info("=" * 70)

    # ── S3 / Spark ──────────────────────────────────────────────────────────
    configure_s3a(ss)
    cfg.outpath.mkdir(parents=True, exist_ok=True)
    cfg.main_notif_path.mkdir(parents=True, exist_ok=True)

    # ── Ini-check + dates ───────────────────────────────────────────────────
    logging.info("--- Step 0: Ini-check and date setup ---")
    ini_run, day_buff = check_ini_run(ss, cfg.outpath, cfg.persistent_ac_file)
    dates = setup_dates(ini_run, day_buff)
    dates["ini_run"] = ini_run   # carry through for persist step

    # ── Teradata: pull base data ─────────────────────────────────────────────
    logging.info("--- Step 1: Pull base notification data ---")
    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        base_df = pull_base_notifications(conn, dates)

    # ── Business rules + segment split ──────────────────────────────────────
    logging.info("--- Step 2: Apply pass/fail business rules ---")
    enriched   = apply_business_rules(base_df)
    segments   = split_segments(enriched)

    # Stack all segments for combined view
    compare_all = pd.concat(list(segments.values()), ignore_index=True)
