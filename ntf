# Context + Dates


@dataclass(frozen=True)
class RunDates:
    """
    Mirrors SAS macro date variables.

    SAS logic:
        tday = intnx('week.3', today(), 0)   -- Tuesday-aligned week
        week_end  = tday - 3                  -- Saturday
        week_start = week_end - 6             -- Sunday  (non-initial run)
        mat_dt    = week_end + 36             -- maturity look-ahead
        back_date_limit = week_start - 20
    """
    run_dt: date          # today
    week_start: date      # Sunday
    week_end: date        # Saturday
    mat_dt: date          # week_end + 36
    back_dt: date         # week_start - 20
    ymd: str              # yyyymmdd label for file names

    # Quoted strings for Trino SQL predicates
    wk_start: str
    wk_end: str
    mat_dt_q: str
    back_dt_q: str
    today2: str


@dataclass
class Context:
    conf: dict
    d: RunDates
    conn: Any
    log: logging.Logger



# Date helpers — exact SAS intnx parity


def _quote(d: date) -> str:
    """Wrap a date as a quoted Trino date literal 'YYYY-MM-DD'."""
    return f"'{d.strftime('%Y-%m-%d')}'"


def _intnx_week3_tuesday_start(d: date) -> date:
    """
    SAS intnx('week.3', d, 0) where week.3 = Tuesday-aligned week.
    Returns the Tuesday on or before d.
    """
    # Mon=0 … Sun=6; Tue=1
    days_since_tue = (d.weekday() - 1) % 7
    return d - timedelta(days=days_since_tue)


def compute_dates(
    today: Optional[date] = None,
    ini_run: bool = True,
    prev_snap_date: Optional[date] = None,
) -> RunDates:
    """
    Reproduce SAS date window logic.

    SAS:
        tday      = intnx('week.3', today(), 0)   -> Tuesday
        week_end  = tday - 3                       -> Saturday
        week_start = week_end - 6    (non-initial) -> Sunday
                   = launch_dt       (initial run)
        mat_dt    = week_end + 36
        back_date_limit = week_start - 20
    """
    if today is None:
        today = date.today()

    launch_dt = date(2022, 7, 1)

    tuesday = _intnx_week3_tuesday_start(today)
    week_end = tuesday - timedelta(days=3)   # Saturday

    if ini_run:
        week_start = launch_dt
    else:
        week_start = week_end - timedelta(days=6)

    mat_dt = week_end + timedelta(days=36)
    back_dt = week_start - timedelta(days=20)

    return RunDates(
        run_dt=today,
        week_start=week_start,
        week_end=week_end,
        mat_dt=mat_dt,
        back_dt=back_dt,
        ymd=today.strftime("%Y%m%d"),
        wk_start=_quote(week_start),
        wk_end=_quote(week_end),
        mat_dt_q=_quote(mat_dt),
        back_dt_q=_quote(back_dt),
        today2=_quote(today),
    )



# Logging + Config + Trino connection


def setup_logger(log_path: Path) -> logging.Logger:
    """Configure file + stdout logging, matching SAS proc printto behaviour."""
    log_path.parent.mkdir(parents=True, exist_ok=True)
    logger = logging.getLogger("c86_rbis_renewal")
    logger.setLevel(logging.INFO)
    logger.handlers.clear()

    fmt = logging.Formatter("%(asctime)s [%(levelname)s] %(message)s")
    fh = logging.FileHandler(log_path)
    fh.setFormatter(fmt)
    sh = logging.StreamHandler(sys.stdout)
    sh.setFormatter(fmt)

    logger.addHandler(fh)
    logger.addHandler(sh)
    return logger


def load_config(path: Path = Path("config.ini")) -> dict:
    """Load config.ini — mirrors SAS %include pswd.sas / %let regpath."""
    if not path.exists():
        raise FileNotFoundError(f"Missing config.ini at: {path}")

    cfg = configparser.ConfigParser()
    cfg.read(path)
    c = cfg["TRINO"]

    return {
        "host":        c.get("host"),
        "port":        c.getint("port", fallback=8443),
        "user":        c.get("username"),
        "password":    c.get("password", fallback=None) or None,
        "http_scheme": c.get("http_schema", fallback="https"),
        "catalog":     c.get("catalog", fallback="edl0_im"),
        "schema":      c.get("schema", fallback="prod_brt0_ess"),
        "source":      c.get("source", fallback="c86_rbis_renewal"),
        "out_root":    c.get("out_root", fallback="./output"),
        "log_root":    c.get("log_root", fallback="./log"),
        # memory connector
        "mem_catalog": c.get("mem_catalog", fallback="memory"),
        "mem_schema":  c.get("mem_schema", fallback="default"),
    }


def get_conn(conf: dict) -> trino.dbapi.Connection:
    """Open a Trino connection — mirrors SAS %ConnectSql / proc sql connect."""
    auth = (
        BasicAuthentication(conf["user"], conf["password"])
        if conf.get("password")
        else None
    )
    return trino.dbapi.connect(
        host=conf["host"],
        port=conf["port"],
        user=conf["user"],
        http_scheme=conf["http_scheme"],
        auth=auth,
        catalog=conf["catalog"],
        schema=conf["schema"],
        source=conf["source"],
    )



# SQL helpers


def exec_sql(ctx: Context, sql: str) -> None:
    """Execute a DDL/DML statement with no result needed."""
    ctx.log.info("SQL: %s", " ".join(sql.split())[:200])
    cur = ctx.conn.cursor()
    cur.execute(sql)
    try:
        _ = cur.fetchall()
    except Exception:
        pass


def fetch_df(ctx: Context, sql: str) -> pd.DataFrame:
    """Execute a SELECT and return results as a DataFrame."""
    ctx.log.info("FETCH: %s", " ".join(sql.split())[:200])
    cur = ctx.conn.cursor()
    cur.execute(sql)
    rows = cur.fetchall()
    cols = [c[0] for c in cur.description] if cur.description else []
    return pd.DataFrame(rows, columns=cols)


def mem_fqtn(ctx: Context, table: str) -> str:
    """Fully-qualified memory connector table name."""
    return f'{ctx.conf["mem_catalog"]}.{ctx.conf["mem_schema"]}.{table}'


def lake_fqtn(ctx: Context, table: str) -> str:
    """Fully-qualified data-lake table name."""
    return f'{ctx.conf["catalog"]}.{ctx.conf["schema"]}.{table}'



# Initial-run detection  (mirrors SAS %ini_check macro)


def detect_ini_run(history_path: Path, ctx: Context) -> tuple[bool, int]:
    """
    Mirrors SAS %ini_check.

    Returns:
        ini_run  : True  if no history file exists (first ever run)
        day_buff : days since last snap (1 for first run)
    """
    if not history_path.exists():
        ctx.log.info("ini_run=Y — no history file found, initial run.")
        return True, 1

    history = pd.read_csv(history_path, parse_dates=["SnapDate"])
    if history.empty or "SnapDate" not in history.columns:
        ctx.log.info("ini_run=Y — history file empty.")
        return True, 1

    max_snap = history["SnapDate"].max()
    if pd.isna(max_snap):
        return True, 1

    day_buff = (ctx.d.run_dt - max_snap.date()).days
    ctx.log.info("ini_run=N — day_buff=%d (last snap %s)", day_buff, max_snap.date())
    return False, day_buff



# Memory tables — push all heavy lifting to Trino SQL


_MEMORY_TABLES = [
    "rbis_noti_base_m",
]


def drop_memory_tables(ctx: Context) -> None:
    """Drop all working memory tables before rebuilding."""
    for t in _MEMORY_TABLES:
        exec_sql(ctx, f"DROP TABLE IF EXISTS {mem_fqtn(ctx, t)}")


def build_base_memory_table(ctx: Context) -> None:
    """
    Mirrors SAS PROC SQL → create table rbis_noti_base_init  + BSC filter.

    Pulls RENW_NOTIF joined to dimension tables, filters to:
        RENW_PROD_NOTIF_TYP = 2
        SEP_DISCLSR_IND in (NULL, 'Y')
        SNAP_DT between wk_start and wk_end
        BSC between 600 and 690
    """
    d = ctx.d
    exec_sql(
        ctx,
        f"""
    CREATE TABLE {mem_fqtn(ctx, "rbis_noti_base_m")} AS
    SELECT
        renw.CLNT_NO,
        renw.CLNT_AR_OWN_TYP,
        renw.ACCT_NO,
        renw.SEG_NO,
        renw.ACCT_TR_NO,
        renw.PROD_NM,
        renw.PROD_TRM_IN_YR,
        renw.PROD_TRM_IN_DYS,
        renw.MTRTY_DT,
        renw.CERT_NO,
        renw.FND_NO,
        renw.ACCT_TYP,
        renw.NOTIF_SENT_DT,
        renw.AR_ID,
        renw.SRVC_ID,
        renw.RENW_PROD_NOTIF_TYP,
        renw.SNAP_DT,
        renw.CLNT_SYS_SRC_ID,
        renw.CO_OWN_CLNT_NO,
        renw.RGSTR_NO_RGSTR_IND,
        renw.SEP_DISCLSR_IND,
        renw.NOTIF_NO_OF_DYS,
        renw.NOTIF_DELVRY_PREF,
        rbc.BSC,
        ar14.DT_OPEN                         AS DT_OPEN_mif14,
        arst.DT_OPEN                         AS DT_OPEN_mif13,
        trm.DEP_TERM_IN_DAYS                 AS TRM_DAYS_14,
        trm.DEP_TERM_IN_YRS                  AS TRM_YRS_14,
        ihd.DEP_TERM_IN_YRS                  AS DEP_TERM_IN_YRS_13,
        ihd.DEP_TERM_IN_DAYS                 AS DEP_TERM_IN_DAYS_13
    FROM      {lake_fqtn(ctx, "RENW_NOTIF")}           AS renw
    LEFT JOIN {lake_fqtn(ctx, "RB_CLNT_DLY")}          AS rbc
           ON renw.CLNT_NO   = rbc.CLNT_NO
          AND rbc.SNAP_DT    = {d.wk_end}
    LEFT JOIN {lake_fqtn(ctx, "AR_DLY")}                AS ar14
           ON ar14.AR_ID     = renw.AR_ID
          AND ar14.SNAP_DT   = {d.wk_end}
    LEFT JOIN {lake_fqtn(ctx, "AR_STATIC_DLY")}         AS arst
           ON arst.AR_ID     = renw.AR_ID
          AND arst.SNAP_DT   = {d.wk_end}
    LEFT JOIN {lake_fqtn(ctx, "TRM_INVSTMT_HLDNG_DLY")} AS trm
           ON trm.AR_ID      = renw.AR_ID
          AND trm.chg_dt     = DATE '9999-12-31'
          AND trm.SRVC_ID    = 14
          AND trm.snap_dt    = {d.wk_end}
    LEFT JOIN {lake_fqtn(ctx, "INVSTMT_HLDNG_DLY_DELTA")} AS ihd
           ON ihd.AR_ID      = renw.AR_ID
          AND ihd.chg_dt     = DATE '9999-12-31'
          AND ihd.SRVC_ID    = 13
    WHERE
        renw.RENW_PROD_NOTIF_TYP = 2
        AND (renw.SEP_DISCLSR_IND IS NULL OR renw.SEP_DISCLSR_IND = 'Y')
        AND renw.SNAP_DT BETWEEN {d.wk_start} AND {d.wk_end}
        AND rbc.BSC BETWEEN 600 AND 690
    """,
    )
    ctx.log.info("Memory table rbis_noti_base_m built.")



# Pass / Fail classification  (mirrors SAS DATA step logic)


def _delivery_preference_label(pref: str) -> str:
    """
    SAS:
        if NOTIF_DELVRY_PREF = 'E' then deliverypreference = 'OLB Notification';
        else if NOTIF_DELVRY_PREF = 'P' then deliverypreference = 'Mail';
        else deliverypreference = 'Other';
    """
    if pref == "E":
        return "OLB Notification"
    if pref == "P":
        return "Mail"
    return "Other"


def _pass_fail(row: pd.Series) -> str:
    """
    SAS pass/fail thresholds for each combination of
    NOTIF_NO_OF_DYS (21 | 5) × NOTIF_DELVRY_PREF (P | non-P).

    Returns 'COM16' (Pass) or 'COM19' (Potential Fail).
    """
    days = row["NOTIF_NO_OF_DYS"]
    pref = row["NOTIF_DELVRY_PREF"]
    total = row["Total_days"]

    if days == 21:
        if pref == "P":
            lo, hi = 32, 36
        else:
            lo, hi = 22, 26
    elif days == 5:
        if pref == "P":
            lo, hi = 16, 20
        else:
            lo, hi = 6, 10
    else:
        return "COM19"   # unexpected value

    return "COM16" if (lo <= total <= hi) else "COM19"


def _thirty_day_ind(total_term_day: float) -> str:
    """
    SAS:
        if total_term_day > 30 then thirty_day_ind = 'Renewals > 30 days';
        else if total_term_day <= 30 and total_term_day >= 0 then ... '<=30 days';
        else if total_term_day = . then ... '> 30 days';
    """
    if pd.isna(total_term_day) or total_term_day > 30:
        return "Renewals > 30 days"
    return "Renewals <= 30 days"


def classify_base(df: pd.DataFrame) -> pd.DataFrame:
    """
    Translate SAS DATA step rbis_noti_compare_reg_05 / _21 / nonreg_05 / _21.

    Adds columns:
        deliverypreference, Total_days, CommentCode, Comments,
        total_term_day, thirty_day_ind,
        RegulatoryName, LOB, ReportName, ProductType
    Drops SEP_DISCLSR_IND = 'N' rows (already filtered in SQL but guarded here).
    """
    df = df.copy()

    # Guard — SEP_DISCLSR_IND = 'N' already excluded in SQL; belt-and-suspenders
    df = df[df["SEP_DISCLSR_IND"] != "N"].copy()

    df["deliverypreference"] = df["NOTIF_DELVRY_PREF"].apply(_delivery_preference_label)

    # Scalar metadata
    df["RegulatoryName"] = "C86"
    df["LOB"]            = "PSI"
    df["ReportName"]     = "C86 Notification Renewals"
    df["ProductType"]    = "GIC"

    # SAS: Total_days = MTRTY_DT - NOTIF_SENT_DT
    df["MTRTY_DT"]       = pd.to_datetime(df["MTRTY_DT"],       errors="coerce")
    df["NOTIF_SENT_DT"]  = pd.to_datetime(df["NOTIF_SENT_DT"],  errors="coerce")
    df["Total_days"]     = (df["MTRTY_DT"] - df["NOTIF_SENT_DT"]).dt.days

    df["CommentCode"] = df.apply(_pass_fail, axis=1)
    df["Comments"]    = df["CommentCode"].map(
        {"COM16": "Pass                  ", "COM19": "Potential Fail        "}
    )

    # total_term_day
    # SAS: if SRVC_ID = 14 then total_term_day = TRM_YRS_14 * 365 + TRM_DAYS_14;
    #      else if SRVC_ID = 13 then total_term_day = DEP_TERM_IN_YRS_13 * 365 + DEP_TERM_IN_DAYS_13;
    cond14 = df["SRVC_ID"] == 14
    cond13 = df["SRVC_ID"] == 13

    df["total_term_day"] = np.nan
    df.loc[cond14, "total_term_day"] = (
        pd.to_numeric(df.loc[cond14, "TRM_YRS_14"],   errors="coerce") * 365
        + pd.to_numeric(df.loc[cond14, "TRM_DAYS_14"], errors="coerce")
    )
    df.loc[cond13, "total_term_day"] = (
        pd.to_numeric(df.loc[cond13, "DEP_TERM_IN_YRS_13"],  errors="coerce") * 365
        + pd.to_numeric(df.loc[cond13, "DEP_TERM_IN_DAYS_13"], errors="coerce")
    )

    df["thirty_day_ind"] = df["total_term_day"].apply(_thirty_day_ind)

    return df


def split_segments(df: pd.DataFrame) -> dict[str, pd.DataFrame]:
    """
    Mirror SAS output routing:
        if RGSTR_NO_RGSTR_IND='R' and NOTIF_NO_OF_DYS=5  → reg_05
        if RGSTR_NO_RGSTR_IND='R' and NOTIF_NO_OF_DYS=21 → reg_21
        if RGSTR_NO_RGSTR_IND='N' and NOTIF_NO_OF_DYS=5  → nonreg_05
        if RGSTR_NO_RGSTR_IND='N' and NOTIF_NO_OF_DYS=21 → nonreg_21
    """
    return {
        "reg_05":    df[(df["RGSTR_NO_RGSTR_IND"] == "R") & (df["NOTIF_NO_OF_DYS"] == 5)].copy(),
        "reg_21":    df[(df["RGSTR_NO_RGSTR_IND"] == "R") & (df["NOTIF_NO_OF_DYS"] == 21)].copy(),
        "nonreg_05": df[(df["RGSTR_NO_RGSTR_IND"] == "N") & (df["NOTIF_NO_OF_DYS"] == 5)].copy(),
        "nonreg_21": df[(df["RGSTR_NO_RGSTR_IND"] == "N") & (df["NOTIF_NO_OF_DYS"] == 21)].copy(),
    }



# Fail-reason resolution  (mirrors SAS %find_fails macro)


def _fetch_mif14(ctx: Context, ar_ids: list[str], clnt_nos: list[int]) -> pd.DataFrame:
    """Mirrors SAS create table mif_14 — AR-level detail for SRVC_ID=14 fails."""
    d = ctx.d
    ar_list   = ", ".join(f"'{a}'" for a in ar_ids)
    clnt_list = ", ".join(str(c) for c in clnt_nos)

    return fetch_df(
        ctx,
        f"""
    SELECT DISTINCT
        ar.AR_ID,
        car.CLNT_NO,
        ar.SNAP_DT,
        ar.MTRTY_EXPRY_DT                  AS mtrty_dt,
        ar.SRVC_ID,
        ar.DT_CLS,
        ar.DT_OPEN,
        ar.OPEN_CLS_STS,
        trm.DEP_TERM_IN_DAYS               AS TRM_DAYS_14,
        trm.DEP_TERM_IN_YRS                AS TRM_YRS_14,
        rbc.BSC,
        ih.PLN_NO,
        CAST(ih.PLN_NO AS VARCHAR(9))      AS plan_number
    FROM      {lake_fqtn(ctx, "AR_DLY")}             AS ar
    JOIN      {lake_fqtn(ctx, "CLNT_AR_RELTN_DLY")}  AS car
           ON ar.AR_ID   = car.AR_ID
          AND ar.SRVC_ID = car.DW_SRVC_ID
          AND ar.SNAP_DT = car.SNAP_DT
    JOIN      {lake_fqtn(ctx, "INVSTMT_HLDNG_DLY")}  AS ih
           ON ih.AR_ID   = car.AR_ID
          AND ih.SNAP_DT = car.SNAP_DT
    LEFT JOIN {lake_fqtn(ctx, "TRM_INVSTMT_HLDNG_DLY")} AS trm
           ON trm.AR_ID  = car.AR_ID
          AND trm.chg_dt = DATE '9999-12-31'
          AND trm.SRVC_ID = 14
    LEFT JOIN {lake_fqtn(ctx, "RB_CLNT_DLY")}        AS rbc
           ON rbc.CLNT_NO = car.CLNT_NO
          AND rbc.SNAP_DT = car.SNAP_DT
    WHERE
        ar.SNAP_DT      = {d.wk_end}
        AND car.SNAP_DT = {d.wk_end}
        AND ih.SNAP_DT  = {d.wk_end}
        AND ar.MTRTY_EXPRY_DT BETWEEN {d.wk_start} AND {d.mat_dt_q}
        AND ar.OPEN_CLS_STS <> 'C'
        AND ar.AR_ID    IN ({ar_list})
        AND car.CLNT_NO IN ({clnt_list})
    ORDER BY 1, 2, 3, 4
    """,
    )


def _fetch_plans(ctx: Context, plan_numbers: list[str]) -> pd.DataFrame:
    """
    Mirrors SAS create table all_plans14a / all_plans13a — ARNGMNT_OPTION preferences.
    Excludes CHOICE_CD_VAL_ID in (17001, 17002).
    """
    plan_list = ", ".join(f"'{p}'" for p in plan_numbers)

    raw = fetch_df(
        ctx,
        f"""
    SELECT DISTINCT
        ao.MIF_SRVC_ID,
        ao.CHOICE_CD_VAL_ID,
        ao.CHANGE_TMSTMP                   AS PREF_CHANGE_TMSTMP,
        ao.DW_SRVC_ID                      AS pln_DW_SRVC_ID,
        ao.PREF_ID,
        RIGHT(ao.AR_ID, 9)                 AS plan_number
    FROM {lake_fqtn(ctx, "ARNGMNT_OPTION")} AS ao
    WHERE RIGHT(ao.AR_ID, 9) IN ({plan_list})
      AND ao.PREF_ID     IN (13001, 13004)
      AND ao.DW_SRVC_ID  IN (10, 99)
    ORDER BY 6
    """,
    )
    # SAS: if choice_cd_val_id in (17001,17002) then delete;
    return raw[~raw["CHOICE_CD_VAL_ID"].isin([17001, 17002])].copy()


def _fetch_mif13(ctx: Context, ar_ids: list[str], clnt_nos: list[int]) -> pd.DataFrame:
    """Mirrors SAS create table mif_13 — AR-level detail for SRVC_ID=13 fails."""
    d = ctx.d
    ar_list   = ", ".join(f"'{a}'" for a in ar_ids)
    clnt_list = ", ".join(str(c) for c in clnt_nos)

    df = fetch_df(
        ctx,
        f"""
    SELECT DISTINCT
        gic.AR_ID,
        car.CLNT_NO,
        gic.SNAP_DT,
        gic.SRVC_ID,
        gic.MTRTY_DT,
        gic.STS_CD,
        ihd.DEP_TERM_IN_YRS                AS DEP_TERM_IN_YRS_13,
        ihd.DEP_TERM_IN_DAYS               AS DEP_TERM_IN_DAYS_13,
        rbc.BSC,
        fht.PLN_NO,
        CAST(fht.PLN_NO AS VARCHAR(9))     AS plan_number
    FROM      {lake_fqtn(ctx, "RBI_INVST_GIC_DLY_S")}      AS gic
    JOIN      {lake_fqtn(ctx, "CLNT_AR_RELTN_DLY")}         AS car
           ON car.AR_ID    = gic.AR_ID
          AND car.DW_SRVC_ID = gic.SRVC_ID
          AND car.SNAP_DT  = gic.SNAP_DT
    JOIN      {lake_fqtn(ctx, "FUND_HOLDING_TXN")}          AS fht
           ON fht.AR_ID    = car.AR_ID
          AND fht.DW_SRVC_ID = car.DW_SRVC_ID
    LEFT JOIN {lake_fqtn(ctx, "INVSTMT_HLDNG_DLY_DELTA")}   AS ihd
           ON ihd.AR_ID    = car.AR_ID
          AND ihd.chg_dt   = DATE '9999-12-31'
          AND ihd.SRVC_ID  = 13
    LEFT JOIN {lake_fqtn(ctx, "RB_CLNT_DLY")}               AS rbc
           ON rbc.CLNT_NO  = car.CLNT_NO
          AND rbc.SNAP_DT  = car.SNAP_DT
    WHERE
        gic.SNAP_DT      = {d.wk_end}
        AND car.SNAP_DT  = {d.wk_end}
        AND gic.MTRTY_DT BETWEEN {d.wk_start} AND {d.mat_dt_q}
        AND gic.STS_CD  <> 'T'
        AND gic.AR_ID    IN ({ar_list})
        AND car.CLNT_NO  IN ({clnt_list})
    ORDER BY 1, 2, 3, 5
    """,
    )

    # SAS: if length(plan_number) = 8 then plan_number = '0' || plan_number;
    df["plan_number"] = df["plan_number"].apply(
        lambda x: ("0" + str(x)) if pd.notna(x) and len(str(x)) == 8 else str(x) if pd.notna(x) else x
    )
    return df


def _fetch_backdates(ctx: Context, ar_ids: list[str]) -> pd.DataFrame:
    """
    Mirrors SAS create table backdated — earliest SNAP_DT for each AR_ID
    after back_date_limit, to detect backdated arrangements.
    """
    d = ctx.d
    ar_list = ", ".join(f"'{a}'" for a in ar_ids)

    return fetch_df(
        ctx,
        f"""
    SELECT
        AR_ID,
        MIN(SNAP_DT)  AS backdate_check
    FROM {lake_fqtn(ctx, "CLNT_AR_RELTN_DLY")}
    WHERE AR_ID   IN ({ar_list})
      AND SNAP_DT >  {d.back_dt_q}
    GROUP BY 1
    ORDER BY 1
    """,
    )


def _merge_plan_prefs(mif_df: pd.DataFrame, plans_df: pd.DataFrame) -> pd.DataFrame:
    """
    Mirror SAS: proc sort nodupkey by plan_number (keep latest PREF_CHANGE_TMSTMP)
    then merge mif + plans by plan_number.
    """
    plans_sorted = (
        plans_df
        .sort_values("PREF_CHANGE_TMSTMP", ascending=False)
        .drop_duplicates(subset=["plan_number"], keep="first")
    )
    mif_sorted = mif_df.sort_values("plan_number")
    return mif_sorted.merge(plans_sorted, on="plan_number", how="left")


def _assign_fail_reason_term(row: pd.Series) -> str:
    """
    SAS fail reason: term too short for the mail SLA window.
        NOTIF_NO_OF_DYS=21 + P → need total_term_day >= 32
        NOTIF_NO_OF_DYS=5  + P → need total_term_day >= 16
    """
    reason = ""
    ttd = row.get("total_term_day")
    if row["NOTIF_NO_OF_DYS"] == 21 and row["NOTIF_DELVRY_PREF"] == "P":
        if pd.notna(ttd) and ttd < 32:
            reason = "Failed due to term length being under regulatory SLA minimum range            "
    if row["NOTIF_NO_OF_DYS"] == 5 and row["NOTIF_DELVRY_PREF"] == "P":
        if pd.notna(ttd) and ttd < 16:
            reason = "Failed due to term length being under regulatory SLA minimum range            "
    return reason


def find_fails(
    compare_all: pd.DataFrame,
    ctx: Context,
) -> pd.DataFrame:
    """
    Mirrors SAS %find_fails macro.

    Steps:
      1. Identify potential-fail rows.
      2. For SRVC_ID=14: pull mif_14, preferences, merge back.
      3. For SRVC_ID=13: pull mif_13, preferences, merge back.
      4. Apply term-length fail reasons.
      5. For remaining unexplained fails: check preference-change date proximity.
      6. For still-unexplained fails: check backdated arrangement intro.

    Returns the final fail-detail DataFrame.
    """
    fails = compare_all[compare_all["CommentCode"] == "COM19"].copy()

    if fails.empty:
        ctx.log.info("No potential fails found.")
        return fails

    # ---- SRVC_ID = 14 -------------------------------------------------------
    fails14_mask = fails["SRVC_ID"] == 14
    fails14 = fails[fails14_mask]

    fails14_enriched = fails14.copy()

    if not fails14.empty:
        ar14   = fails14["AR_ID"].tolist()
        clnt14 = fails14["CLNT_NO"].tolist()

        mif14 = _fetch_mif14(ctx, ar14, clnt14)
        ctx.log.info("mif_14 rows: %d", len(mif14))

        if not mif14.empty:
            plan14 = mif14["plan_number"].dropna().tolist()
            if plan14:
                plans14 = _fetch_plans(ctx, plan14)
                mif14_pref = _merge_plan_prefs(mif14, plans14)
            else:
                mif14_pref = mif14.copy()

            mif14_pref = mif14_pref.sort_values(["AR_ID", "CLNT_NO"])
            fails14_sorted = fails14.sort_values(["AR_ID", "CLNT_NO"])
            fails14_enriched = fails14_sorted.merge(
                mif14_pref, on=["AR_ID", "CLNT_NO"], how="left", suffixes=("", "_mif14")
            )

    # ---- SRVC_ID = 13 -------------------------------------------------------
    fails13_mask = fails["SRVC_ID"] == 13
    fails13 = fails[fails13_mask]

    fails13_enriched = fails13.copy()

    if not fails13.empty:
        ar13   = fails13["AR_ID"].tolist()
        clnt13 = fails13["CLNT_NO"].tolist()

        mif13 = _fetch_mif13(ctx, ar13, clnt13)
        ctx.log.info("mif_13 rows: %d", len(mif13))

        if not mif13.empty:
            plan13 = mif13["plan_number"].dropna().tolist()
            if plan13:
                plans13 = _fetch_plans(ctx, plan13)
                mif13_pref = _merge_plan_prefs(mif13, plans13)
            else:
                mif13_pref = mif13.copy()

            mif13_pref = mif13_pref.sort_values(["AR_ID", "CLNT_NO"])
            fails13_sorted = fails13.sort_values(["AR_ID", "CLNT_NO"])
            fails13_enriched = fails13_sorted.merge(
                mif13_pref, on=["AR_ID", "CLNT_NO"], how="left", suffixes=("", "_mif13")
            )

    # Combine 13 + 14
    fails_all = pd.concat([fails14_enriched, fails13_enriched], ignore_index=True)

    # ---- Backfill total_term_day from DT_OPEN when missing ------------------
    # SAS: if total_term_day = . then
    #          if srvc_id=14: total_term_day = MTRTY_DT - DT_OPEN_mif14
    #          elif srvc_id=13: total_term_day = MTRTY_DT - DT_OPEN_mif13
    if "DT_OPEN" in fails_all.columns:
        mask_missing = fails_all["total_term_day"].isna()
        mask14 = mask_missing & (fails_all["SRVC_ID"] == 14)
        mask13 = mask_missing & (fails_all["SRVC_ID"] == 13)

        dt_open = pd.to_datetime(fails_all.get("DT_OPEN"), errors="coerce")
        mtrty   = pd.to_datetime(fails_all["MTRTY_DT"], errors="coerce")

        fails_all.loc[mask14, "total_term_day"] = (mtrty - dt_open).dt.days[mask14]
        fails_all.loc[mask13, "total_term_day"] = (mtrty - dt_open).dt.days[mask13]

    # ---- Fail reason: term length -------------------------------------------
    fails_all["fail_reason"] = fails_all.apply(_assign_fail_reason_term, axis=1)

    # ---- Fail reason: pref change too close to notification -----------------
    # SAS: if fail_reason='' and pref_date ne . and
    #         abs(intck('day', pref_date, NOTIF_SENT_DT)) < 9
    if "PREF_CHANGE_TMSTMP" in fails_all.columns:
        fails_all["pref_date"] = pd.to_datetime(
            fails_all["PREF_CHANGE_TMSTMP"], errors="coerce"
        ).dt.normalize()
    else:
        fails_all["pref_date"] = pd.NaT

    notif_sent = pd.to_datetime(fails_all["NOTIF_SENT_DT"], errors="coerce")
    pref_date  = fails_all["pref_date"]

    pref_close_mask = (
        (fails_all["fail_reason"] == "")
        & pref_date.notna()
        & ((notif_sent - pref_date).abs().dt.days < 9)
    )
    fails_all.loc[pref_close_mask, "fail_reason"] = (
        "Failed due to introduction of Paper Pref after regulatory SLA minimum range"
    )

    # ---- Fail reason: backdated arrangement ---------------------------------
    unexplained = fails_all[fails_all["fail_reason"] == ""]
    fails_all["backdate_check"] = pd.NaT

    if not unexplained.empty:
        back_ar = unexplained["AR_ID"].tolist()
        backdated = _fetch_backdates(ctx, back_ar)

        if not backdated.empty:
            backdated["backdate_check"] = pd.to_datetime(backdated["backdate_check"], errors="coerce")
            fails_all = fails_all.merge(backdated, on="AR_ID", how="left", suffixes=("", "_bd"))
            if "backdate_check_bd" in fails_all.columns:
                fails_all["backdate_check"] = fails_all["backdate_check"].fillna(
                    fails_all["backdate_check_bd"]
                )
                fails_all.drop(columns=["backdate_check_bd"], inplace=True)

            backdate_close = (
                (fails_all["fail_reason"] == "")
                & fails_all["backdate_check"].notna()
                & ((notif_sent - fails_all["backdate_check"]).abs().dt.days < 9)
            )
            fails_all.loc[backdate_close, "fail_reason"] = (
                "Failed due to introduction of backdated arrangement id              "
            )

    ctx.log.info("fail_reason distribution:\n%s",
                 fails_all["fail_reason"].value_counts(dropna=False).to_string())
    return fails_all



# Autocomplete (AC) summary table builder — mirrors SAS PROC SQL aggregations


def _snap_date_from_notif(notif_sent: pd.Series) -> pd.Series:
    """
    SAS: intnx('week.7', NOTIF_SENT_DT, 1, 'B')
    week.7 = Monday-aligned week; +1 week; 'B' = beginning.
    → Next Monday after NOTIF_SENT_DT.
    """
    def _next_monday(d: date) -> date:
        days_until_mon = (7 - d.weekday()) % 7
        return d + timedelta(days=days_until_mon if days_until_mon else 7)

    return pd.to_datetime(notif_sent, errors="coerce").dt.date.apply(
        lambda d: _next_monday(d) if pd.notna(d) else pd.NaT
    )


def _build_ac_segment(
    df: pd.DataFrame,
    rde: str,
    segment2: str,   # '5 days' or '21 days'
    segment3: str,   # 'Registered GIC' or 'Non-Registered GIC'
    report_dt: date,
) -> pd.DataFrame:
    """
    Mirror SAS PROC SQL for each of the four AC tables.
    Groups by: CommentCode, thirty_day_ind, deliverypreference,
               Total_days (as string), SNAP_DT month, SnapDate.
    """
    tmp = df.copy()
    tmp["Segment9"]  = tmp["Total_days"].apply(lambda x: str(int(x)) if pd.notna(x) else "")
    tmp["Segment10"] = pd.to_datetime(tmp["SNAP_DT"], errors="coerce").dt.strftime("%Y%m")
    tmp["SnapDate"]  = _snap_date_from_notif(tmp["NOTIF_SENT_DT"])

    grp_cols = [
        "CommentCode", "Comments",
        "thirty_day_ind", "deliverypreference",
        "Segment9", "Segment10", "SnapDate",
    ]
    agg = (
        tmp.groupby(grp_cols, dropna=False, as_index=False)
        .agg(Volume=("AR_ID", "count"))
    )

    agg["RegulatoryName"] = "C86"
    agg["LOB"]            = "PSI"
    agg["ReportName"]     = "C86 Notification Renewals"
    agg["ControlRisk"]    = "Timeliness"
    agg["TestType"]       = "Anomaly"
    agg["TestPeriod"]     = "Portfolio"
    agg["ProductType"]    = "GIC"
    agg["RDE"]            = rde
    agg["SubDE"]          = ""
    agg["Segment"]        = "Renewals"
    agg["Segment2"]       = segment2
    agg["Segment3"]       = segment3
    agg["Segment4"]       = agg["thirty_day_ind"]
    agg["Segment5"]       = agg["deliverypreference"]
    agg["Segment6"]       = ""
    agg["Segment7"]       = ""
    agg["Segment8"]       = ""
    agg["HoldoutFlag"]    = "N"
    agg["Bal"]            = np.nan
    agg["Amount"]         = np.nan
    agg["DateCompleted"]  = report_dt

    return agg[[
        "RegulatoryName", "LOB", "ReportName", "ControlRisk", "TestType",
        "TestPeriod", "ProductType", "RDE", "SubDE",
        "Segment", "Segment2", "Segment3", "Segment4", "Segment5",
        "Segment6", "Segment7", "Segment8", "Segment9", "Segment10",
        "HoldoutFlag", "CommentCode", "Comments",
        "Volume", "Bal", "Amount", "DateCompleted", "SnapDate",
    ]]



# Fail detail output  (mirrors SAS data notidata.rbis_noti_time_fail_wk_&ymd.)


def _clientid_mask(clnt_no: Any) -> str:
    """
    SAS: clientid_mask = substr(CLNT_NO, 7, 3)  (1-based → Python [6:9])
    """
    s = "" if pd.isna(clnt_no) else str(clnt_no)
    return s[6:9] if len(s) >= 9 else s[6:]


def _event_week_ending(notif_sent: pd.Timestamp) -> Any:
    """
    SAS: event_week_ending = intnx('week.7', NOTIF_SENT_DT, 0, 'e')
    week.7 = Monday-aligned; end of that week = Sunday.
    """
    if pd.isna(notif_sent):
        return pd.NaT
    d = notif_sent.date() if hasattr(notif_sent, "date") else notif_sent
    days_until_sun = (6 - d.weekday()) % 7
    return d + timedelta(days=days_until_sun)


def build_fail_detail(fails: pd.DataFrame, report_dt: date) -> pd.DataFrame:
    """
    Mirrors SAS DATA step building notidata.rbis_noti_time_fail_wk_&ymd.
    Only includes rows where Comments = 'Potential Fail'.
    """
    df = fails[fails["Comments"].str.strip() == "Potential Fail"].copy()

    df["event_month"]               = pd.to_datetime(df["NOTIF_SENT_DT"], errors="coerce").dt.strftime("%Y%m")
    df["event_week_ending"]         = pd.to_datetime(df["NOTIF_SENT_DT"], errors="coerce").apply(_event_week_ending)
    df["Notification_Delivery_Type"] = df["deliverypreference"]
    df["Type_of_Notification"]      = df["thirty_day_ind"]
    df["Account_number"]            = df["ACCT_NO"]
    df["Certificate_number"]        = df["CERT_NO"]
    df["Renewal_Date"]              = df["MTRTY_DT"]
    df["renewal_rule"]              = df["NOTIF_NO_OF_DYS"].map({21: "21 days", 5: "5 days "})
    df["clientid_mask"]             = df["CLNT_NO"].apply(_clientid_mask)
    df["date_completed"]            = report_dt
    df["product"]                   = np.where(
        df["RGSTR_NO_RGSTR_IND"] == "N",
        "Non-Registered GIC",
        "Registered GIC ",
    )
    df["lob"] = "PSI"

    keep_cols = [
        "event_month", "event_week_ending", "lob", "product",
        "Type_of_Notification", "NOTIF_NO_OF_DYS", "AR_ID",
        "Notification_Delivery_Type", "clientid_mask",
        "Account_number", "Certificate_number", "Renewal_Date",
        "NOTIF_SENT_DT", "renewal_rule", "date_completed",
        "Total_days", "fail_reason",
        "DT_OPEN_mif14", "DT_OPEN_mif13",
        "pref_date", "backdate_check",
    ]
    available = [c for c in keep_cols if c in df.columns]
    return df[available].reset_index(drop=True)



# History management  (mirrors SAS timeliness macro + proc append)


def update_history(
    history_path: Path,
    curr_df: pd.DataFrame,
    snap_col: str = "SnapDate",
    ini_run: bool = True,
) -> pd.DataFrame:
    """
    Mirrors SAS %timeliness macro:
        initial run  → create fresh table
        subsequent   → drop rows for current SnapDate, append new rows
    """
    curr_df = curr_df.copy()
    curr_df[snap_col] = pd.to_datetime(curr_df[snap_col], errors="coerce")

    if ini_run or not history_path.exists():
        merged = curr_df
    else:
        old = pd.read_csv(history_path, parse_dates=[snap_col])
        old[snap_col] = pd.to_datetime(old[snap_col], errors="coerce")
        new_snaps = set(curr_df[snap_col].dropna().unique())
        old_keep = old[~old[snap_col].isin(new_snaps)]
        merged = pd.concat([old_keep, curr_df], ignore_index=True)

    merged = merged.sort_values(snap_col, na_position="last")
    return merged



# File outputs


def write_outputs(
    ctx: Context,
    ac_curr: pd.DataFrame,
    ac_history: pd.DataFrame,
    fail_detail: pd.DataFrame,
    out_root: Path,
) -> None:
    """Write all SAS-equivalent export files."""
    out_root.mkdir(parents=True, exist_ok=True)

    # SAS: proc export outfile="&outpath/renew_gic_autocomplete" sheet="renew_gio_autocomplete"
    ac_xlsx = out_root / "renew_gic_autocomplete.xlsx"
    ac_history.to_excel(ac_xlsx, sheet_name="renew_gio_autocomplete", index=False)
    ctx.log.info("Wrote AC history: %s (%d rows)", ac_xlsx, len(ac_history))

    # SAS: proc export outfile="&outpath/Notif_RBIS_Renew_Timeliness_Detail" sheet="Notif_RBIS_Renew_Time"
    fail_xlsx = out_root / f"Notif_RBIS_Renew_Timeliness_Detail_{ctx.d.ymd}.xlsx"
    fail_detail.to_excel(fail_xlsx, sheet_name="Notif_RBIS_Renew_Time", index=False)
    ctx.log.info("Wrote fail detail: %s (%d rows)", fail_xlsx, len(fail_detail))

    # Persistent history CSV  (mirrors notidata.renew_gic_ac SAS dataset)
    csv_path = out_root / "renew_gic_ac.csv"
    ac_history.to_csv(csv_path, index=False)
    ctx.log.info("Wrote history CSV: %s (%d rows)", csv_path, len(ac_history))



# Orchestration


def build_context() -> Context:
    """Wire config, logger, Trino connection, and dates."""
    conf = load_config(Path("config.ini"))

    log_root = Path(conf["log_root"])
    # Temporary logger before dates are computed
    tmp_log = setup_logger(log_root / "c86_rbis_renewal_startup.log")

    d = compute_dates()   # ini_run/day_buff resolved after history check

    log_path = log_root / f"C86_notification_rbis_{d.ymd}.log"
    logger = setup_logger(log_path)

    logger.info("Program: C86_notif_rbis_renewal.py")
    logger.info("User   : %s", os.getenv("USER", "unknown"))
    logger.info("Host   : %s", os.uname().nodename)
    logger.info("Catalog: %s | Schema: %s", conf["catalog"], conf["schema"])
    logger.info("wk_start=%s  wk_end=%s  mat_dt=%s  back_dt=%s",
                d.wk_start, d.wk_end, d.mat_dt_q, d.back_dt_q)

    conn = get_conn(conf)
    return Context(conf=conf, d=d, conn=conn, log=logger)


def main() -> int:
    ctx = build_context()

    out_root     = Path(ctx.conf["out_root"])
    history_path = out_root / "renew_gic_ac.csv"

    # ---- Initial-run detection (SAS %ini_check) ----------------------------
    ini_run, day_buff = detect_ini_run(history_path, ctx)
    ctx.log.info("ini_run=%s  day_buff=%d", ini_run, day_buff)

    # Recompute dates with correct ini_run flag
    d = compute_dates(today=ctx.d.run_dt, ini_run=ini_run)
    ctx.log.info("Effective wk_start=%s  wk_end=%s", d.wk_start, d.wk_end)

    # Replace dates in context (dataclass is frozen → rebuild)
    ctx = Context(conf=ctx.conf, d=d, conn=ctx.conn, log=ctx.log)

    # ---- Build memory base table -------------------------------------------
    drop_memory_tables(ctx)
    build_base_memory_table(ctx)

    # ---- Pull base into pandas ---------------------------------------------
    base = fetch_df(ctx, f"SELECT * FROM {mem_fqtn(ctx, 'rbis_noti_base_m')}")
    ctx.log.info("rbis_noti_base rows: %d", len(base))

    if base.empty:
        ctx.log.warning("No base data for date window — nothing to process.")
        return 0

    # Normalize column names (Trino returns lower-case)
    base.columns = [c.upper() for c in base.columns]

    # ---- Classify pass/fail, split segments --------------------------------
    classified = classify_base(base)
    segments   = split_segments(classified)
    all_compare = pd.concat(segments.values(), ignore_index=True)

    ctx.log.info(
        "Segment sizes — reg_05:%d  reg_21:%d  nonreg_05:%d  nonreg_21:%d",
        len(segments["reg_05"]), len(segments["reg_21"]),
        len(segments["nonreg_05"]), len(segments["nonreg_21"]),
    )

    # ---- Build fail detail with reason codes --------------------------------
    fails_final = find_fails(all_compare, ctx)

    # ---- Build AC summary tables (4 segments) ------------------------------
    ac_parts = [
        _build_ac_segment(segments["reg_05"],    "Notif014_Timeliness_SLA", "5 days",  "Registered GIC",     d.run_dt),
        _build_ac_segment(segments["reg_21"],    "Notif013_Timeliness_SLA", "21 days", "Registered GIC",     d.run_dt),
        _build_ac_segment(segments["nonreg_05"], "Notif016_Timeliness_SLA", "5 days",  "Non-Registered GIC", d.run_dt),
        _build_ac_segment(segments["nonreg_21"], "Notif015_Timeliness_SLA", "21 days", "Non-Registered GIC", d.run_dt),
    ]
    ac_curr = pd.concat(ac_parts, ignore_index=True)

    # ---- History update (SAS %timeliness) -----------------------------------
    ac_history = update_history(history_path, ac_curr, ini_run=ini_run)

    # ---- Fail detail rows for export ----------------------------------------
    fail_detail = build_fail_detail(fails_final, d.run_dt)
    ctx.log.info("Fail detail rows: %d", len(fail_detail))

    # Diagnostic freq table (SAS: proc freq data=rbis_noti_compare_fails_final; tables fail_reason)
    if not fails_final.empty:
        ctx.log.info("fail_reason freq:\n%s",
                     fails_final["fail_reason"].value_counts(dropna=False).to_string())

    # ---- Write outputs ------------------------------------------------------
    write_outputs(ctx, ac_curr, ac_history, fail_detail, out_root)

    ctx.log.info("DONE — %s", ctx.d.ymd)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
