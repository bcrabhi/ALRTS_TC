# Logging helpers


def setup_logging(log_path: Path, log_file_name: str) -> Path:
    """Configure file + console logging, mirroring SAS proc printto."""
    log_path.mkdir(parents=True, exist_ok=True)
    log_file = log_path / log_file_name

    for handler in logging.root.handlers[:]:
        logging.root.removeHandler(handler)

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s - %(levelname)s - %(message)s",
        handlers=[
            logging.FileHandler(log_file),
            logging.StreamHandler(sys.stdout),
        ],
    )
    logging.info("Logging configured. Log file: %s", log_file)
    return log_file



# S3 / Spark helpers


def configure_s3a(spark: SparkSession) -> None:
    """Wire up S3A filesystem settings on the active SparkSession."""
    hconf = spark.sparkContext._jsc.hadoopConfiguration()
    hconf.set("fs.s3a.endpoint",               S3_ENDPOINT)
    hconf.set("fs.s3a.connection.ssl.enabled", "true")
    hconf.set("fs.s3a.path.style.access",      "true")
    hconf.set("fs.s3a.impl",                   "org.apache.hadoop.fs.s3a.S3AFileSystem")


def s3_path(folder: str, *parts: str) -> str:
    """Build a fully-qualified S3 URI from a folder key and path parts."""
    base = S3_FOLDERS.get(folder, folder)
    return "/".join([base.rstrip("/")] + list(parts))


def upload_file_to_s3(spark: SparkSession, local_path: str, s3_uri: str) -> None:
    """Copy a local file to S3 using Hadoop FileSystem API (no boto3 keys needed)."""
    sc  = spark.sparkContext
    jvm = sc._jvm
    conf = sc._jsc.hadoopConfiguration()

    local_fs_path = jvm.org.apache.hadoop.fs.Path(f"file://{os.path.abspath(local_path)}")
    s3_fs_path    = jvm.org.apache.hadoop.fs.Path(s3_uri)
    fs = s3_fs_path.getFileSystem(conf)
    fs.copyFromLocalFile(False, True, local_fs_path, s3_fs_path)
    logging.info("Uploaded %s -> %s", local_path, s3_uri)


def _normalize_column_types(df: pd.DataFrame) -> pd.DataFrame:
    """
    Coerce mixed column types so that Spark createDataFrame does not choke.
    Mirrors the SAS implicit type handling before dataset writes.
    """
    date_cols   = ("DateCompleted", "SnapDate")
    string_cols = (
        "RegulatoryName", "LOB", "ReportName", "ControlRisk",
        "TestType", "TestPeriod", "ProductType", "RDE",
        "HoldoutFlag", "CommentCode", "Comments",
    )
    numeric_cols = ("Volume", "Amount")

    for col in df.columns:
        if col in date_cols:
            df[col] = pd.to_datetime(df[col], errors="coerce")
        elif col.startswith("Segment") or col.startswith("segment") or col in string_cols:
            df[col] = df[col].fillna("").astype(str)
        elif col in numeric_cols:
            df[col] = pd.to_numeric(df[col], errors="coerce")

    # Catch remaining object columns
    for col in df.columns:
        if df[col].dtype == "object":
            sample = df[col].dropna().head(1)
            if len(sample) > 0 and isinstance(sample.iloc[0], date):
                df[col] = pd.to_datetime(df[col], errors="coerce")
            else:
                df[col] = df[col].fillna("").astype(str)

    return df


def write_parquet_to_s3(spark: SparkSession, df: pd.DataFrame, s3_uri: str) -> None:
    """Write a pandas DataFrame to S3 as parquet via PySpark."""
    df = _normalize_column_types(df.copy())
    sdf = spark.createDataFrame(df)
    sdf.write.mode("overwrite").parquet(s3_uri)
    logging.info("Wrote parquet -> %s", s3_uri)


def s3_file_exists(spark: SparkSession, s3_uri: str) -> bool:
    """Check whether an S3 path exists using Hadoop FileSystem API."""
    sc  = spark.sparkContext
    jvm = sc._jvm
    path = jvm.org.apache.hadoop.fs.Path(s3_uri)
    fs   = path.getFileSystem(sc._jsc.hadoopConfiguration())
    return fs.exists(path)



# Teradata connection


def get_teradata_connection(conn_file: Path) -> teradatasql.TeradataConnection:
    """
    Open a Teradata connection using credentials from a JSON file.
    Mirrors SAS %connectsql / disconnect from teradata pattern.
    """
    if not conn_file.exists():
        raise FileNotFoundError(f"Teradata connection file not found: {conn_file.resolve()}")

    with open(conn_file, "r", encoding="utf-8") as fh:
        creds = json.load(fh)

    host = creds["url"]
    user = creds["user"]
    pwd  = creds["password"]

    logging.info("Connecting to Teradata host=%s user=%s (LDAP)...", host, user)
    try:
        conn = teradatasql.connect(host=host, user=user, password=pwd, logmech="LDAP")
        logging.info("Teradata connection established.")
        return conn
    except Exception as exc:
        logging.error("Teradata connection failed: %s", exc)
        raise



# Date / ini-run logic  (mirrors SAS data _null_ + %ini_check macro)


def _format_sql_date(dt: date) -> str:
    """Return a SQL-ready quoted date string: '2024-06-01'."""
    return f"'{dt.strftime('%Y-%m-%d')}'"


def check_ini_run(
    spark: SparkSession,
    outpath: Path,
    persistent_ac_file: str,
) -> Tuple[str, int]:
    """
    Replicate SAS %ini_check macro.

    Returns
    -------
    ini_run : 'Y' (first run) or 'N' (incremental)
    day_buff : days since last snapshot (used to bound the date window)
    """
    local_ac = outpath / persistent_ac_file
    s3_ac    = s3_path("output", persistent_ac_file)

    exists_locally = local_ac.exists()
    exists_s3      = s3_file_exists(spark, s3_ac)

    if exists_locally or exists_s3:
        logging.info("Existing autocomplete file found — incremental run (ini_run='N').")

        # Back up local copy
        if exists_locally:
            backup = outpath / f"{local_ac.stem}_backup{local_ac.suffix}"
            shutil.copy(local_ac, backup)
            logging.info("Backed up autocomplete file to %s", backup)

        # Calculate day_buff from max(SnapDate) in the existing dataset
        if exists_locally:
            ac_df = pd.read_parquet(local_ac)
        else:
            ac_df = pd.read_parquet(s3_ac)  # if only on S3

        max_snap = pd.to_datetime(ac_df["SnapDate"], errors="coerce").max()
        if pd.isna(max_snap):
            day_buff = 1
        else:
            day_buff = (date.today() - max_snap.date()).days

        logging.info("day_buff (days since last snap) = %d", day_buff)
        return "N", day_buff

    logging.info("No autocomplete file found — initial run (ini_run='Y').")
    return "Y", 1


def setup_dates(ini_run: str, day_buff: int) -> Dict[str, str]:
    """
    Replicate SAS data _null_ date calculation block.

    Mirrors:
        week_end  = intnx('week.3', today(), -0) - 3   → last Saturday
        week_start = week_end - 6                       → last Sunday
        matdt     = week_end + 36
        back_dt   = week_start - 20
        launch_dt = '01JUL2022'd
    """
    today       = date.today()
    launch_dt   = date(2022, 7, 1)

    # week.3 in SAS = week anchored on Tuesday; intnx(..., -0) = current period
    # The result week_end = that Tuesday - 3 = last Saturday
    days_since_tuesday = (today.weekday() - 1) % 7   # Monday=0, Tuesday=1
    this_tuesday  = today - timedelta(days=days_since_tuesday)
    week_end_dt   = this_tuesday - timedelta(days=3)  # Saturday

    if ini_run == "Y":
        week_start_dt = launch_dt
    else:
        runday_dt     = today
        candidate     = runday_dt - timedelta(days=day_buff)
        week_start_dt = max(candidate, launch_dt)

    mat_dt       = week_end_dt  + timedelta(days=36)
    back_dt      = week_start_dt - timedelta(days=20)
    me_dt        = (today.replace(day=1) - timedelta(days=1))  # month-end last month

    dates = {
        "wk_start":  _format_sql_date(week_start_dt),
        "wk_end":    _format_sql_date(week_end_dt),
        "mat_dt":    _format_sql_date(mat_dt),
        "back_dt":   _format_sql_date(back_dt),
        "me_dt":     _format_sql_date(me_dt),
        "today2":    today.strftime("%Y-%m-%d"),
        "rundt":     today.strftime("%Y%m%d"),
        "sasdt2":    week_end_dt.strftime("%Y-%m-%d"),   # used in timeliness filter
        "week_end_dt": week_end_dt,                      # raw date object for Python logic
    }

    for key, val in dates.items():
        logging.info("Date param  %s = %s", key, val)

    return dates



