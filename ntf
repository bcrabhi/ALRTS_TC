def pull_base_notifications(conn: teradatasql.TeradataConnection, dates: Dict[str, str]) -> pd.DataFrame:
    """
    Pull raw renewal notification rows from Teradata and apply BSC filter.

    Mirrors:
        create table rbis_noti_base_init (Teradata pass-through)
        data rbis_noti_base; if bsc >= 600 and bsc <= 690;
    """
    sql = SQL_BASE.format(wk_start=dates["wk_start"], wk_end=dates["wk_end"])
    logging.info("Pulling base notification data from Teradata...")
    df = pd.read_sql(sql, conn)
    logging.info("Loaded %d rows from ddwv01.RENW_NOTIF.", len(df))

    # BSC filter (mirrors: if bsc >= 600 and bsc <= 690)
    df["BSC"] = pd.to_numeric(df["BSC"], errors="coerce")
    df = df[(df["BSC"] >= 600) & (df["BSC"] <= 690)].copy()
    logging.info("After BSC filter (600-690): %d rows.", len(df))

    # Sort to match PROC SORT
    df = df.sort_values(["CLNT_NO", "AR_ID", "MTRTY_DT", "NOTIF_NO_OF_DYS"]).reset_index(drop=True)
    return df



# Step 2 — Apply pass/fail logic and split into four segment tables
# (mirrors the DATA step that outputs rbis_noti_compare_reg/nonreg _05/_21)


def _delivery_preference_label(pref: str) -> str:
    """Mirror SAS format for NOTIF_DELVRY_PREF."""
    if pref == "E":
        return "OLB Notification"
    if pref == "P":
        return "Mail"
    return "Other"


def _thirty_day_ind(total_term_day: Optional[float]) -> str:
    """Mirror SAS thirty_day_ind logic."""
    if total_term_day is None or np.isnan(total_term_day):
        return "Renewals > 30 days"
    if total_term_day > 30:
        return "Renewals > 30 days"
    if 0 <= total_term_day <= 30:
        return "Renewals <= 30 days"
    return "Renewals > 30 days"


def _pass_fail(row: pd.Series) -> Tuple[str, str]:
    """
    Determine pass/fail based on NOTIF_NO_OF_DYS, NOTIF_DELVRY_PREF, and
    the difference between maturity date and notification sent date.

    Updated thresholds (Jun 2025) include Electronic channel logic:
        21-day / Mail  : Total_days in [32, 36] → Pass
        21-day / Other : Total_days in [22, 26] → Pass
         5-day / Mail  : Total_days in [16, 20] → Pass
         5-day / Other : Total_days in [ 6, 10] → Pass
    """
    days    = row["Total_days"]
    n_days  = row["NOTIF_NO_OF_DYS"]
    is_mail = row["NOTIF_DELVRY_PREF"] == "P"

    if n_days == 21:
        lo, hi = (32, 36) if is_mail else (22, 26)
    elif n_days == 5:
        lo, hi = (16, 20) if is_mail else (6, 10)
    else:
        return "COM19", "Potential Fail        "

    if lo <= days <= hi:
        return "COM16", "Pass                  "
    return "COM19", "Potential Fail        "


def apply_business_rules(df: pd.DataFrame) -> pd.DataFrame:
    """
    Apply SLA pass/fail logic, derive segment columns, and return the enriched
    DataFrame.  Mirrors the large DATA step before the four output datasets.
    """
    df = df.copy()

    # Delivery preference label
    df["deliverypreference"] = df["NOTIF_DELVRY_PREF"].apply(_delivery_preference_label)

    # Keep only RENW_PROD_NOTIF_TYP = 2 and drop SEP_DISCLSR_IND = 'N'
    df = df[df["RENW_PROD_NOTIF_TYP"] == 2].copy()
    df = df[df["SEP_DISCLSR_IND"] != "N"].copy()

    # Static annotation columns
    df["RegulatoryName"] = "C86"
    df["LOB"]            = "PSI"
    df["ReportName"]     = "C86 Notification Renewals"
    df["ProductType"]    = "GIC"

    # Date arithmetic (mirrors: Total_days = MTRTY_DT - NOTIF_SENT_DT)
    df["MTRTY_DT"]       = pd.to_datetime(df["MTRTY_DT"],       errors="coerce")
    df["NOTIF_SENT_DT"]  = pd.to_datetime(df["NOTIF_SENT_DT"],  errors="coerce")
    df["Total_days"]     = (df["MTRTY_DT"] - df["NOTIF_SENT_DT"]).dt.days

    # Pass/fail codes
    pf = df.apply(_pass_fail, axis=1, result_type="expand")
    pf.columns = ["CommentCode", "Comments"]
    df = pd.concat([df.reset_index(drop=True), pf.reset_index(drop=True)], axis=1)

    # Total term day (mirrors: if SRVC_ID=14 … else if SRVC_ID=13)
    df["TRM_YRS_14"]           = pd.to_numeric(df["TRM_YRS_14"],           errors="coerce")
    df["TRM_DAYS_14"]          = pd.to_numeric(df["TRM_DAYS_14"],          errors="coerce")
    df["DEP_TERM_IN_YRS_13"]   = pd.to_numeric(df["DEP_TERM_IN_YRS_13"],   errors="coerce")
    df["DEP_TERM_IN_DAYS_13"]  = pd.to_numeric(df["DEP_TERM_IN_DAYS_13"],  errors="coerce")

    cond14 = df["SRVC_ID"] == 14
    cond13 = df["SRVC_ID"] == 13
    df["total_term_day"] = np.where(
        cond14,
        df["TRM_YRS_14"] * 365 + df["TRM_DAYS_14"],
        np.where(
            cond13,
            df["DEP_TERM_IN_YRS_13"] * 365 + df["DEP_TERM_IN_DAYS_13"],
            np.nan,
        ),
    )

    df["thirty_day_ind"] = df["total_term_day"].apply(_thirty_day_ind)

    return df


def split_segments(df: pd.DataFrame) -> Dict[str, pd.DataFrame]:
    """
    Split the enriched base table into four segment DataFrames.
    Mirrors the four output statements in the SAS DATA step:
        rbis_noti_compare_reg_05 / _21
        rbis_noti_compare_nonreg_05 / _21
    """
    masks = {
        "reg_05":    (df["RGSTR_NO_RGSTR_IND"] == "R") & (df["NOTIF_NO_OF_DYS"] == 5),
        "reg_21":    (df["RGSTR_NO_RGSTR_IND"] == "R") & (df["NOTIF_NO_OF_DYS"] == 21),
        "nonreg_05": (df["RGSTR_NO_RGSTR_IND"] == "N") & (df["NOTIF_NO_OF_DYS"] == 5),
        "nonreg_21": (df["RGSTR_NO_RGSTR_IND"] == "N") & (df["NOTIF_NO_OF_DYS"] == 21),
    }
    segments: Dict[str, pd.DataFrame] = {key: df[mask].copy() for key, mask in masks.items()}
    for key, seg in segments.items():
        logging.info("Segment %s: %d rows.", key, len(seg))
    return segments



