def fix_permissions_and_scan_log(cfg: Config, log_file: Path) -> None:

    # find ... -mmin -720 -exec chmod 777 {} \;  (files modified in last 12h)
    cutoff = datetime.now() - timedelta(minutes=720)
    chmod_count = 0
    if cfg.regpath.exists():
        for root, dirs, files in os.walk(cfg.regpath):
            for name in files:
                fpath = Path(root) / name
                try:
                    mtime = datetime.fromtimestamp(fpath.stat().st_mtime)
                    if mtime >= cutoff:
                        os.chmod(fpath, 0o777)
                        chmod_count += 1
                except OSError as e:
                    logging.warning("Could not chmod %s: %s", fpath, e)
    logging.info(
        "Permission fixup: chmod 777 applied to %d files modified in the "
        "last 720 minutes under %s.", chmod_count, cfg.regpath,
    )

    # %ScanLog(&logfile) -- best-effort log scan (see caveat in docstring)
    error_lines: List[str] = []
    warning_lines: List[str] = []
    try:
        with open(log_file, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                if "ERROR" in line:
                    error_lines.append(line.strip())
                elif "WARNING" in line:
                    warning_lines.append(line.strip())
    except OSError as e:
        logging.warning("Could not scan log file %s: %s", log_file, e)
        return

    logging.info(
        "ScanLog summary: %d ERROR line(s), %d WARNING line(s) found in %s.",
        len(error_lines), len(warning_lines), log_file,
    )
    if error_lines:
        logging.warning("ScanLog detected ERROR-level lines:\n%s", "\n".join(error_lines))



