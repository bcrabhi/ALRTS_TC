# %skip macro -> run_skip_block()  (dev/QA scaffolding, opt-in only)


def run_skip_block(
    rbis_noti_base: pd.DataFrame,
    rbis_noti_compare01: pd.DataFrame,
    renew_gic_ac_curr: pd.DataFrame,
    notidata_renew_gic_ac: pd.DataFrame,
    out_dir: Path,
) -> None:
    """Replicates the SAS `%macro skip; ... %mend skip;` block.

    This macro is DEFINED but never INVOKED (`%skip;`) in the source SAS
    script -- it is dev/UAT scaffolding (ad-hoc PROC FREQs, a 25-row
    survey sample export, and a hardcoded test-date row delete against
    '02SEP2022'd). Ported here as an explicit opt-in debug/QA routine so it
    is not silently dropped, but it is NOT called by `main()` by default --
    mirroring the SAS behaviour where the macro exists in the source but
    is dormant unless someone adds a `%skip;` call.

    Several sub-pieces of the original SAS %skip block reference datasets/
    libnames not defined anywhere else in this script (`rmtwork.*`), which
    confirms this is leftover/inactive scaffolding rather than load-bearing
    logic -- those `%commexp` calls are reproduced as best-effort exports of
    the closest equivalent in-scope frames, clearly labeled, rather than
    invented from nothing.

    Call this manually for ad-hoc QA, e.g.:
        run_skip_block(rbis_noti_base, rbis_noti_compare01,
                        renew_gic_ac_curr, notidata_renew_gic_ac,
                        Path("./qa_output"))
    """
    out_dir.mkdir(parents=True, exist_ok=True)
    logging.info("Running %%skip QA block (opt-in debug routine)...")

    # proc surveyselect ... method=srs sampsize=25;
    sample_n = min(25, len(rbis_noti_compare01))
    rbis_noti_samp = rbis_noti_compare01.sample(
        n=sample_n, random_state=None
    ) if sample_n > 0 else rbis_noti_compare01.copy()

    # %commexp(...) -> ad-hoc xlsx exports of the closest in-scope equivalents
    # NOTE: SAS referenced rmtwork.rbis_noti_base / rmtwork.rbis_noti_compare /
    # rmtwork.rbis_noti_samp / rmtwork.renew_gic_ac_curr /
    # rmtwork.RBIS_NOTI_COMPARE_check -- `rmtwork` is not a libname defined
    # anywhere in this script, so these exports were already broken/inactive
    # in the SAS source. Reproduced here against the analogous in-memory
    # frames that *are* in scope, for QA convenience only.
    rbis_noti_base.to_excel(out_dir / "rbis_noti_base.xlsx", index=False)
    rbis_noti_compare01.to_excel(out_dir / "rbis_noti_compare.xlsx", index=False)
    rbis_noti_samp.to_excel(out_dir / "rbis_noti_samp.xlsx", index=False)
    renew_gic_ac_curr.to_excel(out_dir / "renew_gic_ac.xlsx", index=False)

    # proc freq data = rbis_noti_compare01; tables RENW_PROD_NOTIF_TYP; run;
    if "RENW_PROD_NOTIF_TYP" in rbis_noti_compare01.columns:
        logging.info(
            "PROC FREQ RENW_PROD_NOTIF_TYP:\n%s",
            rbis_noti_compare01["RENW_PROD_NOTIF_TYP"].value_counts(dropna=False),
        )

    # proc freq data = rbis_noti_compare01; tables SRVC_ID; run;
    if "SRVC_ID" in rbis_noti_compare01.columns:
        logging.info(
            "PROC FREQ SRVC_ID:\n%s",
            rbis_noti_compare01["SRVC_ID"].value_counts(dropna=False),
        )

    # proc sql; create table thirty_day_test as
    #   select case when total_term_day between 0 and 30 then '...'
    #               when total_term_day > 30 or total_term_day = . then '...'
    #               else 'other' end as term_date_calc,
    #          thirty_day_ind, SRVC_ID, count(ar_id)
    #   from rbis_noti_compare01 group by 1,2,3 order by 1,2,3;
    ttd = rbis_noti_compare01["TOTAL_TERM_DAY"]
