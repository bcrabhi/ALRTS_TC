# Logging


def setup_logging(log_path: Path, log_file_name: str) -> Path:
    """Mirrors SAS `proc printto log=&logfile print=&lstfile new；`."""
    log_path.mkdir(parents=True, exist_ok=True)
    log_file = log_path / log_file_name

    for handler in logging.root.handlers[:]:
        logging.root.removeHandler(handler)

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s - %(levelname)s - %(message)s",
        handlers=[logging.FileHandler(log_file), logging.StreamHandler()],
    )
    logging.info("Logging configured. Log file: %s", log_file)
    return log_file



# Teradata connectivity (mirrors C86_pa_client360.py reference)


def get_teradata_connection(conn_file: Path) -> "teradatasql.TeradataConnection":
    """Open a Teradata connection via LDAP using credentials from JSON.

    SAS source: %include "&cdepath/common/security/pswd.sas"; + %connectsql
    """
    if not conn_file.exists():
        logging.error("Connection file not found at: %s", conn_file.resolve())
        raise FileNotFoundError(
            "Connection file not found at: {}".format(conn_file.resolve())
        )

    with open(conn_file, "r", encoding="utf-8") as f:
        conn_details = json.load(f)

    url = conn_details.get("url")
    user = conn_details.get("user")
    pwd = conn_details.get("password")

    logging.info("Connecting to Teradata URL: %s with user: %s using LDAP...", url, user)
    try:
        conn = teradatasql.connect(host=url, user=user, password=pwd, logmech="LDAP")
        logging.info("Teradata connection successful.")
        return conn
    except Exception as e:
        logging.error("Failed to connect to Teradata: %s", e)
        raise



# %ini_check macro -> check_ini_run()


def check_ini_run(outpath: Path, persistent_ac_filename: str) -> Tuple[str, int]:
    """Replicates the SAS %ini_check macro.

    SAS source:
        %macro ini_check;
        %if %sysfunc(fileexist(&outpath/renew_gic_ac.sas7bdat)) %then %do;
            %let ini_run = 'N';
            x cp "&outpath/renew_gic_ac.sas7bdat" "&outpath/renew_gic_ac_backup.sas7bdat";
            proc sql;
                select &runday - max(SnapDate) into: day_buff
                from notidata.renew_gic_ac
                ;
            quit;
            %end;
        %else %do;
            %let ini_run = 'Y';
            %let day_buff = 1;
        %end;
        %mend;

    Returns:
        (ini_run, day_buff) where ini_run is 'Y' or 'N' and day_buff is the
        integer day gap between today (runday) and the max SnapDate in the
        existing persistent autocomplete table (or 1 if no prior file).
    """
    persistent_file = Path(outpath) / persistent_ac_filename
    backup_file = Path(outpath) / "{}_backup{}".format(
        persistent_file.stem, persistent_file.suffix
    )

    if persistent_file.exists():
        logging.info("Found existing autocomplete file: %s", persistent_file)
        ini_run = "N"
        try:
            shutil.copy(persistent_file, backup_file)
            logging.info("Backed up to: %s", backup_file)
        except Exception as e:
            logging.warning("Could not create backup of autocomplete file: %s", e)

        runday = date.today()
        existing = pd.read_parquet(persistent_file)
        if "SnapDate" in existing.columns and len(existing) > 0:
            max_snap = pd.to_datetime(existing["SnapDate"], errors="coerce").max()
            if pd.isna(max_snap):
                day_buff = 1
            else:
                day_buff = (runday - max_snap.date()).days
        else:
            day_buff = 1
    else:
        logging.info("Autocomplete file not found. Setting ini_run = 'Y'.")
        ini_run = "Y"
        day_buff = 1

    logging.info("ini_run=%s, day_buff=%s", ini_run, day_buff)
    return ini_run, day_buff



# data _null_ date setup block -> setup_dates()


def _week3_anchor(d: date) -> date:
    """SAS intnx('week.3', d, -0): most recent Tuesday on/before d.

    SAS WEEK intervals default to starting on Sunday (shift point 1).
    Shift point 3 moves the interval start to Tuesday (1=Sun, 2=Mon, 3=Tue).
    With default 'beginning' alignment and increment 0, intnx returns the
    start (Tuesday) of the WEEK.3 interval containing d.
    Python date.weekday(): Mon=0 ... Sun=6; Tuesday=1.
    """
    delta = (d.weekday() - 1) % 7
    return d - timedelta(days=delta)


def _week7_anchor(d: date, n: int = 0, align: str = "b") -> date:
    """SAS intnx('week.7', d, n, align): Saturday-anchored week interval.

    Shift point 7 moves the interval start to Saturday (1=Sun,...,7=Sat).
    align='b' (beginning) -> Saturday start of interval, shifted by n weeks.
    align='e' (end)       -> Friday end of interval, shifted by n weeks.
    Python date.weekday(): Saturday=5.
    """
    delta = (d.weekday() - 5) % 7
    start = d - timedelta(days=delta) + timedelta(weeks=n)
    align = align.lower()
    if align in ("b", "beginning"):
        return start
    if align in ("e", "end"):
        return start + timedelta(days=6)
    raise ValueError("Unsupported alignment: {}".format(align))


def setup_dates(cfg: Config, ini_run: str, day_buff: int) -> Dict[str, object]:
    """Replicates the SAS `data _null_;` date-setup block.

    SAS source (key lines):
        tday2=intnx('day',today(),-0);
        startday=intnx('day',today(),-10);
        tday=intnx('week.3',today(),-0);          /* Every Tuesday run */
        launch_dt='01JUL2022'd;
        ongoing_start = ifn(&ini_run = 'Y', launch_dt, max(&runday-&day_buff., launch_dt));
        medate = intnx('month',today(),-1,'E');
        week_end = tday - 3;                       /* Ends on every Saturday */
        if &ini_run = 'N' then week_start = week_end - 6;  /* Start on last Sunday */
        else week_start = ongoing_start;
        matdt = week_end + 36;
        back_date_limit = week_start - 20;

    Returns a dict of derived date values (as `date` objects, plus a few
    pre-formatted strings/SQL literals) matching every SAS macro variable
    produced by the `call symput(...)` statements.
    """
    today = date.today()
    runday = today

    tday2 = today
    startday = today - timedelta(days=10)
    tday = _week3_anchor(today)

    week_end = tday - timedelta(days=3)

    # ongoing_start = ifn(ini_run='Y', launch_dt, max(runday - day_buff, launch_dt))
    candidate = runday - timedelta(days=day_buff)
    ongoing_start = cfg.launch_dt if ini_run.upper() == "Y" else max(candidate, cfg.launch_dt)

    # medate = intnx('month', today(), -1, 'E') -> last day of previous month
    first_of_this_month = today.replace(day=1)
    last_day_prev_month = first_of_this_month - timedelta(days=1)
    medate = last_day_prev_month

    if ini_run.upper() == "N":
        week_start = week_end - timedelta(days=6)
    else:
        week_start = ongoing_start

    matdt = week_end + timedelta(days=36)
    back_date_limit = week_start - timedelta(days=20)

    def sql_date(d: date) -> str:
        """Format a Python date as a quoted Teradata DATE literal: 'YYYY-MM-DD'."""
        return "'{}'".format(d.strftime("%Y-%m-%d"))

    dates: Dict[str, object] = {
        "wk_start": week_start,
        "wk_end": week_end,
        "today2": tday2,
        "me_dt": medate,
        "rundt": runday.strftime("%Y%m%d"),
        "str_dt": startday,
        "mat_dt": matdt,
        "back_dt": back_date_limit,
        # SQL literal strings for embedding directly in Teradata SQL text,
        # preserving the SAS pattern of quoted date literals in the query.
        "wk_start_sql": sql_date(week_start),
        "wk_end_sql": sql_date(week_end),
        "mat_dt_sql": sql_date(matdt),
        "back_dt_sql": sql_date(back_date_limit),
    }

    logging.info("wk_start=%s", dates["wk_start"])
    logging.info("wk_end=%s", dates["wk_end"])
    logging.info("today2=%s", dates["today2"])
    logging.info("me_dt=%s", dates["me_dt"])
    logging.info("rundt=%s", dates["rundt"])
    logging.info("str_dt=%s", dates["str_dt"])
    logging.info("mat_dt=%s", dates["mat_dt"])
    logging.info("back_dt=%s", dates["back_dt"])

    return dates



# Main Teradata pull: rbis_noti_base_init  (SAS: proc sql; create table ... )


def pull_rbis_noti_base(cfg: Config, dates: Dict[str, object]) -> pd.DataFrame:
    """Replicates the main `rbis_noti_base_init` Teradata pull.

    SAS SQL preserved verbatim (only &wk_start./&wk_end. are parameterized).
    """
    sql = """
select
    RENW_NOTIF.CLNT_NO,
    RENW_NOTIF.CLNT_AR_OWN_TYP,
    RENW_NOTIF.ACCT_NO,
    RENW_NOTIF.SEG_NO,
    RENW_NOTIF.ACCT_TR_NO,
    RENW_NOTIF.PROD_NM,
    RENW_NOTIF.PROD_TRM_IN_YR,
    RENW_NOTIF.PROD_TRM_IN_DYS,
    RENW_NOTIF.MTRTY_DT,
    RENW_NOTIF.CERT_NO,
    RENW_NOTIF.FND_NO,
    RENW_NOTIF.ACCT_TYP,
    RENW_NOTIF.NOTIF_SENT_DT,
    RENW_NOTIF.AR_ID,
    RENW_NOTIF.SRVC_ID,
    RENW_NOTIF.RENW_PROD_NOTIF_TYP,
    RENW_NOTIF.SNAP_DT,
    RENW_NOTIF.CLNT_SYS_SRC_ID,
    RENW_NOTIF.CO_OWN_CLNT_NO,
    RENW_NOTIF.RGSTR_NO_RGSTR_IND,
    RENW_NOTIF.SEP_DISCLSR_IND,
    RENW_NOTIF.NOTIF_NO_OF_DYS,
    RENW_NOTIF.NOTIF_DELVRY_PREF,
    RB_CLNT_DLY.BSC,
    AR_DLY.DT_OPEN as DT_OPEN_mif14,
    AR_STATIC_DLY.DT_OPEN as DT_OPEN_mif13,
    TRM_INVSTMT_HLDNG_DLY.DEP_TERM_IN_DAYS    as TRM_DAYS_14,
    TRM_INVSTMT_HLDNG_DLY.DEP_TERM_IN_YRS     as TRM_YRS_14,
    INVSTMT_HLDNG_DLY_DELTA.DEP_TERM_IN_YRS   as DEP_TERM_IN_YRS_13,
    INVSTMT_HLDNG_DLY_DELTA.DEP_TERM_IN_DAYS  as DEP_TERM_IN_DAYS_13
from
    ddwv01.RENW_NOTIF as RENW_NOTIF

    left join ddwv01.RB_CLNT_DLY as RB_CLNT_DLY
            on RENW_NOTIF.CLNT_NO = RB_CLNT_DLY.CLNT_NO
            and RB_CLNT_DLY.SNAP_DT = {wk_end}

    left join ddwv01.AR_DLY as AR_DLY
            on AR_DLY.AR_ID = RENW_NOTIF.AR_ID
            and AR_DLY.SNAP_DT = {wk_end}

    left join ddwv01.AR_STATIC_DLY as AR_STATIC_DLY
            on AR_STATIC_DLY.AR_ID = RENW_NOTIF.AR_ID
            and AR_STATIC_DLY.SNAP_DT = {wk_end}

    left join ddwv01.TRM_INVSTMT_HLDNG_DLY as TRM_INVSTMT_HLDNG_DLY
            on RENW_NOTIF.AR_ID = TRM_INVSTMT_HLDNG_DLY.AR_ID
            and TRM_INVSTMT_HLDNG_DLY.chg_dt = '9999-12-31'
            and TRM_INVSTMT_HLDNG_DLY.SRVC_ID = 14
            and TRM_INVSTMT_HLDNG_DLY.snap_dt = {wk_end}

    left join ddwv01.INVSTMT_HLDNG_DLY_DELTA as INVSTMT_HLDNG_DLY_DELTA
            on RENW_NOTIF.AR_ID = INVSTMT_HLDNG_DLY_DELTA.AR_ID
            and INVSTMT_HLDNG_DLY_DELTA.chg_dt = '9999-12-31'
            and INVSTMT_HLDNG_DLY_DELTA.SRVC_ID = 13

where
    RENW_PROD_NOTIF_TYP = 2
    and (SEP_DISCLSR_IND is null or SEP_DISCLSR_IND = 'Y')
    and RENW_NOTIF.SNAP_DT between {wk_start} and {wk_end}
""".format(wk_start=dates["wk_start_sql"], wk_end=dates["wk_end_sql"])

    logging.info("Executing rbis_noti_base_init Teradata pull...")
    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        rbis_noti_base_init = pd.read_sql(sql, conn)
    logging.info("Loaded %d rows into rbis_noti_base_init.", len(rbis_noti_base_init))
    return rbis_noti_base_init


def apply_bsc_filter(rbis_noti_base_init: pd.DataFrame) -> pd.DataFrame:
    """SAS: data rbis_noti_base; set rbis_noti_base_init; if bsc>=600 and bsc<=690;

    Then `proc sort by CLNT_NO AR_ID MTRTY_DT NOTIF_NO_OF_DYS;`
    """
    df = rbis_noti_base_init.copy()
    df.columns = [c.upper() for c in df.columns]
    df = df[(df["BSC"] >= 600) & (df["BSC"] <= 690)].copy()
    df = df.sort_values(
        by=["CLNT_NO", "AR_ID", "MTRTY_DT", "NOTIF_NO_OF_DYS"]
    ).reset_index(drop=True)
    logging.info("rbis_noti_base after BSC filter (600-690): %d rows", len(df))
    return df



# Pass/Fail classification -> rbis_noti_compare01
# (SAS: data rbis_noti_compare_reg_05 rbis_noti_compare_reg_21
#            rbis_noti_compare_nonreg_05 rbis_noti_compare_nonreg_21; ...)


def classify_pass_fail(rbis_noti_base: pd.DataFrame) -> pd.DataFrame:
    """Replicates the SAS DATA step that:
      - derives `deliverypreference` from NOTIF_DELVRY_PREF
      - re-asserts RENW_PROD_NOTIF_TYP = 2 (subsetting IF), drops SEP_DISCLSR_IND='N'
      - sets RegulatoryName/LOB/ReportName/ProductType literals
      - computes Total_days = MTRTY_DT - NOTIF_SENT_DT
      - classifies CommentCode/Comments (COM16 Pass / COM19 Potential Fail)
        per the 21-day and 5-day SLA windows, split by mail ('P') vs other
        delivery preference
      - computes total_term_day from SRVC_ID 14/13 term fields and derives
        thirty_day_ind
      - routes rows into 4 logical buckets by RGSTR_NO_RGSTR_IND x NOTIF_NO_OF_DYS
        (reg_05 / reg_21 / nonreg_05 / nonreg_21), unioned here into one frame
        with a `_bucket` column for traceability, mirroring the SAS
        `rbis_noti_compare01` UNION of the 4 output datasets.

    NOTE on missing-value parity: SAS missing numeric (.) propagates through
    comparisons as "unknown" (effectively false in IF conditions) and is LOW
    in sort order. Pandas NaN comparisons (`>=`, `<=`) also evaluate False,
    which matches SAS's IF-condition behavior here, so the Pass/Fail branches
    correctly fall through to 'Potential Fail' when Total_days is NaN (just
    as SAS would fail the IF test and hit the ELSE).
    """
    df = rbis_noti_base.copy()

    df["DELIVERYPREFERENCE"] = np.select(
        [df["NOTIF_DELVRY_PREF"] == "E", df["NOTIF_DELVRY_PREF"] == "P"],
        ["OLB Notification", "Mail"],
        default="Other",
    )

    # if RENW_PROD_NOTIF_TYP = 2; (subsetting IF -- redundant given upstream
    # WHERE filter, but preserved verbatim for fidelity)
    df = df[df["RENW_PROD_NOTIF_TYP"] == 2].copy()
    # if SEP_DISCLSR_IND = 'N' then delete;
    df = df[df["SEP_DISCLSR_IND"] != "N"].copy()

    df["REGULATORYNAME"] = "C86"
    df["LOB"] = "PSI"
    df["REPORTNAME"] = "C86 Notification Renewals"
    df["PRODUCTTYPE"] = "GIC"

    mtrty = pd.to_datetime(df["MTRTY_DT"], errors="coerce")
    sent = pd.to_datetime(df["NOTIF_SENT_DT"], errors="coerce")
    df["TOTAL_DAYS"] = (mtrty - sent).dt.days

    comment_code = pd.Series(np.nan, index=df.index, dtype=object)
    comments = pd.Series(np.nan, index=df.index, dtype=object)

    is_mail = df["NOTIF_DELVRY_PREF"] == "P"
    is_not_mail = df["NOTIF_DELVRY_PREF"] != "P"
    days21 = df["NOTIF_NO_OF_DYS"] == 21
    days5 = df["NOTIF_NO_OF_DYS"] == 5
    td = df["TOTAL_DAYS"]

    # 21-day, mail: pass if 32-36 days
    m = days21 & is_mail
    pass_21_mail = m & (td >= 32) & (td <= 36)
    comment_code = comment_code.mask(m & pass_21_mail, "COM16")
    comments = comments.mask(m & pass_21_mail, "Pass                  ")
    comment_code = comment_code.mask(m & ~pass_21_mail, "COM19")
    comments = comments.mask(m & ~pass_21_mail, "Potential Fail        ")

    # 21-day, non-mail: pass if 22-26 days
    m = days21 & is_not_mail
    pass_21_nonmail = m & (td >= 22) & (td <= 26)
    comment_code = comment_code.mask(m & pass_21_nonmail, "COM16")
    comments = comments.mask(m & pass_21_nonmail, "Pass                  ")
    comment_code = comment_code.mask(m & ~pass_21_nonmail, "COM19")
    comments = comments.mask(m & ~pass_21_nonmail, "Potential Fail        ")

    # 5-day, mail: pass if 16-20 days
    m = days5 & is_mail
    pass_5_mail = m & (td >= 16) & (td <= 20)
    comment_code = comment_code.mask(m & pass_5_mail, "COM16")
    comments = comments.mask(m & pass_5_mail, "Pass                  ")
    comment_code = comment_code.mask(m & ~pass_5_mail, "COM19")
    comments = comments.mask(m & ~pass_5_mail, "Potential Fail        ")

    # 5-day, non-mail: pass if 6-10 days
    m = days5 & is_not_mail
    pass_5_nonmail = m & (td >= 6) & (td <= 10)
    comment_code = comment_code.mask(m & pass_5_nonmail, "COM16")
    comments = comments.mask(m & pass_5_nonmail, "Pass                  ")
    comment_code = comment_code.mask(m & ~pass_5_nonmail, "COM19")
    comments = comments.mask(m & ~pass_5_nonmail, "Potential Fail        ")

    df["COMMENTCODE"] = comment_code
    df["COMMENTS"] = comments

    # total_term_day from SRVC_ID 14 or 13 term fields
    # SAS: if SRVC_ID = 14 then total_term_day = TRM_YRS_14*365 + TRM_DAYS_14;
    #      else if SRVC_ID = 13 then total_term_day = DEP_TERM_IN_YRS_13*365 + DEP_TERM_IN_DAYS_13;
    # Strict IF / ELSE IF -- SRVC_ID values other than 13/14 leave total_term_day missing.
    total_term_day = pd.Series(np.nan, index=df.index, dtype=float)
    srvc14 = df["SRVC_ID"] == 14
    srvc13_not14 = (df["SRVC_ID"] == 13) & ~srvc14
    total_term_day = total_term_day.mask(
        srvc14, df["TRM_YRS_14"].astype(float) * 365 + df["TRM_DAYS_14"].astype(float)
    )
    total_term_day = total_term_day.mask(
        srvc13_not14,
        df["DEP_TERM_IN_YRS_13"].astype(float) * 365 + df["DEP_TERM_IN_DAYS_13"].astype(float),
    )
    df["TOTAL_TERM_DAY"] = total_term_day

    thirty_day_ind = pd.Series(np.nan, index=df.index, dtype=object)
    thirty_day_ind = thirty_day_ind.mask(df["TOTAL_TERM_DAY"] > 30, "Renewals > 30 days")
    thirty_day_ind = thirty_day_ind.mask(
        (df["TOTAL_TERM_DAY"] <= 30) & (df["TOTAL_TERM_DAY"] >= 0), "Renewals <= 30 days"
    )
    thirty_day_ind = thirty_day_ind.mask(df["TOTAL_TERM_DAY"].isna(), "Renewals > 30 days")
    df["THIRTY_DAY_IND"] = thirty_day_ind

    # Output routing (4 buckets), preserved for traceability / parity checks
    conditions = [
        (df["RGSTR_NO_RGSTR_IND"] == "R") & (df["NOTIF_NO_OF_DYS"] == 5),
        (df["RGSTR_NO_RGSTR_IND"] == "R") & (df["NOTIF_NO_OF_DYS"] == 21),
        (df["RGSTR_NO_RGSTR_IND"] == "N") & (df["NOTIF_NO_OF_DYS"] == 5),
        (df["RGSTR_NO_RGSTR_IND"] == "N") & (df["NOTIF_NO_OF_DYS"] == 21),
    ]
    choices = ["reg_05", "reg_21", "nonreg_05", "nonreg_21"]
    df["_BUCKET"] = np.select(conditions, choices, default=None)

    # rows not matching any of the 4 ELSE IF branches are NOT output in SAS
    # (no final ELSE clause) -- drop them here to match.
    rbis_noti_compare01 = df[df["_BUCKET"].notna()].copy()
    logging.info(
        "rbis_noti_compare01 (4 buckets unioned): %d rows", len(rbis_noti_compare01)
    )
    return rbis_noti_compare01



