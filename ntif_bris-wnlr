def _pull_mif14(
    cfg: Config,
    dates: Dict[str, object],
    ar_id_list: List[str],
    clnt_no_list: List[str],
) -> pd.DataFrame:
    """SAS: create table mif_14 as select * from connection to teradata (...)

    SQL preserved verbatim from source; only the date literals and the two
    IN-lists (&gic_notif_list14., &gic_notif_list_clnt14.) are parameterized.
    """
    ar_ids_sql = ",".join("'{}'".format(x) for x in ar_id_list)
    clnt_nos_sql = ",".join(str(x) for x in clnt_no_list)

    sql = """
select distinct
    AR_DLY.AR_ID,
    CLNT_AR_RELTN_DLY.CLNT_NO,
    AR_DLY.SNAP_DT,
    AR_DLY.MTRTY_EXPRY_DT as mtrty_dt,
    AR_DLY.SRVC_ID ,
    AR_DLY.DT_CLS,
    AR_DLY.DT_OPEN,
    AR_DLY.OPEN_CLS_STS ,
    TRM_INVSTMT_HLDNG_DLY.DEP_TERM_IN_DAYS    as TRM_DAYS_14,
    TRM_INVSTMT_HLDNG_DLY.DEP_TERM_IN_YRS     as TRM_YRS_14,
    RB_CLNT_DLY.BSC,
    INVSTMT_HLDNG_DLY.PLN_NO,
    CAST(INVSTMT_HLDNG_DLY.PLN_NO as char(9)) as plan_number

from
    ddwv01.AR_DLY ,
    ddwv01.INVSTMT_HLDNG_DLY,
    ddwv01.CLNT_AR_RELTN_DLY
    left join ddwv01.TRM_INVSTMT_HLDNG_DLY as TRM_INVSTMT_HLDNG_DLY
            on CLNT_AR_RELTN_DLY.AR_ID = TRM_INVSTMT_HLDNG_DLY.AR_ID
            and TRM_INVSTMT_HLDNG_DLY.chg_dt = '9999-12-31'
            and TRM_INVSTMT_HLDNG_DLY.SRVC_ID = 14

        left join ddwv01.RB_CLNT_DLY as RB_CLNT_DLY
            on CLNT_AR_RELTN_DLY.CLNT_NO = RB_CLNT_DLY.CLNT_NO
            and CLNT_AR_RELTN_DLY.SNAP_DT = RB_CLNT_DLY.SNAP_DT
where
    AR_DLY.SNAP_DT = {wk_end}
    and CLNT_AR_RELTN_DLY.SNAP_DT = {wk_end}
    and INVSTMT_HLDNG_DLY.SNAP_DT = {wk_end}
    and AR_DLY.MTRTY_EXPRY_DT between {wk_start} and {mat_dt}
    and AR_DLY.AR_ID in ({ar_ids})
    and CLNT_AR_RELTN_DLY.CLNT_NO in ({clnt_nos})

    and AR_DLY.OPEN_CLS_STS ne 'C'
    and AR_DLY.AR_ID = CLNT_AR_RELTN_DLY.AR_ID
    and AR_DLY.SRVC_ID = CLNT_AR_RELTN_DLY.DW_SRVC_ID
    and AR_DLY.SNAP_DT = CLNT_AR_RELTN_DLY.SNAP_DT
    and INVSTMT_HLDNG_DLY.AR_ID = CLNT_AR_RELTN_DLY.AR_ID
    and INVSTMT_HLDNG_DLY.SNAP_DT = CLNT_AR_RELTN_DLY.SNAP_DT
order by
    1,2,3,4
""".format(
        wk_end=dates["wk_end_sql"],
        wk_start=dates["wk_start_sql"],
        mat_dt=dates["mat_dt_sql"],
        ar_ids=ar_ids_sql,
        clnt_nos=clnt_nos_sql,
    )

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        mif_14 = pd.read_sql(sql, conn)
    mif_14.columns = [c.upper() for c in mif_14.columns]
    logging.info("Loaded %d rows into mif_14.", len(mif_14))
    return mif_14


def _pull_arngmnt_option(
    cfg: Config, plan_numbers: List[str], order_alias: str = "all_plans"
) -> pd.DataFrame:
    """SAS: create table all_plans14a / all_plans13a as select * from connection to teradata(...)

    Both SAS blocks (14 and 13) use an identical query shape against
    ARNGMNT_OPTION, differing only by the plan-number IN-list. Implemented
    once here and reused for both srvc_id branches to avoid duplicating SQL
    text; the logic is byte-identical to both SAS blocks.
    """
    plans_sql = ",".join("'{}'".format(x) for x in plan_numbers)

    sql = """
select distinct
    ARNGMNT_OPTION.MIF_SRVC_ID,
    ARNGMNT_OPTION.CHOICE_CD_VAL_ID,
    ARNGMNT_OPTION.CHANGE_TMSTMP as PREF_CHANGE_TMSTMP,
    ARNGMNT_OPTION.DW_SRVC_ID as pln_DW_SRVC_ID,
    ARNGMNT_OPTION.PREF_ID ,
    right(ARNGMNT_OPTION.AR_ID,9) as plan_number
from
    ddwv01.ARNGMNT_OPTION
where right(ARNGMNT_OPTION.AR_ID,9) in ({plans})
    and
    ARNGMNT_OPTION.PREF_ID in (13001,13004)
    and ARNGMNT_OPTION.DW_SRVC_ID in (10,99)
order by
    6
""".format(plans=plans_sql)

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        all_plans_a = pd.read_sql(sql, conn)
    all_plans_a.columns = [c.upper() for c in all_plans_a.columns]
    logging.info("Loaded %d rows into %s.", len(all_plans_a), order_alias)
    return all_plans_a


def _clean_arngmnt_option(all_plans_a: pd.DataFrame) -> pd.DataFrame:
    """SAS:
        data all_plans14; set all_plans14a; if choice_cd_val_id in (17001,17002) then delete; run;
        proc sort data=all_plans14; by plan_number descending PREF_CHANGE_TMSTMP; run;
        proc sort data=all_plans14 nodupkey; by plan_number; run;   /* latest change only */
    """
    df = all_plans_a[~all_plans_a["CHOICE_CD_VAL_ID"].isin([17001, 17002])].copy()
    df = df.sort_values(
        by=["PLAN_NUMBER", "PREF_CHANGE_TMSTMP"], ascending=[True, False]
    )
    df = df.drop_duplicates(subset=["PLAN_NUMBER"], keep="first").reset_index(drop=True)
    return df


def _pull_mif13(
    cfg: Config,
    dates: Dict[str, object],
    ar_id_list: List[str],
    clnt_no_list: List[str],
) -> pd.DataFrame:
    """SAS: create table mif_13 as select * from connection to teradata (...)"""
    ar_ids_sql = ",".join("'{}'".format(x) for x in ar_id_list)
    clnt_nos_sql = ",".join(str(x) for x in clnt_no_list)

    sql = """
select distinct

    RBI_INVST_GIC_DLY_S.AR_ID,
    CLNT_AR_RELTN_DLY.CLNT_NO,
    RBI_INVST_GIC_DLY_S.SNAP_DT,
    RBI_INVST_GIC_DLY_S.SRVC_ID,
    RBI_INVST_GIC_DLY_S.MTRTY_DT ,
    RBI_INVST_GIC_DLY_S.STS_CD,
    INVSTMT_HLDNG_DLY_DELTA.DEP_TERM_IN_YRS    as DEP_TERM_IN_YRS_13,
    INVSTMT_HLDNG_DLY_DELTA.DEP_TERM_IN_DAYS   as DEP_TERM_IN_DAYS_13,
    RB_CLNT_DLY.BSC,
    FUND_HOLDING_TXN.PLN_NO,
    CAST(FUND_HOLDING_TXN.PLN_NO as char(9))   as plan_number
from
    ddwv01.RBI_INVST_GIC_DLY_S ,
    ddwv01.FUND_HOLDING_TXN ,
    ddwv01.CLNT_AR_RELTN_DLY

    left join ddwv01.INVSTMT_HLDNG_DLY_DELTA as INVSTMT_HLDNG_DLY_DELTA
            on CLNT_AR_RELTN_DLY.AR_ID = INVSTMT_HLDNG_DLY_DELTA.AR_ID
            and INVSTMT_HLDNG_DLY_DELTA.chg_dt = '9999-12-31'
            and INVSTMT_HLDNG_DLY_DELTA.SRVC_ID = 13
    left join ddwv01.RB_CLNT_DLY as RB_CLNT_DLY
            on CLNT_AR_RELTN_DLY.CLNT_NO = RB_CLNT_DLY.CLNT_NO
            and CLNT_AR_RELTN_DLY.SNAP_DT = RB_CLNT_DLY.SNAP_DT
where
    RBI_INVST_GIC_DLY_S.SNAP_DT = {wk_end}
    and CLNT_AR_RELTN_DLY.SNAP_DT = {wk_end}
    and RBI_INVST_GIC_DLY_S.MTRTY_DT between {wk_start} and {mat_dt}
    and RBI_INVST_GIC_DLY_S.STS_CD ne 'T'
    and RBI_INVST_GIC_DLY_S.AR_ID in ({ar_ids})
    and CLNT_AR_RELTN_DLY.CLNT_NO in ({clnt_nos})

    and RBI_INVST_GIC_DLY_S.AR_ID = CLNT_AR_RELTN_DLY.AR_ID
    and RBI_INVST_GIC_DLY_S.SRVC_ID = CLNT_AR_RELTN_DLY.DW_SRVC_ID
    and RBI_INVST_GIC_DLY_S.SNAP_DT = CLNT_AR_RELTN_DLY.SNAP_DT
    and FUND_HOLDING_TXN.AR_ID = CLNT_AR_RELTN_DLY.AR_ID
    and FUND_HOLDING_TXN.DW_SRVC_ID = CLNT_AR_RELTN_DLY.DW_SRVC_ID
order by
    1,2,3,5
""".format(
        wk_end=dates["wk_end_sql"],
        wk_start=dates["wk_start_sql"],
        mat_dt=dates["mat_dt_sql"],
        ar_ids=ar_ids_sql,
        clnt_nos=clnt_nos_sql,
    )

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        mif_13 = pd.read_sql(sql, conn)
    mif_13.columns = [c.upper() for c in mif_13.columns]

    # SAS: data mif_13; set mif_13;
    #      if length(plan_number) = 8 then plan_number = "0" || plan_number;
    # (left-pad plan_number to 9 chars when it came back as 8)
    def _pad(x: object) -> object:
        if pd.isna(x):
            return x
        s = str(x)
        if len(s) == 8:
            return "0" + s
        return s

    mif_13["PLAN_NUMBER"] = mif_13["PLAN_NUMBER"].apply(_pad)
    logging.info("Loaded %d rows into mif_13.", len(mif_13))
    return mif_13


def _pull_backdated(
    cfg: Config, dates: Dict[str, object], ar_id_list: List[str]
) -> pd.DataFrame:
    """SAS: create table backdated as select * from connection to teradata(...)

    Finds, per AR_ID, the earliest CLNT_AR_RELTN_DLY snapshot date AFTER
    back_date_limit -- used to detect backdated arrangement IDs.
    """
    ar_ids_sql = ",".join("'{}'".format(x) for x in ar_id_list)
    sql = """
select distinct

    CLNT_AR_RELTN_DLY.AR_ID,
    min(CLNT_AR_RELTN_DLY.SNAP_DT) as backdate_check

from

    ddwv01.CLNT_AR_RELTN_DLY
where
    AR_ID in ({ar_ids})
    and CLNT_AR_RELTN_DLY.SNAP_DT > {back_dt}
group by 1
order by 1
""".format(ar_ids=ar_ids_sql, back_dt=dates["back_dt_sql"])

    with get_teradata_connection(cfg.teradata_conn_json) as conn:
        backdated = pd.read_sql(sql, conn)
    backdated.columns = [c.upper() for c in backdated.columns]
    logging.info("Loaded %d rows into backdated.", len(backdated))
    return backdated


def find_fails(
    cfg: Config,
    dates: Dict[str, object],
    rbis_noti_compare01: pd.DataFrame,
) -> pd.DataFrame:
    """Replicates the %find_fails SAS macro end-to-end.

    Produces rbis_noti_compare_fails_final, the detail frame with `fail_reason`
    populated for genuine SLA-timeliness failures (after excluding rows whose
    "Potential Fail" was actually explainable by term-length, a late
    preference change, or a backdated arrangement).

    *** PARITY RISK -- FLAGGED, NOT SILENTLY RESOLVED ***
    The SAS source uses `MERGE ... BY ar_id clnt_no;` to join
    rbis_noti_compare_fails against mif_14_pref / mif_13_pref. SAS's
    match-merge for a BY-group containing duplicate keys on the "lookup"
    side does a sequential 1st-with-1st, 2nd-with-2nd pairing -- it is NOT
    a cartesian fan-out the way `pd.merge(how="left")` is. mif_14 / mif_13
    are pulled via `select distinct` over many columns without aggregating
    down to one row per (ar_id, clnt_no), so duplicate (ar_id, clnt_no)
    pairs in mif_14_pref / mif_13_pref are plausible (e.g. an AR_ID tied to
    multiple INVSTMT_HLDNG_DLY/PLN_NO rows). If that occurs in practice,
    `pd.merge` here WILL fan out rows where SAS's positional MERGE would
    not, breaking row-count parity.
    Action required before sign-off: confirm with the SAS author / via a
    parallel run whether (ar_id, clnt_no) is unique in mif_14/mif_13 for the
    real data. If duplicates are confirmed possible, this needs a
    positional-pairing reimplementation (e.g. groupby + cumcount-aligned
    merge) rather than a plain pandas merge. Implemented as a left-merge
    for now since that is the closest direct analogue and matches SAS
    exactly when keys are unique on the lookup side -- but this is an
    explicit fidelity gap, not a verified-safe shortcut.
    """
    rbis_noti_compare_fails = rbis_noti_compare01[
        rbis_noti_compare01["COMMENTCODE"] == "COM19"
    ].copy()
    logging.info("rbis_noti_compare_fails: %d rows", len(rbis_noti_compare_fails))

    fails_13 = rbis_noti_compare_fails[rbis_noti_compare_fails["SRVC_ID"] == 13]
    fails_14 = rbis_noti_compare_fails[rbis_noti_compare_fails["SRVC_ID"] == 14]

    size13 = fails_13["AR_ID"].count()
    size14 = fails_14["AR_ID"].count()
    logging.info("size13=%s size14=%s", size13, size14)

    # ---- SRVC_ID = 14 branch ----
    # *** FIDELITY FIX ***
    # SAS runs the `create table mif_14 as select * from connection to
    # teradata(...)` pull UNCONDITIONALLY -- only the downstream
    # ARNGMNT_OPTION pull (all_plans14a) is gated behind `%if &mif14.>0`.
    # An earlier draft of this conversion incorrectly gated the mif_14 pull
    # itself behind `size14 > 0`, which is a silent behavioral deviation
    # from the source and was not disclosed. Restored to unconditional here.
    #
    # NOTE: when size14 == 0, &gic_notif_list14. / &gic_notif_list_clnt14.
    # are never populated in the SAS source (the %if block that builds them
    # is skipped), so the generated SQL would contain literal empty
    # `IN ()` clauses -- this is a latent bug/edge case in the SAS script
    # itself (behavior would depend on how Teradata's SQL parser handles
    # `IN ()`; some dialects raise a syntax error, others treat it as
    # always-false). Rather than silently "fixing" this by skipping the
    # pull (the prior behavior) or guessing at Teradata's actual response,
    # we replicate the unconditional call but guard the Python-side IN-list
    # construction explicitly and log a loud warning so this edge case is
    # visible to whoever reviews a real run where size14 == 0, instead of
    # being silently papered over in either direction.
    ar_list14 = fails_14["AR_ID"].tolist()
    clnt_list14 = fails_14["CLNT_NO"].tolist()
    if size14 == 0:
        logging.warning(
            "size14=0: SAS source runs the mif_14 Teradata pull unconditionally "
            "with EMPTY &gic_notif_list14./&gic_notif_list_clnt14. macro "
            "variables in this case (a latent edge case in the SAS script, "
            "not something this script invented). Calling _pull_mif14 with "
            "empty ID lists to match; verify Teradata's behavior on IN () "
            "matches expectations, or confirm with the SAS author whether "
            "this path has ever actually been exercised in production."
        )
    mif_14 = _pull_mif14(cfg, dates, ar_list14, clnt_list14)
    mif14_count = mif_14["PLAN_NUMBER"].count()
    logging.info("mif14=%s", mif14_count)

    if mif14_count > 0:
        plan_list14 = mif_14["PLAN_NUMBER"].dropna().tolist()
        all_plans14a = _pull_arngmnt_option(cfg, plan_list14, "all_plans14a")
        all_plans14 = _clean_arngmnt_option(all_plans14a)

        mif_14_sorted = mif_14.sort_values(by=["PLAN_NUMBER"])
        mif_14_pref = pd.merge(
            all_plans14, mif_14_sorted, on="PLAN_NUMBER", how="outer"
        )
        mif_14_pref = mif_14_pref.sort_values(by=["AR_ID", "CLNT_NO"])

        fails_sorted = rbis_noti_compare_fails.sort_values(by=["AR_ID", "CLNT_NO"])
        rbis_noti_compare_fails14 = pd.merge(
            fails_sorted, mif_14_pref, on=["AR_ID", "CLNT_NO"], how="left",
            suffixes=("", "_mif14"),
        )
    else:
        rbis_noti_compare_fails14 = rbis_noti_compare_fails.copy()

    # ---- SRVC_ID = 13 branch ----
    # Same fidelity fix as above: SAS runs the mif_13 pull unconditionally.
    ar_list13 = fails_13["AR_ID"].tolist()
    clnt_list13 = fails_13["CLNT_NO"].tolist()
    if size13 == 0:
        logging.warning(
            "size13=0: SAS source runs the mif_13 Teradata pull unconditionally "
            "with EMPTY &gic_notif_list13./&gic_notif_list_clnt13. macro "
            "variables in this case. See size14==0 warning above for the "
            "same caveat applied to SRVC_ID=13."
        )
    mif_13 = _pull_mif13(cfg, dates, ar_list13, clnt_list13)
    mif13_count = mif_13["PLAN_NUMBER"].count()
    logging.info("mif13=%s", mif13_count)

    # ARNGMNT_OPTION pull (all_plans13a) remains correctly gated on mif13_count,
    # matching the SAS `%if &mif13. > 0` guard exactly.
    if mif13_count > 0:
        plan_list13 = mif_13["PLAN_NUMBER"].dropna().tolist()
        all_plans13a = _pull_arngmnt_option(cfg, plan_list13, "all_plans13a")
        all_plans13 = _clean_arngmnt_option(all_plans13a)

        mif_13_sorted = mif_13.sort_values(by=["PLAN_NUMBER"])
        mif_13_pref = pd.merge(
            all_plans13, mif_13_sorted, on="PLAN_NUMBER", how="outer"
        )
        mif_13_pref = mif_13_pref.sort_values(by=["AR_ID", "CLNT_NO"])

        fails14_sorted = rbis_noti_compare_fails14.sort_values(by=["AR_ID", "CLNT_NO"])
        rbis_noti_compare_fails_all = pd.merge(
            fails14_sorted, mif_13_pref, on=["AR_ID", "CLNT_NO"], how="left",
            suffixes=("", "_mif13"),
        )

        # backfill total_term_day from DT_OPEN where still missing
        mtrty = pd.to_datetime(rbis_noti_compare_fails_all["MTRTY_DT"], errors="coerce")
        ttd_missing = rbis_noti_compare_fails_all["TOTAL_TERM_DAY"].isna()
        srvc14_mask = rbis_noti_compare_fails_all["SRVC_ID"] == 14
        srvc13_mask = rbis_noti_compare_fails_all["SRVC_ID"] == 13

        if "DT_OPEN_MIF14" in rbis_noti_compare_fails_all.columns:
            dt_open14 = pd.to_datetime(
                rbis_noti_compare_fails_all["DT_OPEN_MIF14"], errors="coerce"
            )
            fill14 = ttd_missing & srvc14_mask
            rbis_noti_compare_fails_all.loc[fill14, "TOTAL_TERM_DAY"] = (
                mtrty[fill14] - dt_open14[fill14]
            ).dt.days

        if "DT_OPEN_MIF13" in rbis_noti_compare_fails_all.columns:
            dt_open13 = pd.to_datetime(
                rbis_noti_compare_fails_all["DT_OPEN_MIF13"], errors="coerce"
            )
            fill13 = ttd_missing & srvc13_mask
            rbis_noti_compare_fails_all.loc[fill13, "TOTAL_TERM_DAY"] = (
                mtrty[fill13] - dt_open13[fill13]
            ).dt.days

        pref_ts = pd.to_datetime(
            rbis_noti_compare_fails_all.get("PREF_CHANGE_TMSTMP"), errors="coerce"
        )
        rbis_noti_compare_fails_all["PREF_DATE"] = pref_ts.dt.date

        rbis_noti_compare_fails_all = _assign_fail_reason(
            rbis_noti_compare_fails_all
        )
    else:
        rbis_noti_compare_fails_all = _assign_fail_reason_no_pref(
            rbis_noti_compare_fails14
        )

    # rbis_noti_compare_fails_all2: rows still without a fail_reason after
    # the term-length / preference-change checks
    rbis_noti_compare_fails_all2 = rbis_noti_compare_fails_all[
        rbis_noti_compare_fails_all["FAIL_REASON"].isna()
        | (rbis_noti_compare_fails_all["FAIL_REASON"] == "")
    ].copy()
    backdtck = rbis_noti_compare_fails_all2["AR_ID"].count()
    logging.info("backdtck=%s", backdtck)

    if backdtck > 0:
        ar_list_bd = rbis_noti_compare_fails_all2["AR_ID"].tolist()
        backdated = _pull_backdated(cfg, dates, ar_list_bd)

        rbis_noti_compare_fails_final = pd.merge(
            rbis_noti_compare_fails_all, backdated, on="AR_ID", how="left"
        )

        sent = pd.to_datetime(
            rbis_noti_compare_fails_final["NOTIF_SENT_DT"], errors="coerce"
        )
        backdate_check = pd.to_datetime(
            rbis_noti_compare_fails_final["BACKDATE_CHECK"], errors="coerce"
        )
        day_diff = (backdate_check - sent).dt.days.abs()

        needs_reason = (
            rbis_noti_compare_fails_final["FAIL_REASON"].isna()
            | (rbis_noti_compare_fails_final["FAIL_REASON"] == "")
        )
        backdated_fail = needs_reason & backdate_check.notna() & (day_diff < 9)
        rbis_noti_compare_fails_final.loc[backdated_fail, "FAIL_REASON"] = (
            "Failed due to introduction of backdated arrangement id              "
        )
    else:
        rbis_noti_compare_fails_final = rbis_noti_compare_fails_all.copy()

    logging.info(
        "rbis_noti_compare_fails_final: %d rows", len(rbis_noti_compare_fails_final)
    )
    return rbis_noti_compare_fails_final


def _assign_fail_reason(df: pd.DataFrame) -> pd.DataFrame:
    """SAS fail_reason assignment block (mif13 > 0 branch):

        if NOTIF_NO_OF_DYS = 21 and NOTIF_DELVRY_PREF = 'P' then do;
            if total_term_day < 32 then fail_reason = 'Failed due to term length...';
        end;
        if NOTIF_NO_OF_DYS = 5 and NOTIF_DELVRY_PREF = 'P' then do;
            if total_term_day < 16 then fail_reason = 'Failed due to term length...';
        end;
        if fail_reason = '' and pref_date ne . and
            abs(intck('day', pref_date, NOTIF_SENT_DT)) < 9 then
            fail_reason = 'Failed due to introduction of Paper Pref after regulatory SLA minimum range';
    """
    df = df.copy()
    df["FAIL_REASON"] = pd.Series([np.nan] * len(df), index=df.index, dtype=object)

    cond21 = (df["NOTIF_NO_OF_DYS"] == 21) & (df["NOTIF_DELVRY_PREF"] == "P")
    df.loc[cond21 & (df["TOTAL_TERM_DAY"] < 32), "FAIL_REASON"] = (
        "Failed due to term length being under regulatory SLA minimum range            "
    )

    cond5 = (df["NOTIF_NO_OF_DYS"] == 5) & (df["NOTIF_DELVRY_PREF"] == "P")
    df.loc[cond5 & (df["TOTAL_TERM_DAY"] < 16), "FAIL_REASON"] = (
        "Failed due to term length being under regulatory SLA minimum range            "
    )

    no_reason_yet = df["FAIL_REASON"].isna() | (df["FAIL_REASON"] == "")
    pref_date = pd.to_datetime(df["PREF_DATE"], errors="coerce")
    sent = pd.to_datetime(df["NOTIF_SENT_DT"], errors="coerce")
    day_diff = (pref_date - sent).dt.days.abs()
    pref_cond = no_reason_yet & pref_date.notna() & (day_diff < 9)
    df.loc[pref_cond, "FAIL_REASON"] = (
        "Failed due to introduction of Paper Pref after regulatory SLA minimum range"
    )
    return df


def _assign_fail_reason_no_pref(df: pd.DataFrame) -> pd.DataFrame:
    """SAS fail_reason assignment block (mif13 <= 0 branch -- no PREF_DATE
    join available, so only the term-length checks apply):

        if NOTIF_NO_OF_DYS = 21 and NOTIF_DELVRY_PREF = 'P' then do;
            if total_term_day < 32 then fail_reason = 'Failed due to term length...';
        end;
        if NOTIF_NO_OF_DYS = 5 and NOTIF_DELVRY_PREF = 'P' then do;
            if total_term_day < 16 then fail_reason = 'Failed due to term length...';
        end;
    """
    df = df.copy()
    df["FAIL_REASON"] = pd.Series([np.nan] * len(df), index=df.index, dtype=object)

    cond21 = (df["NOTIF_NO_OF_DYS"] == 21) & (df["NOTIF_DELVRY_PREF"] == "P")
    df.loc[cond21 & (df["TOTAL_TERM_DAY"] < 32), "FAIL_REASON"] = (
        "Failed due to term length being under regulatory SLA minimum range            "
    )

    cond5 = (df["NOTIF_NO_OF_DYS"] == 5) & (df["NOTIF_DELVRY_PREF"] == "P")
    df.loc[cond5 & (df["TOTAL_TERM_DAY"] < 16), "FAIL_REASON"] = (
        "Failed due to term length being under regulatory SLA minimum range            "
    )
    return df



# Autocomplete aggregation -> ac_time_rbis_noti_{reg,nonreg}_{05,21}
# (4x SAS `proc sql; create table ... group by ...` blocks)


_AC_BLOCK_SPECS = [
    # (bucket_name, RDE literal, Segment3 literal)
    ("reg_05", "Notif014_Timeliness_SLA", "Registered GIC"),
    ("reg_21", "Notif013_Timeliness_SLA", "Registered GIC"),
    ("nonreg_05", "Notif016_Timeliness_SLA", "Non-Registered GIC"),
    ("nonreg_21", "Notif015_Timeliness_SLA", "Non-Registered GIC"),
]
_AC_SEGMENT2 = {"05": "5 days", "21": "21 days"}


def _build_ac_block(
    bucket_df: pd.DataFrame, rde: str, segment3: str, segment2: str, dates: Dict[str, object]
) -> pd.DataFrame:
    """Replicates one of the 4 `ac_time_rbis_noti_*` SAS proc sql aggregations.

    SAS source (per block, e.g. reg_05):
        select
            RegulatoryName, LOB, ReportName,
            'Timeliness' as ControlRisk, 'Anomaly' as TestType,
            'Portfolio' as TestPeriod, ProductType,
            'Notif014_Timeliness_SLA' as RDE, '' as SubDE,
            'Renewals' as Segment, '5 days' as Segment2,
            'Registered GIC' as Segment3,
            thirty_day_ind as Segment4, deliverypreference as Segment5,
            '' as Segment6, '' as Segment7, '' as Segment8,
            put(Total_days, 8.-L) as Segment9,
            put(SNAP_DT, yymmn6.) as segment10,
            'N' as HoldoutFlag, CommentCode, Comments,
            count(*) as Volume, . as Bal, . as Amount,
            input(&today2., yymmdd10.) as DateCompleted,
            intnx('week.7', NOTIF_SENT_DT, 1, 'B') as SnapDate
        from rbis_noti_compare_reg_05
        group by 1..22,26,27   -- i.e. all selected columns except Volume/Bal/Amount,
                                -- but including DateCompleted and SnapDate
        order by 1,2,27
    """
    df = bucket_df.copy()
    if df.empty:
        cols = [
            "RegulatoryName", "LOB", "ReportName", "ControlRisk", "TestType",
            "TestPeriod", "ProductType", "RDE", "SubDE", "Segment", "Segment2",
            "Segment3", "Segment4", "Segment5", "Segment6", "Segment7",
            "Segment8", "Segment9", "Segment10", "HoldoutFlag", "CommentCode",
            "Comments", "Volume", "Bal", "Amount", "DateCompleted", "SnapDate",
        ]
        return pd.DataFrame(columns=cols)

    notif_sent = pd.to_datetime(df["NOTIF_SENT_DT"], errors="coerce")
    snap_dt_src = pd.to_datetime(df["SNAP_DT"], errors="coerce")

    out = pd.DataFrame(
        {
            "RegulatoryName": df["REGULATORYNAME"],
            "LOB": df["LOB"],
            "ReportName": df["REPORTNAME"],
            "ControlRisk": "Timeliness",
            "TestType": "Anomaly",
            "TestPeriod": "Portfolio",
            "ProductType": df["PRODUCTTYPE"],
            "RDE": rde,
            "SubDE": "",
            "Segment": "Renewals",
            "Segment2": segment2,
            "Segment3": segment3,
            "Segment4": df["THIRTY_DAY_IND"],
            "Segment5": df["DELIVERYPREFERENCE"],
            "Segment6": "",
            "Segment7": "",
            "Segment8": "",
            # put(Total_days, 8.-L) -> left-justified numeric-as-string
            "Segment9": df["TOTAL_DAYS"].apply(
                lambda x: "" if pd.isna(x) else str(int(x))
            ),
            "Segment10": snap_dt_src.dt.strftime("%Y%m"),
            "HoldoutFlag": "N",
            "CommentCode": df["COMMENTCODE"],
            "Comments": df["COMMENTS"],
            "DateCompleted": pd.to_datetime(dates["today2"]),
            "SnapDate": notif_sent.apply(
                lambda d: pd.NaT if pd.isna(d) else _week7_anchor(d.date(), n=1, align="b")
            ),
        }
    )
    out["SnapDate"] = pd.to_datetime(out["SnapDate"])

    group_cols = [c for c in out.columns]
    grouped = (
        out.groupby(group_cols, dropna=False).size().reset_index(name="Volume")
    )
    grouped["Bal"] = np.nan
    grouped["Amount"] = np.nan
    grouped = grouped.sort_values(by=["RegulatoryName", "LOB", "SnapDate"]).reset_index(
        drop=True
    )
    return grouped


def build_autocomplete_tables(
    rbis_noti_compare01: pd.DataFrame, dates: Dict[str, object]
) -> pd.DataFrame:
    """Builds and unions the 4 ac_time_rbis_noti_* blocks into renew_gic_ac_curr.

    SAS source:
        data notidata.renew_gic_ac_&rundt. renew_gic_ac_curr;
            format segment $150. segment2 $150. segment3 $150. ;
            set ac_time_rbis_noti_nonreg_05 ac_time_rbis_noti_nonreg_21
                ac_time_rbis_noti_reg_05    ac_time_rbis_noti_reg_21;
        run;
    NOTE: SAS unions in the order nonreg_05, nonreg_21, reg_05, reg_21 --
    preserved here for row-order fidelity even though it's a UNION.
    """
    blocks = {}
    for bucket, rde, segment3 in _AC_BLOCK_SPECS:
        days_key = bucket.split("_")[-1]
        segment2 = _AC_SEGMENT2[days_key]
        bucket_df = rbis_noti_compare01[rbis_noti_compare01["_BUCKET"] == bucket]
        blocks[bucket] = _build_ac_block(bucket_df, rde, segment3, segment2, dates)

    renew_gic_ac_curr = pd.concat(
        [blocks["nonreg_05"], blocks["nonreg_21"], blocks["reg_05"], blocks["reg_21"]],
        ignore_index=True,
    )
    logging.info("renew_gic_ac_curr: %d rows", len(renew_gic_ac_curr))
    return renew_gic_ac_curr



# %Timeliness macro -> apply_timeliness_append()


def apply_timeliness_append(
    cfg: Config,
    ini_run: str,
    renew_gic_ac_curr: pd.DataFrame,
    dates: Dict[str, object],
) -> pd.DataFrame:
    """Replicates the %Timeliness SAS macro.

    SAS source:
        %macro Timeliness;
        %if &ini_run = 'Y' %then %do;
            data notidata.renew_gic_ac notif_m.cnac_renew_gic_ac;
            set renew_gic_ac_curr;
            run;
        %end;
        %else %do;
            data notidata.renew_gic_ac notif_m.cnac_renew_gic_ac;
            set notidata.renew_gic_ac (where=(SnapDate ne &sasdt2.))
                renew_gic_ac_curr;
            run;
        %end;
        %mend;

    `notif_m.cnac_renew_gic_ac` is a separate downstream library write (the
    "MAIN_NOTIF" libname) -- both targets receive an identical frame in SAS.
    This function returns a single DataFrame representing the content for
    both write targets; `export_autocomplete()` is responsible for actually
    persisting it to both `cfg.outpath` (notidata.renew_gic_ac) and
    `cfg.notif_m_outpath` (notif_m.cnac_renew_gic_ac) -- confirmed done in
    that function, not merely assumed.
    """
    persistent_file = cfg.outpath / cfg.persistent_ac_file

    if ini_run.upper() == "Y":
        notidata_renew_gic_ac = renew_gic_ac_curr.copy()
    else:
        existing = pd.read_parquet(persistent_file)
        existing["SnapDate"] = pd.to_datetime(existing["SnapDate"], errors="coerce")
        wk_end_as_snapdate = pd.to_datetime(dates["wk_end"])
        existing_filtered = existing[existing["SnapDate"] != wk_end_as_snapdate].copy()
        notidata_renew_gic_ac = pd.concat(
            [existing_filtered, renew_gic_ac_curr], ignore_index=True
        )

    logging.info("notidata.renew_gic_ac (post-Timeliness): %d rows", len(notidata_renew_gic_ac))
    return notidata_renew_gic_ac



# Fail detail export -> rbis_noti_time_fail_wk_&ymd.


def build_fail_detail(
    rbis_noti_compare_fails_final: pd.DataFrame, dates: Dict[str, object]
) -> pd.DataFrame:
    """Replicates the SAS `data notidata.rbis_noti_time_fail_wk_&ymd.` step.

    SAS source (keep= list controls output column set):
        keep= event_month event_week_ending lob product Type_of_Notification
              NOTIF_NO_OF_DYS AR_id Notification_Delivery_Type clientid_mask
              Account_number Certificate_number Renewal_Date NOTIF_SENT_DT
              renewal_rule date_completed Total_days fail_reason
              DT_OPEN_mif14 DT_OPEN_mif13 pref_date backdate_check
        if Comments = 'Potential Fail        '; (subsetting IF)
        event_month = put(NOTIF_SENT_DT, yymmn6.);
        ... (see field assignments below)
        clientid_mask = substr(CLNT_NO,7,3);
        date_completed = input(&today2., yymmdd10.);
        event_week_ending = intnx('week.7',NOTIF_SENT_DT,0,'e');
        if RGSTR_NO_RGSTR_IND='N' then product='Non-Registered GIC';
        else if RGSTR_NO_RGSTR_IND='R' then product='Registered GIC ';

    DELIBERATELY OMITTED (confirmed dead-on-arrival in the SAS source, not
    silently dropped): the SAS DATA step also assigns
        Campaign_id = "N/A"; Credit_card_account = "N/A"; promo_rule = "N/A";
        Transit = ACCT_TR_NO; Segment_number = seg_no;
    None of these five appear in the `keep=` list above, so SAS computes
    them and then discards them before the dataset is materialized -- they
    have zero effect on notidata.rbis_noti_time_fail_wk_&ymd. or its Excel
    export. Omitted here for the same reason (output-column parity with
    the keep= list), not because they were overlooked.
    """
    df = rbis_noti_compare_fails_final.copy()
    df = df[df["COMMENTS"] == "Potential Fail        "].copy()

    notif_sent = pd.to_datetime(df["NOTIF_SENT_DT"], errors="coerce")

    out = pd.DataFrame()
    out["event_month"] = notif_sent.dt.strftime("%Y%m")
    out["event_week_ending"] = notif_sent.apply(
        lambda d: pd.NaT if pd.isna(d) else _week7_anchor(d.date(), n=0, align="e")
    )
    out["lob"] = df.get("LOB")
    out["product"] = np.select(
        [df["RGSTR_NO_RGSTR_IND"] == "N", df["RGSTR_NO_RGSTR_IND"] == "R"],
        ["Non-Registered GIC", "Registered GIC "],
        default=None,
    )
    out["Type_of_Notification"] = df["THIRTY_DAY_IND"]
    out["NOTIF_NO_OF_DYS"] = df["NOTIF_NO_OF_DYS"]
    out["AR_id"] = df["AR_ID"]
    out["Notification_Delivery_Type"] = df["DELIVERYPREFERENCE"]
    out["clientid_mask"] = df["CLNT_NO"].astype(str).str.slice(6, 9)
    out["Account_number"] = df["ACCT_NO"]
    out["Certificate_number"] = df["CERT_NO"]
    out["Renewal_Date"] = pd.to_datetime(df["MTRTY_DT"], errors="coerce")
    out["NOTIF_SENT_DT"] = notif_sent
    out["renewal_rule"] = np.select(
        [df["NOTIF_NO_OF_DYS"] == 21, df["NOTIF_NO_OF_DYS"] == 5],
        ["21 days", "5 days "],
        default=None,
    )
    out["date_completed"] = pd.to_datetime(dates["today2"])
    out["Total_days"] = df["TOTAL_DAYS"]
    out["fail_reason"] = df.get("FAIL_REASON")
    out["DT_OPEN_mif14"] = pd.to_datetime(df.get("DT_OPEN_MIF14"), errors="coerce")
    out["DT_OPEN_mif13"] = pd.to_datetime(df.get("DT_OPEN_MIF13"), errors="coerce")
    out["pref_date"] = pd.to_datetime(df.get("PREF_DATE"), errors="coerce")
    out["backdate_check"] = pd.to_datetime(df.get("BACKDATE_CHECK"), errors="coerce")

    # Exact keep= column order from SAS
    keep_order = [
        "event_month", "event_week_ending", "lob", "product",
        "Type_of_Notification", "NOTIF_NO_OF_DYS", "AR_id",
        "Notification_Delivery_Type", "clientid_mask", "Account_number",
        "Certificate_number", "Renewal_Date", "NOTIF_SENT_DT", "renewal_rule",
        "date_completed", "Total_days", "fail_reason", "DT_OPEN_mif14",
        "DT_OPEN_mif13", "pref_date", "backdate_check",
    ]
    out = out[keep_order]
    logging.info("rbis_noti_time_fail (detail): %d rows", len(out))
    return out



# Export helpers (proc export ... dbms=xlsx replace; / persistent parquet)


def export_autocomplete(
    cfg: Config, notidata_renew_gic_ac: pd.DataFrame
) -> Path:
    """SAS:
        data notidata.renew_gic_ac notif_m.cnac_renew_gic_ac;
            ...
        run;  (the %Timeliness macro -- see apply_timeliness_append)

        proc export data=notidata.renew_gic_ac
            outfile="&outpath/renew_gic_autocomplete"
            dbms=xlsx replace;
            sheet="renew_gio_autocomplete";
        run;

    Persists the SAS DATA step's TWO write targets:
      1. notidata.renew_gic_ac  -> cfg.outpath / cfg.persistent_ac_file
      2. notif_m.cnac_renew_gic_ac -> cfg.notif_m_outpath / cfg.cnac_persistent_file
    Both receive byte-identical content in the SAS source (a single `set`
    statement feeding two output datasets in one DATA step), so the same
    DataFrame is written to both locations here. An earlier draft of this
    conversion only wrote target #1 and silently dropped target #2 --
    fixed.

    Also exports the Excel rendition of notidata.renew_gic_ac (proc export).

    TODO: add S3 upload of the parquet(s) and the Excel file via
    upload_file_to_s3()/write_parquet_to_s3() once S3 wiring is enabled
    (see C86_pa_client360.py reference: s3_path("output", ...)).
    """
    cfg.outpath.mkdir(parents=True, exist_ok=True)
    cfg.notif_m_outpath.mkdir(parents=True, exist_ok=True)

    # Target 1: notidata.renew_gic_ac
    persistent_file = cfg.outpath / cfg.persistent_ac_file
    notidata_renew_gic_ac.to_parquet(persistent_file, index=False)
    logging.info("Saved persistent autocomplete file: %s", persistent_file)

    # Target 2: notif_m.cnac_renew_gic_ac (same content, separate library/path)
    cnac_file = cfg.notif_m_outpath / cfg.cnac_persistent_file
    notidata_renew_gic_ac.to_parquet(cnac_file, index=False)
    logging.info("Saved notif_m.cnac_renew_gic_ac equivalent: %s", cnac_file)

    excel_path = cfg.outpath / cfg.excel_autocomplete_file
    with pd.ExcelWriter(excel_path, engine="openpyxl") as writer:
        notidata_renew_gic_ac.to_excel(
            writer, sheet_name="renew_gio_autocomplete", index=False
        )
    logging.info("Exported autocomplete Excel: %s", excel_path)
    return excel_path


def export_fail_detail(cfg: Config, fail_detail: pd.DataFrame, ymd: str) -> Path:
    """SAS:
        data notidata.rbis_noti_time_fail_wk_&ymd.(keep= ...);
        set rbis_noti_compare_fails_final;
        ...
        run;

        proc export data=notidata.rbis_noti_time_fail_wk_&ymd.
            outfile="&outpath/Notif_RBIS_Renew_Timeliness_Detail"
            dbms=xlsx replace;
            sheet="Notif_RBIS_Renew_Time";
