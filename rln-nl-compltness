logger = logging.getLogger("C86_notif_rbis_completeness")


def _configure_logging(level: int = logging.INFO) -> None:
    if logger.handlers:
        return
    handler = logging.StreamHandler()
    handler.setFormatter(logging.Formatter("%(asctime)s  %(levelname)-5s  %(message)s"))
    logger.addHandler(handler)
    logger.setLevel(level)


class step:
    """Context manager that brackets a logical block, SAS-log style."""

    def __init__(self, title: str) -> None:
        self.title = title

    def __enter__(self) -> "step":
        logger.info(">>>>>>>>> %s <<<<<<<<<", self.title)
        self._t0 = dt.datetime.now()
        return self

    def __exit__(self, exc_type, exc, tb) -> None:
        elapsed = (dt.datetime.now() - self._t0).total_seconds()
        if exc_type is None:
            logger.info("--------- %s done (%.2fs) ---------", self.title, elapsed)
        else:
            logger.error("--------- %s FAILED: %s ---------", self.title, exc)


 #
# Date window logic
 #
# SAS reference:
#   tday    = intnx('week.3', today(), 0)   -> snap back to this week's TUESDAY
#   week_end = tday - 3                      -> the SATURDAY before that Tuesday
#   snapdt   = tday - 1                      -> the MONDAY before (data SNAP_DT)
#   week_start = week_end - 6                -> Sunday  (Sun–Sat reporting week)
#   formpulldt = week_end - 21               -> 1-week+ lookback for RENW_NOTIF
#   e05end = week_end + 6 ; e21str = +16 ; e21end = +22
#   p05str = +10 ; p05end = +16 ; p21str = +26 ; p21end = +32 (= endrange)
#
# `week.3` defines a week beginning on its 3rd day = Tuesday. intnx with the
# default BEGINNING alignment and 0 offset returns the start (Tuesday) of the
# week containing `today`. Because the week is Tue-anchored, any run date from
# Tuesday through the following Monday maps to the SAME window — which is why
# the job is robust to not running exactly on Tuesday.

SAS_EPOCH = dt.date(1960, 1, 1)  # SAS day 0


def sas_week3_tuesday(today: dt.date) -> dt.date:
    """Return the Tuesday of the SAS `week.3` week containing ``today``.

    Equivalent to ``intnx('week.3', today, 0)`` with BEGINNING alignment.
    Python weekday(): Mon=0 .. Sun=6, so Tuesday == 1.
    """
    offset = (today.weekday() - 1) % 7  # days since the most recent Tuesday
    return today - dt.timedelta(days=offset)


class DateWindow:
    """All derived dates for one run, mirroring the SAS `data _null_` block."""

    def __init__(self, run_date: dt.date) -> None:
        self.run_date = run_date
        tday = sas_week3_tuesday(run_date)

        self.week_end = tday - dt.timedelta(days=3)        # Saturday
        self.snap_dt = tday - dt.timedelta(days=1)         # Monday (SNAP_DT)
        self.week_start = self.week_end - dt.timedelta(days=6)  # Sunday
        self.formpull = self.week_end - dt.timedelta(days=21)

        self.e05end = self.week_end + dt.timedelta(days=6)
        self.e21str = self.week_end + dt.timedelta(days=16)
        self.e21end = self.week_end + dt.timedelta(days=22)
        self.p05str = self.week_end + dt.timedelta(days=10)
        self.p05end = self.week_end + dt.timedelta(days=16)
        self.p21str = self.week_end + dt.timedelta(days=26)
        self.p21end = self.week_end + dt.timedelta(days=32)  # endrange

        self.today2 = run_date  # SAS today2 = intnx('day', today, 0)

    # -- helpers for the Teradata SQL literals (DATE 'yyyy-mm-dd') ---------- #
    @staticmethod
    def td(d: dt.date) -> str:
        """Render a date as a Teradata DATE literal."""
        return f"DATE '{d.isoformat()}'"

    def log(self) -> None:
        for name in (
            "run_date", "week_start", "week_end", "snap_dt", "formpull",
            "e05end", "e21str", "e21end", "p05str", "p05end",
            "p21str", "p21end", "today2",
        ):
            logger.info("  %-12s = %s", name, getattr(self, name).isoformat())


