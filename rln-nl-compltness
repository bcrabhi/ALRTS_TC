def _coerce_id_strings(df: pd.DataFrame) -> pd.DataFrame:
    """Defensive: force known ID columns to string dtype if a stub returns
    them numeric. Real connector should already do this."""
    for col in df.columns:
        if col in _STRING_ID_COLS:
            df[col] = df[col].astype("string").str.strip()
    return df


